  §string.contains(feed,"<feed xmlns=\"http://www.w3.org/2005/Atom\">") and §string.contains(feed,"https://inerte.github.io/sigil/feed.xml") and §string.contains(feed,"https://inerte.github.io/sigil/articles/worlds-not-mocks/") and §string.contains(feed,"<title>Worlds, Not Mocks</title>")
}

