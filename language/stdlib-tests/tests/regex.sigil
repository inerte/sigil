i stdlib::regex

λmain()=>Unit=()

test "regex compile accepts valid patterns" {
  match stdlib::regex.compile("","^a+$"){
    Ok(regex)=>regex.flags="" and regex.pattern="^a+$"|
    Err(_)=>false
  }
}

test "regex compile rejects invalid patterns" {
  match stdlib::regex.compile("",")"){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "regex find returns first capture set" {
  match stdlib::regex.compile("","([a-z]+)([0-9]+)"){
    Ok(regex)=>match stdlib::regex.find("abc123xyz",regex){
      Some(found)=>found.captures=["abc","123"] and found.end=6 and found.full="abc123" and found.start=0|
      None()=>false
    }|
    Err(_)=>false
  }
}

test "regex find returns none when absent" {
  match stdlib::regex.compile("","z+"){
    Ok(regex)=>match stdlib::regex.find("abc",regex){
      Some(_)=>false|
      None()=>true
    }|
    Err(_)=>false
  }
}

test "regex flags affect matching" {
  match stdlib::regex.compile("i","^abc$"){
    Ok(regex)=>stdlib::regex.isMatch("ABC",regex)|
    Err(_)=>false
  }
}

test "regex isMatch reports non-matches" {
  match stdlib::regex.compile("","^abc$"){
    Ok(regex)=>¬stdlib::regex.isMatch("ab",regex)|
    Err(_)=>false
  }
}
