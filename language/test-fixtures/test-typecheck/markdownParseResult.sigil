⟦ Test: Exact structure from markdown.sigil ⟧

t Block=Header(Int,String)|Paragraph(String)

t ParseResult={blocks:[Block],state:ParseState}

t ParseState={
  codeLang:String,
  codeLines:[String],
  inCodeBlock:Bool,
  paraLines:[String]
}

λmain()=>Unit=()

λtest(x:Bool)=>ParseResult match x{
  true=>{blocks:[],state:{codeLang:"",codeLines:[],inCodeBlock:false,paraLines:[]}}|
  false=>{blocks:[Paragraph("hi")],state:{codeLang:"js",codeLines:["test"],inCodeBlock:true,paraLines:[]}}
}
