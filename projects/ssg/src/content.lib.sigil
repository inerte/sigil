Î»compareArticlePages(left:srcâ‹…types.SitePage,right:srcâ‹…types.SitePage)â†’Bool=
  l leftKey=(dateSortKey(left.meta.date):Int);
  l rightKey=(dateSortKey(right.meta.date):Int);
  match leftKey=rightKey{
    trueâ†’compareText(right.sourcePath,left.sourcePath)|
    falseâ†’leftKey>rightKey
  }

Î»compareText(left:String,right:String)â†’Bool=
  compareTextInner(
    0,
    stdlibâ‹…string.toLower(left),
    stdlibâ‹…string.toLower(right)
