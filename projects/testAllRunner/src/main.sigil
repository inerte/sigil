λpackageInstallCommand(projectRoot:String,root:String)=>§process.Command=sigilCommandIn(
  [
    "package",
    "install"
  ],
  projectRoot,
  root
)

λpackageInstallCommands(root:String)=>[§process.Command]=[packageInstallCommand(
  featureFlagStorefrontRoot(root),
  root
)]

λparallelSuites(root:String)=>[µParallelSuite]=[
  algorithmsSuite(root),
  canonicalIntegrationSuite(root),
  featureFlagStorefrontSuite(root),
  flashcardsSuite(root),
  game2048Suite(root),
  labelledBoundariesSuite(root),
  languageSuite(root),
  minesweepSuite(root),
  multimoduleSuite(root),
  roguelikeSuite(root),
  ssgSuite(root),
  stdlibSuite(root),
  todoSuite(root)
]

λpnpmCommand(args:[String],root:String)=>§process.Command=§process.withCwd(
  §process.command(["pnpm"]⧺args),
  root
)

λprintBatchResults(results:[µSuiteResult])=>!CliIo Unit
decreases #results
match results{
  []=>()|
  [
  head,
  .tail
]=>{
    l _=(printSuiteResult(head):Unit);
    printBatchResults(tail)
  }
}

λprintResultOutput(result:§process.ProcessResult)=>!CliIo Unit={
  l _=(match #result.stdout>0{
    true=>(§io.print(result.stdout):Unit)|
    false=>()
  }:Unit);
  match #result.stderr>0{
    true=>(§io.eprintln(result.stderr):Unit)|
    false=>()
  }
}

λprintSuiteResult(suite:µSuiteResult)=>!CliIo Unit={
  l _=(§io.println(""):Unit);
  l _=(§io.println("==> "++suite.label):Unit);
  printResultOutput(suite.result)
}

λrenderCommand(args:[String])=>String match args{
  []=>""|
  [
  head,
  .tail
]=>renderCommandRest(
    §path.basename(head),
    tail
  )
}

λrenderCommandRest(acc:String,args:[String])=>String
decreases #args
match args{
  []=>acc|
  [
  head,
  .tail
]=>renderCommandRest(
    acc
      ++" "
      ++head,
    tail
  )
}

λrepoAuditRoot(root:String)=>String=§path.join(
  §path.join(
    root,
    "projects"
  ),
  "repoAudit"
)

λrepoRoot()=>!Process Result[
  String,
  String
]={
  l result=(§process.run(§process.command([
    "git",
    "rev-parse",
    "--show-toplevel"
  ])):§process.ProcessResult);
  match result.code=0{
    true=>Ok(§string.trim(result.stdout))|
    false=>Err(match #result.stderr>0{
      true=>§string.trim(result.stderr)|
      false=>"failed to resolve repo root"
    })
  }
}

λroguelikeRoot(root:String)=>String=§path.join(
  §path.join(
    root,
    "projects"
  ),
  "roguelike"
)

λroguelikeSuite(root:String)=>µParallelSuite={
  command:sigilCommandIn(
    [
      "test",
      "tests"
    ],
    roguelikeRoot(root),
    root
  ),
  label:"roguelike suite"
}

λrunCommands(commands:[§process.Command])=>!CliIo Result[
  Unit,
  String
]
decreases #commands
match commands{
  []=>Ok(())|
  [
  command,
  .rest
]=>{
    l result=(§process.run(command):§process.ProcessResult);
    l _=(printResultOutput(result):Unit);
    match result.code=0{
      true=>runCommands(rest)|
      false=>Err(failedCommandMessage(
        command,
        result
      ))
    }
  }
}

λrunParallelBatch(suites:[µParallelSuite])=>!CliIo Result[
  Unit,
  String
]=runStartedSuites(
  suites,
  []
)

λrunSerialStep(step:µSerialStep)=>!CliIo Result[
  Unit,
  String
]={
  l _=(§io.println(""):Unit);
  l _=(§io.println("==> "++step.label):Unit);
  runCommands(step.commands)
}

λrunStartedSuites(remaining:[µParallelSuite],started:[µStartedSuite])=>!CliIo Result[
  Unit,
  String
]
decreases #remaining
match remaining{
  []=>{
    l results=(waitSuites(started):[µSuiteResult]);
    l _=(printBatchResults(results):Unit);
    match suiteFailure(results){
      Some(message)=>Err(message)|
      None()=>Ok(())
    }
  }|
  [
  head,
  .tail
]=>{
    using process=§process.start(head.command){
      runStartedSuites(
        tail,
        [{
          command:head.command,
          label:head.label,
          process:process
        }]⧺started
      )
    }
  }
}

λrunStep(step:µStep)=>!CliIo Result[
  Unit,
  String
] match step{
  µParallel(suites)=>{
    l _=(§io.println(""):Unit);
    l _=(§io.println("==> parallel Sigil suites"):Unit);
    runParallelBatch(suites)
  }|
  µSerial(serial)=>runSerialStep(serial)
}

λrunSteps(all:[µStep])=>!CliIo Result[
  Unit,
  String
]
decreases #all
match all{
  []=>Ok(())|
  [
  step,
  .rest
]=>match runStep(step){
    Ok(_)=>runSteps(rest)|
    Err(message)=>Err(message)
  }
}

λsigilCommand(args:[String],root:String)=>§process.Command=§process.withCwd(
  §process.command([compilerBin(root)]⧺args),
  root
)

λsigilCommandIn(args:[String],cwd:String,root:String)=>§process.Command=§process.withCwd(
  §process.command([compilerBin(root)]⧺args),
  cwd
)

λssgSuite(root:String)=>µParallelSuite={
  command:sigilCommand(
    [
      "test",
      "projects/ssg/tests"
    ],
    root
  ),
  label:"ssg suite"
}

λstdlibSuite(root:String)=>µParallelSuite={
  command:sigilCommand(
    [
      "test",
      "language/stdlib-tests/tests"
    ],
    root
  ),
  label:"stdlib suite"
}

λsteps(root:String)=>[µStep]=[
  µSerial({
    commands:[cargo(
      [
        "test",
        "--manifest-path",
        "language/compiler/Cargo.toml",
        "--workspace",
        "--no-default-features"
      ],
      root
    )],
    label:"compiler tests"
  }),
  µSerial({
    commands:packageInstallCommands(root),
    label:"package installs"
  }),
  µSerial({
    commands:[
      sigilCommandIn(
        [
          "test",
          "tests"
        ],
        repoAuditRoot(root),
        root
      ),
      sigilCommandIn(
        [
          "run",
          "src/main.sigil"
        ],
        repoAuditRoot(root),
        root
      )
    ],
    label:"repo audit"
  }),
  µParallel(parallelSuites(root)),
  µSerial({
    commands:[pnpmCommand(
      ["sigil:build:website"],
      root
    )],
    label:"website build"
  }),
  µSerial({
    commands:[homebrewCommand(root)],
    label:"homebrew packaging"
  }),
  µSerial({
    commands:[httpTestCommand(root)],
    label:"http integration"
  }),
  µSerial({
    commands:[tcpTestCommand(root)],
    label:"tcp integration"
  })
]

λsuiteFailure(results:[µSuiteResult])=>Option[String]
decreases #results
match results{
  []=>None()|
  [
  head,
  .tail
]=>match head.result.code=0{
    true=>suiteFailure(tail)|
    false=>Some(failedSuiteMessage(head))
  }
}

λtcpTestCommand(root:String)=>§process.Command=sigilCommand(
  [
    "test",
    "language/integrationTests/tests/tcpClientServer.sigil"
  ],
  root
)

λtodoSuite(root:String)=>µParallelSuite={
  command:sigilCommand(
    [
      "test",
      "projects/todo-app/tests"
    ],
    root
  ),
  label:"todo app suite"
}

λwaitSuites(started:[µStartedSuite])=>!Process [µSuiteResult]
decreases #started
match started{
  []=>[]|
  [
  head,
  .tail
]=>{
    l result=(§process.wait(head.process):§process.ProcessResult);
    [{
      command:head.command,
      label:head.label,
      result:result
    }]⧺waitSuites(tail)
  }
}
