Î»articleNav(config:srcâ‹…types.SiteBuildConfig,nextCard:String,previousCard:String)â†’String match nextCard++previousCard{
  ""â†’""|
  cardsâ†’"<nav class=\"article-nav\">"++cards++"</nav>"
