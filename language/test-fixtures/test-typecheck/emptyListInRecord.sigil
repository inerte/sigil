⟦ Test: Empty lists in record literals should infer from record type ⟧

t State={
  items:[ℤ],
  names:[𝕊]
}

⟦ This should work - record type provides context for empty list fields ⟧
λemptyState()→State={
  items:[],
  names:[]
}

⟦ Non-empty fields should also work ⟧
λinitialState()→State={
  items:[1,2,3],
  names:["a","b"]
}

λmain()→𝕌=()

⟦ Mixed empty and non-empty ⟧
λpartialState()→State={
  items:[],
  names:["test"]
}
