λinstant(value:§json.JsonValue)=>Result[
  §time.Instant,
  §decode.DecodeError
] match §decode.string(value){
  Ok(text)=>match §time.parseIso(text){
    Ok(decoded)=>Ok(decoded)|
    Err(error)=>Err({
      message:error.message,
      path:[]
    })
  }|
  Err(error)=>Err(error)
}

λmain()=>Unit=()

λmessage(value:§json.JsonValue)=>Result[
  µMessage,
  §decode.DecodeError
] match §decode.field(
  instant,
  "createdAt"
)(value){
  Ok(createdAt)=>match §decode.field(
    todoId,
    "id"
  )(value){
    Ok(id)=>Ok({
      createdAt:createdAt,
      id:id
    })|
    Err(error)=>Err(error)
  }|
  Err(error)=>Err(error)
}

λtodoId(value:§json.JsonValue)=>Result[
  µTodoId,
  §decode.DecodeError
] match §decode.int(value){
  Ok(id)=>Ok(µTodoId(id))|
  Err(error)=>Err(error)
}

test "decode.dict decodes object values" {
  match §decode.run(
    §decode.dict(§decode.int),
    §json.JsonObject({
      "a"↦§json.JsonString("1"),
      "b"↦§json.JsonNumber(2.0)
    })
  ){
    Ok(values)=>¶map.size(values)=2
      and (match ¶map.get(
        "a",
        values
      ){
        Some(value)=>value=1|
        None()=>false
      })
      and (match ¶map.get(
        "b",
        values
      ){
        Some(value)=>value=2|
        None()=>false
      })|
    Err(_)=>false
  }
}

test "decode.field reports missing required field path" {
  match §decode.run(
    §decode.field(
      §decode.string,
      "name"
    ),
    §json.JsonObject((({↦}:{String↦§json.JsonValue}):{String↦§json.JsonValue}))
  ){
    Ok(_)=>false|
    Err(error)=>error={
      message:"missing required field",
      path:["name"]
    }
  }
}

test "decode.list prefixes failing index path" {
  match §decode.run(
    §decode.field(
      §decode.list(§decode.int),
      "ids"
    ),
    §json.JsonObject({"ids"↦§json.JsonArray([
      §json.JsonString("1"),
      §json.JsonBool(true)
    ])})
  ){
    Ok(_)=>false|
    Err(error)=>error={
      message:"expected int",
      path:[
        "ids",
        "1"
      ]
    }
  }
}

test "decode.optionalField returns None when key is absent" {
  match §decode.run(
    §decode.optionalField(
      §decode.string,
      "name"
    ),
    §json.JsonObject((({↦}:{String↦§json.JsonValue}):{String↦§json.JsonValue}))
  ){
    Ok(value)=>match value{
      None()=>true|
      Some(_)=>false
    }|
    Err(_)=>false
  }
}

test "decode.parse builds trusted wrapper-backed message" {
  match §decode.parse(
    message,
    "{\"createdAt\":\"2026-03-07T00:00:00.000Z\",\"id\":\"42\"}"
  ){
    Ok(decoded)=>match decoded.id{
      µTodoId(id)=>id=42 and decoded.createdAt.epochMillis>0
    }|
    Err(_)=>false
  }
}
