λbadDirectWrapperSource()=>String="λsum1(xs:[Int])=>Int=§list.sum(xs)
"

λbadMapWrapperSource()=>String="λproject[T,U](fn:λ(T)=>U,xs:[T])=>[U]=xs map fn
"

λbadMatchSource()=>String="λfib(n:Int)=>Int match n{0=>0|1=>1|value=>fib(value-1)+fib(value-2)}
λmain()=>Int=fib(5)
"

λbadSignatureSource()=>String="λfib(n:Int)=>Int
match n{0=>0}
λmain()=>Int=fib(5)
"

λcompile(file:String)=>!Process §process.ProcessResult=§process.run(•support.sigil([
  "compile",
  file
]))

λgoodFibSource()=>String="λfib(n:Int)=>Int
requires n≥0
=fibHelper(
  0,
  1,
  n
)

total λfibHelper(a:Int,b:Int,n:Int)=>Int
requires n≥0
decreases n
match n{
  0=>a|
  value=>fibHelper(
    b,
    a+b,
    value-1
  )
}

λmain()=>Int=fib(5)
"

λmain()=>Unit=()

λwrapperPlusLogicSource()=>String="λsumPlusOne(xs:[Int])=>Int=§list.sum(xs)+1
"

test "canonical rejects single-line multi-arm match" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalMatch"):String);
  l file=(§path.join(
    root,
    "badMatch.sigil"
  ):String);
  l _=(§file.writeText(
    badMatchSource(),
    file
  ):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  §string.contains(
    •support.combinedOutput(result),
    "SIGIL-CANON-SOURCE-FORM"
  )=true
}

test "canonical rejects split signature before match" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalSignature"):String);
  l file=(§path.join(
    root,
    "badSignature.sigil"
  ):String);
  l _=(§file.writeText(
    badSignatureSource(),
    file
  ):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  §string.contains(
    •support.combinedOutput(result),
    "SIGIL-CANON-SOURCE-FORM"
  )=true
}

test "canonical fib fixture compiles" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalGood"):String);
  l file=(§path.join(
    root,
    "goodFib.sigil"
  ):String);
  l _=(§file.writeText(
    goodFibSource(),
    file
  ):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  result.code=0
}

test "canonical rejects exact stdlib helper wrappers" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalDirectWrapper"):String);
  l file=(§path.join(
    root,
    "badWrapper.lib.sigil"
  ):String);
  l _=(§file.writeText(
    badDirectWrapperSource(),
    file
  ):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  result.code≠0 and §string.contains(
    •support.combinedOutput(result),
    "SIGIL-CANON-HELPER-DIRECT-WRAPPER"
  )
}

