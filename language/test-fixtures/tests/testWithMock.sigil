⟦ TEST: withMock parser/typechecker/codegen parity ⟧

e console

λfetchStatus()→!IO String="real"

λmain()→Unit=()

test "withMock body can compose booleans" →!IO {
  withMock(fetchStatus, λ()→!IO String="temporary") {
    fetchStatus()="temporary" and fetchStatus()≠"real"
  }
}

test "withMock can replace any function in tests" →!IO {
  withMock(fetchStatus, λ()→!IO String="mocked") {
    fetchStatus()="mocked"
  }
}
