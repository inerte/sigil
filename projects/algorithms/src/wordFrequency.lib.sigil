Î»frequency(lines:[String])=>{Stringâ†¦Int}=normalizedWords(lines) reduce increment from (Â¶map.empty():{Stringâ†¦Int})

Î»increment(histogram:{Stringâ†¦Int},word:String)=>{Stringâ†¦Int} match Â¶map.get(
  word,
  histogram
){
  Some(count)=>Â¶map.insert(
    word,
    histogram,
    count+1
  )|
  None()=>Â¶map.insert(
    word,
    histogram,
    1
  )
}

Î»nonEmpty(word:String)=>Bool=wordâ‰ ""

Î»normalizedWords(lines:[String])=>[String]=Â§list.flatMap(
  splitWords,
  lines
) filter nonEmpty

Î»splitWords(line:String)=>[String]=Â§string.split(
  " ",
  Â§string.toLower(line)
)

Î»summary(lines:[String])=>[ÂµWordBucket]=Â¶map.entries(frequency(lines)) map (Î»(entry:Â¶map.Entry[
  String,
  Int
])=>ÂµWordBucket={
  count:entry.value,
