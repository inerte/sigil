test "decode.dict decodes object values" {
  match stdlibâ‹…decode.run(
    stdlibâ‹…decode.dict(stdlibâ‹…decode.int),
    stdlibâ‹…json.JsonObject({
      "a"â†¦stdlibâ‹…json.JsonString("1"),
      "b"â†¦stdlibâ‹…json.JsonNumber(2.0)
    })
  ){
    Ok(values)â†’
      coreâ‹…map.size(values)=2 and match coreâ‹…map.get("a",values){
        Some(value)â†’value=1|
        None()â†’false
      } and match coreâ‹…map.get("b",values){
        Some(value)â†’value=2|
        None()â†’false
      }|
    Err(_)â†’false
  }
}

