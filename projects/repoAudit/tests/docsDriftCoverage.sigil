          "\"a\"",
          "",
          "\"b\""
        ],
        "λmain()=>Unit={",
        "}"
      ),
      "sample2"
    )
  ])
}

test "fence helpers parse valid and invalid forms" {
  l extracted=(•fences.extractSnippets(
    "docs/test.md",
    §string.unlines([
      "```sigil module src/sample.lib.sigil",
      "λsample()=>String=\"ok\"",
      "```"
    ])
  ):µExtractResult);
  allOk([
    match •fences.parseFenceInfo("sigil module src/sample.lib.sigil"){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="module" and (match parsed.context{
          Some(path)=>path="src/sample.lib.sigil"|
          None()=>false
        })
      }|
      Err(_)=>false
    },
    match •fences.parseFenceInfo("sigil unknown"){
      Ok(_)=>false|
      Err(message)=>§string.contains(
        message,
        "unknown Sigil fence kind"
      )
    },
    match •fences.parseFenceKind("module src/sample.lib.sigil"){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="module" and (match parsed.context{
          Some(path)=>path="src/sample.lib.sigil"|
          None()=>false
        })
      }|
      Err(_)=>false
    },
    match •fences.parseFenceKindWithContext(
      "module",
      "src/sample.lib.sigil"
    ){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="module" and (match parsed.context{
          Some(path)=>path="src/sample.lib.sigil"|
          None()=>false
        })
      }|
      Err(_)=>false
    },
    match •fences.parseFenceKindWithContext(
      "expr",
      "arg"
    ){
      Ok(_)=>false|
      Err(message)=>§string.contains(
        message,
        "does not accept an argument"
      )
    },
    match •fences.parseFenceKindWithoutContext("expr"){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="expr" and (match parsed.context{
          None()=>true|
          Some(_)=>false
        })
      }|
      Err(_)=>false
    },
    match •fences.parseFenceKindWithoutContext("mystery"){
      Ok(_)=>false|
      Err(message)=>§string.contains(
        message,
        "unknown Sigil fence kind"
      )
    },
    match •fences.parseModulePath(
      "module",
      "src/sample.lib.sigil"
    ){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="module" and (match parsed.context{
          Some(path)=>path="src/sample.lib.sigil"|
          None()=>false
        })
      }|
      Err(_)=>false
    },
    match •fences.parseModulePath(
      "module",
      "src/sample.sigil"
    ){
      Ok(_)=>false|
      Err(message)=>§string.contains(
        message,
        "must use a .lib.sigil virtual path"
      )
    },
    match •fences.parseProgramPath(
      "program",
      "src/sample.lib.sigil"
    ){
      Ok(_)=>false|
      Err(message)=>§string.contains(
        message,
        "must use a .sigil virtual path"
      )
    },
    match •fences.parseProgramPath(
      "program",
      "src/sample.sigil"
    ){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="program" and (match parsed.context{
          Some(path)=>path="src/sample.sigil"|
          None()=>false
        })
      }|
      Err(_)=>false
    },
    •fences.invalidFenceIssue(
      "docs/test.md",
      2,
      "boom"
    )={
      line:2,
      message:"boom",
      path:"docs/test.md"
    },
    •fences.isFence("```"),
    •fences.isSigilFence("```sigil expr"),
    •fences.nonEmpty("x"),
    extracted.issues=[],
    match extracted.results{
      [item]=>{
        l found=(item:µSnippet);
        found.info.kind="module" and found.line=1
      }|
      _=>false
    }
  ])
}

test "markdown coverage helpers read sandbox files" =>!Fs world {
  c fs=(†fs.sandbox(".local/repoAuditCoverage/markdownSandbox"):†fs.FsEntry)
} {
  l _=(§file.makeDirs("docs"):Unit);
  l _=(§file.makeDirs("tests"):Unit);
  l _=(§file.writeText(
    §string.unlines([
      "```sigil decl §string",
      "λtrim(s:String)=>String",
      "```",
      "",
      "```sigil expr",
      "§string.trim(\" hi \")",
      "```"
    ]),
    "docs/example.md"
  ):Unit);
  l _=(§file.writeText(
    "λmain()=>Unit={
  l sample=(§string.trim(\" hi \"):String);
  ()
}
",
    "tests/example.sigil"
  ):Unit);
  l audit=(•docsDrift.collectMarkdownAuditRefs(
    "docs/example.md",
    "."
  ):µMarkdownAudit);
  l coverageAudit=(•docsDrift.runMarkdownCoverageAudit(
    ["docs/example.md"],
    "."
  ):µMarkdownAudit);
  l refs=(•docsDrift.readCoverageRefs(
    ["tests/example.sigil"],
    "."
  ):[String]);
  allOk([
    audit.documentedRefs=["§string.trim"],
    audit.issues=[],
    audit.snippetRefs=["§string.trim"],
    coverageAudit.documentedRefs=["§string.trim"],
    coverageAudit.issues=[],
    coverageAudit.snippetRefs=["§string.trim"],
    refs=["§string.trim"]
  ])
}

test "path based helpers succeed on decl only markdown" =>!AuditIo {
  l root=(repoRoot():String);
  l path=(".local/repoAuditCoverage/declOnly.md":String);
  l tempDir=(§path.join(
    root,
    ".local/repoAuditCoverage/tmp-decl"
  ):String);
  l _=(§file.makeDirs(".local/repoAuditCoverage"):Unit);
  l _=(§file.removeTree(tempDir):Unit);
  l _=(§file.makeDirs(tempDir):Unit);
  l _=(§file.writeText(
    §string.unlines([
      "```sigil decl §string",
      "λtrim(s:String)=>String",
      "```"
    ]),
    path
  ):Unit);
  l markdownAudit=(•docsDrift.processMarkdownFile(
    false,
    path,
    root,
    tempDir
  ):µMarkdownAudit);
  l refsForFile=(•docsDrift.runRefsForFile(path):Result[
  µMarkdownAudit,
  String
]);
  l refsForPaths=(•docsDrift.runRefsForPaths([path]):Result[
  µMarkdownAudit,
  String
]);
  l runCheck=(•docsDrift.runCheckForPaths([path]):Result[
  [µIssue],
  String
]);
  allOk([
    markdownAudit.issues=[],
    match refsForFile{
      Ok(audit)=>{
        l found=(audit:µMarkdownAudit);
        found.documentedRefs=["§string.trim"] and found.issues=[]
      }|
      Err(_)=>false
    },
    match refsForPaths{
      Ok(audit)=>{
        l found=(audit:µMarkdownAudit);
        found.documentedRefs=["§string.trim"] and found.issues=[]
      }|
      Err(_)=>false
    },
    match runCheck{
      Ok(issues)=>issues=[]|
      Err(_)=>false
    }
  ])
}

