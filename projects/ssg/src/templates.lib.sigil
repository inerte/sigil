Î»breadcrumb(config:srcâ‹…types.SiteBuildConfig,page:srcâ‹…types.SitePage)â†’đť•Š=
  "<nav class=\"breadcrumb\"><a href=\""++site_url(config.base_path,"/")++"\">Home</a><span>/</span><a href=\""++section_url(config.base_path,page.section)++"\">"++srcâ‹…content.section_name(page.section)++"</a></nav>"

Î»detail_meta(page:srcâ‹…types.SitePage)â†’đť•Š=
  l author=(page.meta.author:đť•Š);
  l date=(page.meta.date:đť•Š);
  match (#author>0) or (#date>0){
    trueâ†’"<p class=\"page-meta\">"++detail_meta_value(author,date)++"</p>"|
    falseâ†’""
  }

Î»detail_meta_value(author:đť•Š,date:đť•Š)â†’đť•Š match (#author>0) and (#date>0){
  trueâ†’date++" Â· "++author|
  falseâ†’match #date>0{
    trueâ†’date|
    falseâ†’author
  }
}

Î»docs_index(config:srcâ‹…types.SiteBuildConfig,pages:[srcâ‹…types.SitePage])â†’đť•Š=
