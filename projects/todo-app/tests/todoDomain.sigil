t Todo={done:Bool,id:Int,text:String}

i src::todoDomain

i stdlib::numeric

λlenTodos(todos:[Todo])=>Int match todos{
  []=>0|
  [_,.rest]=>1+lenTodos(rest)
}

λmain()=>Unit=()

test "todo add prepends item" {
  match src::todoDomain.addTodo(1,"Task",[]){
    [todo]=>todo.id=1 and todo.text="Task" and todo.done=false|
    _=>false
  }
}

test "todo clearCompleted keeps active only" {
  match src::todoDomain.clearCompleted([{done:true,id:1,text:"A"},{done:false,id:2,text:"B"}]){
    [todo]=>todo.id=2 and todo.done=false|
    _=>false
  }
}

test "todo completedCount counts completed" {
  src::todoDomain.completedCount([{done:true,id:1,text:"A"},{done:false,id:2,text:"B"},{done:true,id:3,text:"C"}])=2
}

test "todo completedCount result can use numeric predicates" {
  l count=(src::todoDomain.completedCount([{done:true,id:1,text:"A"},{done:false,id:2,text:"B"},{done:true,id:3,text:"C"}]):Int);
  stdlib::numeric.isEven(count)=true and stdlib::numeric.inRange(3,0,count)=true
}

test "todo delete reduces length" {
  lenTodos(src::todoDomain.deleteTodo(1,[{done:false,id:1,text:"A"},{done:false,id:2,text:"B"}]))=1
}

test "todo delete removes target" {
  match src::todoDomain.deleteTodo(1,[{done:false,id:1,text:"A"},{done:false,id:2,text:"B"}]){
    [todo]=>todo.id=2 and todo.text="B"|
    _=>false
  }
}

test "todo edit updates text" {
  src::todoDomain.editTodo("New",1,[{done:false,id:1,text:"Old"}])[0].text="New"
}

test "todo toggle flips done flag" {
  src::todoDomain.toggleTodo(1,[{done:false,id:1,text:"Task"}])[0].done=true
}
