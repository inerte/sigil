test "numeric.abs returns magnitude" {
  stdlibâ‹…numeric.abs(-5)=5 and stdlibâ‹…numeric.abs(0)=0 and stdlibâ‹…numeric.abs(7)=7
}

test "numeric.divmod returns quotient and remainder" {
  stdlibâ‹…numeric.divmod(17,5)={quotient:3,remainder:2} and stdlibâ‹…numeric.divmod(-17,5)={quotient:-4,remainder:3}
