λmain()=>Unit=()

test "list.inBounds checks valid and invalid indexes" {
  §list.inBounds(
    0,
    [
      10,
      20,
      30
    ]
  )=true and §list.inBounds(
    3,
    [
      10,
      20,
      30
    ]
  )=false
}

test "list.sortedAsc accepts ascending list" {
  §list.sortedAsc([
    1,
    2,
    3,
    4
  ])=true
}

test "list.sortedDesc accepts descending list" {
  §list.sortedDesc([
    4,
    3,
    2,
    1
  ])=true
}
