Î»resolveRepoPath(sourcePath:String,targetPath:String)â†’String match stdlibâ‹…string.startsWith("/",targetPath){
  trueâ†’normalizeRepoPath(stdlibâ‹…string.substring(#targetPath,targetPath,1))|
  falseâ†’match stdlibâ‹…string.startsWith("../docs/",targetPath){
