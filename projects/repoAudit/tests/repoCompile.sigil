λallOk(results:[Bool])=>Bool=§list.all(
  λ(result:Bool)=>Bool=result,
  results
)

λmain()=>Unit=()

test "compiler command uses repo relative output paths" {
  l command=(•repoCompile.compilerCommand("/repo"):§process.Command);
  l installCommand=(•repoCompile.installDependenciesCommand(
    "projects/featureFlagStorefront",
    "/repo"
  ):§process.Command);
  l projectCommand=(•repoCompile.projectCompilerCommand(
    "projects/featureFlagStorefront",
    "/repo"
  ):§process.Command);
  allOk([
    command.argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "compile",
      ".",
      "--ignore",
      ".git",
      "--ignore-from",
      ".gitignore"
    ],
    •repoCompile.compilerCommandIgnoringProjects(
      ["projects/featureFlagStorefront"],
      "/repo"
    ).argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "compile",
      ".",
      "--ignore",
      ".git",
      "--ignore",
      "projects/featureFlagStorefront",
      "--ignore-from",
      ".gitignore"
    ],
    match command.cwd{
      Some(cwd)=>cwd="/repo"|
      None()=>false
    },
    installCommand.argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "package",
      "install"
    ],
    match installCommand.cwd{
      Some(cwd)=>cwd="/repo/projects/featureFlagStorefront"|
      None()=>false
    },
    projectCommand.argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "compile",
      "projects/featureFlagStorefront",
      "--env",
      "test"
    ],
    match projectCommand.cwd{
      Some(cwd)=>cwd="/repo"|
      None()=>false
    }
  ])
}

test "process output prefers stderr then stdout" {
  allOk([
    •repoCompile.isTestConfigPath("projects/featureFlagStorefront/config/test.lib.sigil"),
    ¬•repoCompile.isTestConfigPath("projects/featureFlagStorefront/config/prod.lib.sigil"),
    •repoCompile.scratchIgnoreDirs([
      "sigil-cli-package-a/file.txt",
      "sigil-cli-package-a/other.txt",
      "sigil-package-b/out.txt",
      "projects/demo/src/main.sigil"
    ])=[
      "sigil-cli-package-a",
      "sigil-package-b"
    ],
    •repoCompile.processOutput({
      code:1,
      stderr:" boom ",
      stdout:"ok"
    })="boom",
    •repoCompile.processOutput({
      code:1,
      stderr:"",
      stdout:" ok "
    })="ok"
  ])
}

test "parse compile issue decodes structured compiler failures" {
  •repoCompile.parseCompileIssue("{\"error\":{\"message\":\"boom\",\"details\":{\"file\":\"language/examples/demo.sigil\"}}}")=Some({
    message:"compile failed: boom",
    path:"language/examples/demo.sigil"
  })
}

test "parse compile issue falls back on invalid json" {
  match •repoCompile.parseCompileIssue("nope"){
    Some(_)=>false|
    None()=>true
  }
}

test "fallback and helper none paths stay stable" {
  l empty=(({↦}:{String↦§json.JsonValue}):{String↦§json.JsonValue});
  allOk([
    •repoCompile.fallbackCompileIssue({
      code:1,
      stderr:"",
      stdout:" bad "
    })={
      message:"compile failed: bad",
      path:"."
    },
    match •repoCompile.compileIssuePath(empty){
      Some(_)=>false|
      None()=>true
    },
    match •repoCompile.jsonObjectField(
      "details",
      empty
    ){
      Some(_)=>false|
      None()=>true
    },
    match •repoCompile.jsonStringField(
      "message",
      empty
    ){
      Some(_)=>false|
      None()=>true
    },
    •repoCompile.packageInstallIssue(
      "projects/featureFlagStorefront",
      {
        code:1,
        stderr:" boom ",
        stdout:""
      }
    )={
      message:"package install failed: boom",
      path:"projects/featureFlagStorefront"
    }
  ])
}

test "dependency project detection reads non-empty dependency maps" =>!Fs world {
  c fs=(†fs.sandbox(".local/repoCompile/dependencies"):†fs.FsEntry)
} {
  l _=(§file.makeDirs("projects/featureFlagStorefront"):Unit);
  l _=(§file.makeDirs("projects/demo"):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"featureFlagStorefront\",
  \"version\": \"2026-04-12T14-30-00Z\",
  \"dependencies\": {
    \"featureFlagStorefrontFlags\": \"2026-04-12T14-00-00Z\"
  }
}
",
    "projects/featureFlagStorefront/sigil.json"
  ):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"demoApp\",
  \"version\": \"2026-04-05T14-58-24Z\"
}
",
    "projects/demo/sigil.json"
  ):Unit);
  •repoCompile.dependencyProjectDirs(
    [
      "projects/featureFlagStorefront/sigil.json",
      "projects/demo/sigil.json"
    ],
    "."
  )=["projects/featureFlagStorefront"] and •repoCompile.configProjectDirs([
    "projects/featureFlagStorefront/config/test.lib.sigil",
    "projects/featureFlagStorefront/config/prod.lib.sigil",
    "projects/demo/config/test.lib.sigil"
  ])=[
    "projects/featureFlagStorefront",
    "projects/demo"
  ]
}

test "git top level surfaces process failure" =>!Process world {
  c process=(†process.fixture([†process.rule(
  [
    "git",
    "rev-parse",
    "--show-toplevel"
  ],
  None(),
  {
    code:1,
    stderr:"boom",
    stdout:""
  }
)]):†process.ProcessEntry)
} {
  match •repoCompile.gitTopLevel(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  }
}

