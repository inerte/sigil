test "list.count counts duplicates" {
  stdlibâ‹…list.count(3,[3,1,3,2,3])=3 and stdlibâ‹…list.count(9,[])=0 and stdlibâ‹…list.count(7,[1,2,3])=0
}

test "list.drop clamps naturally" {
  stdlibâ‹…list.drop(0,[1,2,3])=[1,2,3] and stdlibâ‹…list.drop(2,[1,2,3,4])=[3,4] and stdlibâ‹…list.drop(10,[1,2])=[] and stdlibâ‹…list.drop(-1,[1,2])=[1,2]
}

test "list.last returns option" {
  stdlibâ‹…list.last([])=stdlibâ‹…list.IntNone() and stdlibâ‹…list.last([9])=stdlibâ‹…list.IntSome(9) and stdlibâ‹…list.last([1,2,3])=stdlibâ‹…list.IntSome(3)
}

test "list.nth returns option" {
  stdlibâ‹…list.nth(0,[7,8])=stdlibâ‹…list.IntSome(7) and stdlibâ‹…list.nth(1,[7,8])=stdlibâ‹…list.IntSome(8) and stdlibâ‹…list.nth(2,[7,8])=stdlibâ‹…list.IntNone() and stdlibâ‹…list.nth(-1,[7,8])=stdlibâ‹…list.IntNone()
}

test "list.remove_first removes only first match" {
  stdlibâ‹…list.remove_first(2,[1,2,3,2])=[1,3,2] and stdlibâ‹…list.remove_first(9,[1,2,3])=[1,2,3] and stdlibâ‹…list.remove_first(9,[])=[]
}

test "list.reverse reverses list" {
  stdlibâ‹…list.reverse([])=[] and stdlibâ‹…list.reverse([1])=[1] and stdlibâ‹…list.reverse([1,2,3])=[3,2,1]
}

test "list.take clamps naturally" {
  stdlibâ‹…list.take(0,[1,2,3])=[] and stdlibâ‹…list.take(2,[1,2,3,4])=[1,2] and stdlibâ‹…list.take(10,[1,2])=[1,2] and stdlibâ‹…list.take(-1,[1,2])=[]
}
