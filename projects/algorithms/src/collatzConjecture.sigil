λcollatz(n:Int)=>[Int]=collatzR(
  n,
  1000000
)

total λcollatzR(n:Int,remaining:Int)=>[Int]
requires 0≤remaining
decreases remaining
match n{
  1=>[1]|
  value=>match remaining=0{
    true=>[value]|
    false=>[value]⧺collatzR(
      nextCollatz(value),
      remaining+-1
    )
  }
}

λmain()=>[Int]=collatz(13)

total λnextCollatz(n:Int)=>Int match n%2{
  0=>n/2|
  _=>3*n+1
}
