test "git discovery helpers return repo paths" =>!Process {
  l markdown=(•docsDrift.gitTrackedMarkdown():Result[
  [String],
  String
]);
  l selection=(•docsDrift.selectedMarkdownPaths():Result[
  µMarkdownSelection,
  String
]);
  l stdlibPaths=(•docsDrift.gitTrackedStdlib():Result[
  [String],
  String
]);
  l stdlibTests=(•docsDrift.gitTrackedStdlibTests():Result[
  [String],
  String
]);
  allOk([
    match markdown{
      Ok(paths)=>#paths>0|
      Err(_)=>false
    },
    match selection{
      Ok(found)=>{
        l selectedPaths=(found:µMarkdownSelection);
        ¬selectedPaths.failFast and #selectedPaths.paths>0
      }|
      Err(_)=>false
    },
    match stdlibPaths{
      Ok(paths)=>#paths>0|
      Err(_)=>false
    },
    match stdlibTests{
      Ok(paths)=>#paths>0|
      Err(_)=>false
    }
  ])
}

test "git rev parse failure propagates through wrappers" =>!AuditIo world {
  c process=(†process.fixture([†process.rule(
  [
    "git",
    "rev-parse",
    "--show-toplevel"
  ],
  None(),
  {
    code:1,
    stderr:"boom",
    stdout:""
  }
)]):†process.ProcessEntry)
} {
  allOk([
    match •docsDrift.gitTopLevel(){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runCheck(){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runCheckForPaths(["docs/test.md"]){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runCoverageOnly(){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runRefsForFile("docs/test.md"){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runRefsForPaths(["docs/test.md"]){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runRepoCheck(){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runStdlibExportsForFile("language/stdlib/string.lib.sigil"){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    },
    match •docsDrift.runStdlibExportsForPaths(["language/stdlib/string.lib.sigil"]){
      Ok(_)=>false|
      Err(message)=>message="git rev-parse failed: boom"
    }
  ])
}

