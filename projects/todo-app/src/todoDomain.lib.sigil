t Todo={done:Bool,id:Int,text:String}

Î»addTodo(id:Int,text:String,todos:[Todo])=>[Todo]=[{done:false,id:id,text:text}]â§ºtodos

Î»canAdd(text:String)=>Bool=textâ‰ ""

Î»clearCompleted(todos:[Todo])=>[Todo]=todosâŠ³(Î»(todo:Todo)=>Bool=Â¬todo.done)

Î»completedCount(todos:[Todo])=>Int=todosâŠ•(Î»(acc:Int,todo:Todo)=>Int match todo.done{
  true=>acc+1|
  false=>acc
})âŠ•0

Î»deleteTodo(targetId:Int,todos:[Todo])=>[Todo]=todosâŠ³(Î»(todo:Todo)=>Bool=todo.idâ‰ targetId)

Î»editTodo(newText:String,targetId:Int,todos:[Todo])=>[Todo]=todosâ†¦(Î»(todo:Todo)=>Todo match todo.id=targetId{
  true=>{done:todo.done,id:todo.id,text:newText}|
  false=>todo
})

Î»isVisible(done:Bool,filter:String)=>Bool match filter{
  "all"=>true|
  "active"=>Â¬done|
  "completed"=>done|
  _=>true
}

Î»remainingCount(completed:Int,total:Int)=>Int=total-completed

Î»toggleTodo(targetId:Int,todos:[Todo])=>[Todo]=todosâ†¦(Î»(todo:Todo)=>Todo match todo.id=targetId{
  true=>{done:Â¬todo.done,id:todo.id,text:todo.text}|
