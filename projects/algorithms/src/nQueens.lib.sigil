Î»nQueens(size:Int)=>[[Int]] match sizeâ‰¤0{
  true=>[]|
  false=>nQueensSearch(
    0,
    [],
    0,
    size
  )
}

Î»nQueensAppend(prefix:[[Int]],suffix:[[Int]])=>[[Int]]=prefixâ§ºsuffix

Î»nQueensSearch(col:Int,placedRev:[Int],row:Int,size:Int)=>[[Int]]
requires 0â‰¤size+-row and 0â‰¤size+-col
decreases (size+-row, size+-col)
match row=size{
  true=>wrapSolution(Â§list.reverse(placedRev))|
  false=>match colâ‰¥size{
    true=>[]|
    false=>match safeAgainst(
      col,
      1,
      placedRev
    ){
      true=>nQueensAppend(
        nQueensSearch(
          0,
          [col]â§ºplacedRev,
          row+1,
          size
        ),
        nQueensSearch(
          col+1,
          placedRev,
          row,
          size
        )
      )|
      false=>nQueensSearch(
        col+1,
        placedRev,
        row,
        size
      )
    }
  }
}

Î»safeAgainst(col:Int,distance:Int,placedRev:[Int])=>Bool
requires 0â‰¤#placedRev
decreases #placedRev
match placedRev{
  []=>true|
  [
  placedCol,
  .tail
]=>match placedCol=col
    or placedCol+distance=col
    or placedCol-distance=col{
    true=>false|
    false=>safeAgainst(
      col,
      distance+1,
      tail
    )
  }
}

Î»wrapAll(cols:[Int],partials:[[Int]])=>[[Int]]
requires #colsâ‰¥0
decreases #cols
match cols{
  []=>partials|
  [
  head,
  .tail
]=>wrapAll(
    tail,
    wrapHead(
      head,
      partials
    )
  )
}

Î»wrapHead(head:Int,partials:[[Int]])=>[[Int]]
requires #partialsâ‰¥0
decreases #partials
match partials{
  []=>[]|
  [
  partial,
  .tail
]=>[[head]â§ºpartial]â§ºwrapHead(
    head,
    tail
  )
}

Î»wrapSolution(cols:[Int])=>[[Int]]=wrapAll(
  cols,
  [[]]
)
