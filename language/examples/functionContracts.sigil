t BirthYear=Int where value>1800

Î»main()=>Int=positiveGap(
  1800,
  normalizeYear(1700)
)

Î»normalizeYear(raw:Int)=>Int
requires rawâ‰¥0
ensures result>1800
match raw>1800{
  true=>raw|
  false=>1900
}

Î»positiveGap(baseline:Int,current:BirthYear)=>Int
requires currentâ‰¥baseline
ensures resultâ‰¥0
=current-baseline
