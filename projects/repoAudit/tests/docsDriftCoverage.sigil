    )=".",
    •docsDrift.relativeToRootPath(
      "/repo",
      §path.join(
        "/repo",
        "tmp/file.sigil"
      )
    )="tmp/file.sigil",
    •docsDrift.repoTempDir("/repo")=§path.join(
      "/repo",
      ".local/repoAuditTmp"
    ),
    •docsDrift.runCoverageChecks(
      ["§string.trim"],
      ["§string.trim"],
      [],
      ["§string.trim"],
      []
    )=[],
    •docsDrift.runCoverageChecksInner(
      ["§string.trim"],
      ["§string.trim"],
      ["§string.trim"],
      []
