        35,
        12
      ),
      [•roguelike.treasurePickup(•roguelike.point(
        5,
        4
      ))],
      0
    )
  ):µGameState);
  (potionState.loadout.potions:Int)=1
    and (treasureState.collectedTreasure:Int)=1
    and #potionState.pickups=0
    and #treasureState.pickups=0
}

