i stdlib::file

i stdlib::path

i stdlib::process

i stdlib::string

i src::support

λmain()=>Unit=()

λprojectConfig()=>String="{\"layout\":{\"src\":\"src\",\"tests\":\"tests\",\"out\":\".local\"}}"

λrunProject(root:String,target:String)=>!IO String={
  l result=(stdlib::process.run(src::support.sigilIn(["run",target],root)):stdlib::process.ProcessResult);
  src::support.combinedOutput(result)
}

λwriteProjectFile(content:String,path:String,root:String)=>!IO Unit=stdlib::file.writeText(content,stdlib::path.join(root,path))

test "multimodule simple import runs" =>!IO  {
  l root=(src::support.uniqueRepoTempDir("multimodule"):String);
  l _=(stdlib::file.makeDirs(stdlib::path.join(root,"src")):Unit);
  l _=(writeProjectFile(projectConfig(),"sigil.json",root):Unit);
  l _=(writeProjectFile("λdouble(x:Int)=>Int=x*2\n\nλtriple(x:Int)=>Int=x*3\n","src/utils.lib.sigil",root):Unit);
  l _=(writeProjectFile("i src::utils\n\nλmain()=>Int=src::utils.double(21)\n","src/main.sigil",root):Unit);
  l output=(runProject(root,"src/main.sigil"):String);
  l _=(stdlib::file.removeTree(root):Unit);
  stdlib::string.indexOf(output,"42")≥0=true
}

test "multimodule multiple imports run" =>!IO  {
  l root=(src::support.uniqueRepoTempDir("multimodule"):String);
  l _=(stdlib::file.makeDirs(stdlib::path.join(root,"src")):Unit);
  l _=(writeProjectFile(projectConfig(),"sigil.json",root):Unit);
  l _=(writeProjectFile("λdouble(x:Int)=>Int=x*2\n\nλtriple(x:Int)=>Int=x*3\n","src/utils.lib.sigil",root):Unit);
  l _=(writeProjectFile("λadd(x:Int,y:Int)=>Int=x+y\n\nλsubtract(x:Int,y:Int)=>Int=x-y\n","src/math.lib.sigil",root):Unit);
  l _=(writeProjectFile("i src::math\n\ni src::utils\n\nλmain()=>Int=src::math.add(src::utils.double(10),src::utils.triple(5))\n","src/calc.sigil",root):Unit);
  l output=(runProject(root,"src/calc.sigil"):String);
  l _=(stdlib::file.removeTree(root):Unit);
  stdlib::string.indexOf(output,"35")≥0=true
}

test "multimodule transitive dependency runs" =>!IO  {
  l root=(src::support.uniqueRepoTempDir("multimodule"):String);
  l _=(stdlib::file.makeDirs(stdlib::path.join(root,"src")):Unit);
  l _=(writeProjectFile(projectConfig(),"sigil.json",root):Unit);
  l _=(writeProjectFile("λincrement(x:Int)=>Int=x+1\n","src/base.lib.sigil",root):Unit);
  l _=(writeProjectFile("i src::base\n\nλaddTwo(x:Int)=>Int=src::base.increment(src::base.increment(x))\n","src/derived.lib.sigil",root):Unit);
  l _=(writeProjectFile("i src::derived\n\nλmain()=>Int=src::derived.addTwo(5)\n","src/app.sigil",root):Unit);
  l output=(runProject(root,"src/app.sigil"):String);
  l _=(stdlib::file.removeTree(root):Unit);
  stdlib::string.indexOf(output,"7")≥0=true
}
