λallOk(results:[Bool])=>Bool=§list.all(
  λ(result:Bool)=>Bool=result,
  results
)

λmain()=>Unit=()

test "all check ids stay canonical" {
  •repoAudit.allCheckIds()=[
    "docs-drift",
    "canonical-stdlib",
    "repo-compile",
    "package-publishability"
  ]
}

test "build check result counts issues" {
  •repoAudit.buildCheckResult(
    "docs-drift",
    {
      issues:[{
        check:"docs-drift",
        code:"docs-drift/issue",
        line:1,
        message:"bad",
        path:"docs/test.md",
        severity:"error"
      }],
      repoCompileStats:(None():Option[µRepoCompileStats])
    }
  )={
    check:"docs-drift",
    issueCount:1,
    ok:false,
    repoCompileStats:(None():Option[µRepoCompileStats])
  }
}

test "audit and mapping helpers keep stable shapes" {
  l canonicalIssue=({
    line:7,
    name:"sum",
    path:"projects/demo.sigil",
    replacement:"§list.sum"
  }:µCanonicalIssue);
  l docsIssue=({
    line:3,
    message:"compiler check failed: boom",
    path:"docs/test.md"
  }:µIssue);
  l repoCompileIssue=({
    message:"compile failed: boom",
    path:"projects/demo/src/main.sigil"
  }:µRepoCompileIssue);
  l packageIssue=({
    message:"package validate failed: boom",
    path:"projects/router"
  }:µPackagePublishabilityIssue);
  allOk([
    •repoAudit.auditIssue(
      "docs-drift",
      "docs-drift/issue",
      3,
      "bad",
      "docs/test.md"
    )={
      check:"docs-drift",
      code:"docs-drift/issue",
      line:3,
      message:"bad",
      path:"docs/test.md",
      severity:"error"
    },
    (•repoAudit.encodeAuditIssue({
      check:"docs-drift",
      code:"docs-drift/snippet-check",
      line:3,
      message:"compiler check failed: boom",
      path:"docs/test.md",
      severity:"error"
    }):§json.JsonValue)=§json.JsonObject({
      "check"↦§json.JsonString("docs-drift"),
      "code"↦§json.JsonString("docs-drift/snippet-check"),
      "line"↦§json.JsonNumber(3.0),
      "message"↦§json.JsonString("compiler check failed: boom"),
      "path"↦§json.JsonString("docs/test.md"),
      "severity"↦§json.JsonString("error")
    }),
    (•repoAudit.encodeAuditCheckResult({
      check:"repo-compile",
      issueCount:0,
      ok:true,
      repoCompileStats:Some({
        cacheHits:1,
        cacheMisses:0,
        compiled:0,
        considered:1,
        durationMs:9
      })
    }):§json.JsonValue)=§json.JsonObject({
      "check"↦§json.JsonString("repo-compile"),
      "issueCount"↦§json.JsonNumber(0.0),
      "ok"↦§json.JsonBool(true),
      "repoCompileStats"↦§json.JsonObject({
        "cacheHits"↦§json.JsonNumber(1.0),
        "cacheMisses"↦§json.JsonNumber(0.0),
        "compiled"↦§json.JsonNumber(0.0),
        "considered"↦§json.JsonNumber(1.0),
        "durationMs"↦§json.JsonNumber(9.0)
      })
    }),
    •repoAudit.mapCanonicalIssue(canonicalIssue)={
      check:"canonical-stdlib",
      code:"canonical-stdlib/local-wrapper",
      line:7,
      message:"projects/demo.sigil:7: local 'sum' duplicates canonical helper '§list.sum'; use the qualified stdlib path instead.",
      path:"projects/demo.sigil",
      severity:"error"
    },
    •repoAudit.mapCanonicalIssues([canonicalIssue])=[{
      check:"canonical-stdlib",
      code:"canonical-stdlib/local-wrapper",
      line:7,
      message:"projects/demo.sigil:7: local 'sum' duplicates canonical helper '§list.sum'; use the qualified stdlib path instead.",
      path:"projects/demo.sigil",
      severity:"error"
    }],
    •repoAudit.mapDocsDriftIssue(docsIssue)={
      check:"docs-drift",
      code:"docs-drift/snippet-check",
      line:3,
      message:"compiler check failed: boom",
      path:"docs/test.md",
      severity:"error"
    },
    •repoAudit.mapDocsDriftIssues([docsIssue])=[{
      check:"docs-drift",
      code:"docs-drift/snippet-check",
      line:3,
      message:"compiler check failed: boom",
      path:"docs/test.md",
      severity:"error"
    }],
    •repoAudit.mapRepoCompileIssue(repoCompileIssue)={
      check:"repo-compile",
      code:"repo-compile/compile-failed",
      line:1,
      message:"compile failed: boom",
      path:"projects/demo/src/main.sigil",
      severity:"error"
    },
    •repoAudit.mapRepoCompileIssues([repoCompileIssue])=[{
      check:"repo-compile",
      code:"repo-compile/compile-failed",
      line:1,
      message:"compile failed: boom",
      path:"projects/demo/src/main.sigil",
      severity:"error"
    }],
    •repoAudit.mapPackagePublishabilityIssue(packageIssue)={
      check:"package-publishability",
      code:"package-publishability/validate-failed",
      line:1,
      message:"package validate failed: boom",
      path:"projects/router",
      severity:"error"
    },
    •repoAudit.mapPackagePublishabilityIssues([packageIssue])=[{
      check:"package-publishability",
      code:"package-publishability/validate-failed",
      line:1,
      message:"package validate failed: boom",
      path:"projects/router",
      severity:"error"
    }]
  ])
}

test "audit program and insert unique helpers execute" {
  l program=(•repoAudit.auditProgram():§cli.Program[µAuditInvocation]);
  allOk([
    program=program,
    •repoAudit.insertUnique(
      "docs-drift",
      ["repo-compile"]
    )=[
      "repo-compile",
      "docs-drift"
    ],
    •repoAudit.insertUnique(
      "docs-drift",
      [
        "docs-drift",
        "repo-compile"
      ]
    )=[
      "docs-drift",
      "repo-compile"
    ]
  ])
}

test "docs drift messages map to stable codes" {
  allOk([
    •repoAudit.mapDocsDriftIssueCode("compiler check failed: boom")="docs-drift/snippet-check",
    •repoAudit.mapDocsDriftIssueCode("documented stdlib function lacks checked example or stdlib test coverage: §string.trim")="docs-drift/missing-coverage",
    •repoAudit.mapDocsDriftIssueCode("reference to missing stdlib symbol '§string.trim'")="docs-drift/missing-stdlib-ref",
    •repoAudit.mapDocsDriftIssueCode("sigil decl snippets require a stdlib module context")="docs-drift/invalid-fence",
    •repoAudit.mapDocsDriftIssueCode("misc")="docs-drift/issue"
  ])
}

test "selection defaults to all checks" {
  match •repoAudit.selectionFromRequestedChecks([]){
    Ok(selection)=>selection.checks=[
      "docs-drift",
      "canonical-stdlib",
      "repo-compile",
      "package-publishability"
    ]|
    Err(_)=>false
  }
}

test "selection dedupes and preserves canonical order" {
  match •repoAudit.selectionFromRequestedChecks([
    "repo-compile",
    "docs-drift",
    "repo-compile"
  ]){
    Ok(selection)=>selection.checks=[
      "docs-drift",
      "repo-compile"
    ]|
    Err(_)=>false
  }
}

test "selection supports package publishability checks" {
  match •repoAudit.selectionFromRequestedChecks([
    "package-publishability",
    "docs-drift"
  ]){
    Ok(selection)=>selection.checks=[
      "docs-drift",
      "package-publishability"
    ]|
    Err(_)=>false
  }
}

test "validate requested checks rejects unknown ids" {
  match •repoAudit.validateRequestedChecks([
    "docs-drift",
    "mystery-check"
  ]){
    Ok(_)=>false|
    Err(message)=>message="unknown check 'mystery-check'"
  }
}

test "run check rejects unknown ids" =>!AuditIo {
  match •repoAudit.runCheck("mystery-check"){
    Ok(_)=>false|
    Err(message)=>message="unknown check 'mystery-check'"
  }
}

test "runner surfaces invocation and selection errors" =>!AuditIo {
  allOk([
    match •repoAudit.runInvocation({requestedChecks:["mystery-check"]}){
      Ok(_)=>false|
      Err(message)=>message="unknown check 'mystery-check'"
    },
    match •repoAudit.runSelection({checks:["mystery-check"]}){
      Ok(_)=>false|
      Err(message)=>message="mystery-check: unknown check 'mystery-check'"
    },
    match •repoAudit.runSelectionInner(
      [],
      ["mystery-check"],
      [],
      ["mystery-check"]
    ){
      Ok(_)=>false|
      Err(message)=>message="mystery-check: unknown check 'mystery-check'"
    }
  ])
}

test "runner executes filtered checks under a controlled world" =>!AuditIo world {
  c fs=(†fs.sandbox(".local/repoAudit/controlled-world"):†fs.FsEntry)
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    (•repoCompile.compileTargetCommand({
      env:None(),
      path:"language",
      root:"."
    }).argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:"language/examples/addsNumbers.sigil
projects/router/sigil.json
"
    }
  ),
  †process.rule(
    (•repoCompile.compilerBinaryHashCommand(".").argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:"compiler-hash
"
    }
  ),
  †process.rule(
    (•packagePublishability.packageValidateCommand(
      "projects/router",
      "."
    ).argv:[String]),
    Some("projects/router"),
    {
      code:0,
      stderr:"",
      stdout:"{\"ok\":true}"
    }
  )
]):†process.ProcessEntry)
} {
  l _=(§file.removeTree(".sigil"):Unit);
  l _=(§file.removeTree("projects"):Unit);
  l _=(§file.makeDirs("projects/router"):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"router\",
  \"version\": \"2026-04-05T14-58-24Z\",
  \"publish\": {}
}
",
    "projects/router/sigil.json"
  ):Unit);
  allOk([
    match •repoAudit.runCheck("repo-compile"){
      Ok(outcome)=>outcome.issues=[] and (match outcome.repoCompileStats{
        Some(stats)=>stats.cacheHits=0
          and stats.cacheMisses=1
          and stats.compiled=1
          and stats.considered=1
          and stats.durationMs≥0|
        None()=>false
      })|
      Err(_)=>false
    },
    match •repoAudit.runCheck("package-publishability"){
      Ok(outcome)=>outcome.issues=[] and outcome.repoCompileStats=(None():Option[µRepoCompileStats])|
      Err(_)=>false
    },
    match •repoAudit.runInvocation({requestedChecks:["repo-compile"]}){
      Ok(data)=>data.summary.checks=1
        and data.summary.issueCount=0
        and data.summary.selectedChecks=["repo-compile"]
        and #data.checks=1
        and data.checks[0].check="repo-compile"
        and data.checks[0].issueCount=0
        and data.checks[0].ok
        and (match data.checks[0].repoCompileStats{
          Some(stats)=>stats.cacheHits=1
            and stats.cacheMisses=0
            and stats.compiled=0
            and stats.considered=1
            and stats.durationMs≥0|
          None()=>false
        })|
      Err(_)=>false
    },
    match •repoAudit.runSelection({checks:["repo-compile"]}){
      Ok(data)=>data.summary.checks=1
        and data.summary.issueCount=0
        and data.summary.selectedChecks=["repo-compile"]
        and #data.checks=1
        and data.checks[0].check="repo-compile"
        and data.checks[0].issueCount=0
        and data.checks[0].ok
        and (match data.checks[0].repoCompileStats{
          Some(stats)=>stats.cacheHits=1
            and stats.cacheMisses=0
            and stats.compiled=0
            and stats.considered=1
            and stats.durationMs≥0|
          None()=>false
        })|
      Err(_)=>false
    },
    match •repoAudit.runSelectionInner(
      [],
      ["repo-compile"],
      [],
      ["repo-compile"]
    ){
      Ok(data)=>data.summary.checks=1
        and data.summary.issueCount=0
        and data.summary.selectedChecks=["repo-compile"]
        and #data.checks=1
        and data.checks[0].check="repo-compile"
        and data.checks[0].issueCount=0
        and data.checks[0].ok
        and (match data.checks[0].repoCompileStats{
          Some(stats)=>stats.cacheHits=1
            and stats.cacheMisses=0
            and stats.compiled=0
            and stats.considered=1
            and stats.durationMs≥0|
          None()=>false
        })|
      Err(_)=>false
    },
    match •repoAudit.runInvocation({requestedChecks:["package-publishability"]}){
      Ok(data)=>data.summary.checks=1
        and data.summary.issueCount=0
        and data.summary.selectedChecks=["package-publishability"]|
      Err(_)=>false
    },
    match •repoAudit.runSelection({checks:["package-publishability"]}){
      Ok(data)=>data.summary.checks=1
        and data.summary.issueCount=0
        and data.summary.selectedChecks=["package-publishability"]|
      Err(_)=>false
    }
  ])
}

test "render helpers emit the canonical envelope" {
  l error=(•repoAudit.renderError("boom"):String);
  l success=(•repoAudit.renderSuccess({
    checks:[{
      check:"repo-compile",
      issueCount:0,
      ok:true,
      repoCompileStats:Some({
        cacheHits:1,
        cacheMisses:0,
        compiled:0,
        considered:1,
        durationMs:7
      })
    }],
    issues:[],
    summary:{
      checks:1,
      issueCount:0,
      selectedChecks:["repo-compile"]
    }
  }):String);
  allOk([
    §string.contains(
      error,
      "\"command\":\"repoAudit\""
    ),
    §string.contains(
      error,
      "\"message\":\"boom\""
    ),
    §string.contains(
      error,
      "\"ok\":false"
    ),
    §string.contains(
      success,
      "\"command\":\"repoAudit\""
    ),
    §string.contains(
      success,
      "\"check\":\"repo-compile\""
    ),
    §string.contains(
      success,
      "\"selectedChecks\":[\"repo-compile\"]"
    ),
    §string.contains(
      success,
      "\"repoCompileStats\":{\"cacheHits\":1"
    ),
    §string.contains(
      success,
      "\"ok\":true"
    )
  ])
}
