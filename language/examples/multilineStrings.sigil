λmain()=>!Log Unit={
  l _=(§io.println("# Heading

- one
- two
"):Unit);
  §io.println("Roses are red
  violets stay indented
Sigil keeps the spaces
")
}

test "multiline
test description works" {
  §string.lines("alpha
beta")=[
    "alpha",
    "beta"
  ]
}

