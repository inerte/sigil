t ParallelSuite={
  command:§process.Command,
  label:String
}

t ParallelStep={
  label:String,
  suites:[ParallelSuite]
}

t SerialStep={
  commands:[§process.Command],
  label:String
}

t StartedSuite={
  command:§process.Command,
  label:String,
  process:§process.RunningProcess
}

t Step=Parallel(ParallelStep)|Serial(SerialStep)

t SuiteResult={
  command:§process.Command,
  label:String,
  result:§process.ProcessResult
}
