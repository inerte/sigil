test "run check succeeds under a controlled world" =>!AuditIo world {
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  ),
  †process.rule(
    (•repoCompile.compilerCommand(".").argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  )
]):†process.ProcessEntry)
} {
  match •repoCompile.runCheck(){
    Ok(issues)=>issues=[]|
    Err(_)=>false
  }
}

test "run check reports compile failures from compiler json" =>!AuditIo world {
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  ),
  †process.rule(
    (•repoCompile.compilerCommand(".").argv:[String]),
    Some("."),
    {
      code:1,
      stderr:"",
      stdout:"{\"error\":{\"message\":\"bad compile\",\"details\":{\"file\":\"projects/demo/src/main.sigil\"}}}"
    }
  )
]):†process.ProcessEntry)
} {
  match •repoCompile.runCheck(){
    Ok(issues)=>issues=[{
      message:"compile failed: bad compile",
      path:"projects/demo/src/main.sigil"
    }]|
    Err(_)=>false
  }
}

test "run check installs package dependencies before compiling" =>!AuditIo world {
  c fs=(†fs.sandbox(".local/repoCompile/package-install"):†fs.FsEntry)
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:"projects/featureFlagStorefront/sigil.json
projects/featureFlagStorefrontFlags/sigil.json
"
    }
  ),
  †process.rule(
    (•repoCompile.installDependenciesCommand(
      "projects/featureFlagStorefront",
      "."
    ).argv:[String]),
    Some("projects/featureFlagStorefront"),
    {
      code:0,
      stderr:"",
      stdout:"{\"ok\":true}"
    }
  ),
  †process.rule(
    (•repoCompile.compilerCommand(".").argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  )
]):†process.ProcessEntry)
} {
  l _=(§file.makeDirs("projects/featureFlagStorefront"):Unit);
  l _=(§file.makeDirs("projects/featureFlagStorefrontFlags"):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"featureFlagStorefront\",
  \"version\": \"2026-04-12T14-30-00Z\",
  \"dependencies\": {
    \"featureFlagStorefrontFlags\": \"2026-04-12T14-00-00Z\"
  }
}
",
    "projects/featureFlagStorefront/sigil.json"
  ):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"featureFlagStorefrontFlags\",
  \"version\": \"2026-04-12T14-00-00Z\",
  \"publish\": {}
}
",
    "projects/featureFlagStorefrontFlags/sigil.json"
  ):Unit);
  match •repoCompile.runCheck(){
    Ok(issues)=>issues=[]|
    Err(_)=>false
  }
}

