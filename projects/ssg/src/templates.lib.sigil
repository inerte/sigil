Î»page_card(config:srcâ‹…types.SiteBuildConfig,page:srcâ‹…types.SitePage)â†’đť•Š=
  "<li class=\"page-card\" data-section=\""++srcâ‹…content.section_name_lowercase(page.section)++"\"><a class=\"page-link\" href=\""++site_url(config.base_path,srcâ‹…content.canonical_route(page))++"\">"++page.meta.title++"</a>"++page_card_meta(page)++page_card_description(page)++"</li>"

Î»page_card_description(page:srcâ‹…types.SitePage)â†’đť•Š match #page.meta.description>0{
