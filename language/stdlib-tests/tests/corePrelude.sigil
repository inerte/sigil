λmain()=>Unit=()

test "core prelude exposes option constructors without import" {
  match Some(42){
    Some(value)=>value=42|
    None()=>false
  }
}

test "core prelude exposes result constructors without import" {
  match Ok("done"){
    Ok(value)=>value="done"|
    Err(error)=>false
  }
}

test "core option helpers stay namespaced" {
  ¶option.isSome(Some(1))
    and ¶option.isNone(None())
    and ¶option.unwrapOr(
      7,
      None()
    )=7
}

test "core result helpers stay namespaced" {
  ¶result.isOk(Ok(1))
    and ¶result.isErr(Err("bad"))
    and ¶result.unwrapOrResult(
      9,
      Err("bad")
    )=9
}
