О»main()в†’рќ•Њ=()

test "todo add prepends item" {
  в‰Ўsrcв‹…todo-domain.addTodo(1,"Task",[]){
    [todo]в†’todo.id=1в€§todo.text="Task"в€§todo.done=false|
    _в†’false
  }
}

test "todo clearCompleted keeps active only" {
  в‰Ўsrcв‹…todo-domain.clearCompleted([Todo{id:1,text:"A",done:true},Todo{id:2,text:"B",done:false}]){
    [todo]в†’todo.id=2в€§todo.done=false|
    _в†’false
  }
}

test "todo completedCount counts completed" {
  srcв‹…todo-domain.completedCount([Todo{id:1,text:"A",done:true},Todo{id:2,text:"B",done:false},Todo{id:3,text:"C",done:true}])=2
}

test "todo completedCount result can use numeric predicates" {
  l count=(srcв‹…todo-domain.completedCount([Todo{id:1,text:"A",done:true},Todo{id:2,text:"B",done:false},Todo{id:3,text:"C",done:true}]):в„¤);
  stdlibв‹…numeric.is_even(count)=trueв€§stdlibв‹…numeric.in_range(3,0,count)=true
}

test "todo delete reduces length" {
  lenTodos(srcв‹…todo-domain.deleteTodo(1,[Todo{id:1,text:"A",done:false},Todo{id:2,text:"B",done:false}]))=1
}

test "todo delete removes target" {
  в‰Ўsrcв‹…todo-domain.deleteTodo(1,[Todo{id:1,text:"A",done:false},Todo{id:2,text:"B",done:false}]){
    [todo]в†’todo.id=2в€§todo.text="B"|
    _в†’false
