test "run check succeeds under a controlled world" =>!AuditIo world {
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:"language/examples/addsNumbers.sigil
"
    }
  ),
  †process.rule(
    (•repoCompile.compileTargetCommand({
      env:None(),
      path:"language",
      root:"."
    }).argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  )
]):†process.ProcessEntry)
} {
  match •repoCompile.runCheck(){
    Ok(issues)=>issues=[]|
    Err(_)=>false
  }
}

test "run check reports compile failures from compiler json" =>!AuditIo world {
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:"projects/demo/src/main.sigil
"
    }
  ),
  †process.rule(
    (•repoCompile.compileTargetCommand({
      env:None(),
      path:"projects/demo",
      root:"."
    }).argv:[String]),
    Some("."),
    {
      code:1,
      stderr:"",
      stdout:"{\"error\":{\"message\":\"bad compile\",\"details\":{\"file\":\"projects/demo/src/main.sigil\"}}}"
    }
  )
]):†process.ProcessEntry)
} {
  match •repoCompile.runCheck(){
    Ok(issues)=>issues=[{
      message:"compile failed: bad compile",
      path:"projects/demo/src/main.sigil"
    }]|
    Err(_)=>false
  }
}

