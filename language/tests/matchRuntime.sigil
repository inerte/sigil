λlistLabel(xs:[Int])=>String match xs{
  []=>"empty"|
  [1]=>"one"|
  [_]=>"single"|
  [
  1,
  .rest
]=>"one-prefix"|
  [
  _,
  _
]=>"two"|
  [
  _,
  _,
  .rest
]=>"many"
}

λmain()=>Unit=()

λnestedLabel(value:Option[Result[
  Int,
  String
]])=>String match value{
  Some(Ok(1))=>"one"|
  Some(Ok(_))=>"ok"|
  Some(Err(message))=>"err:"++message|
  None()=>"none"
}

λtupleLabel(left:Bool,right:Bool)=>String match (
  left,
  right
){
  (
  true,
  false
)=>"true-false"|
  (
  false,
  true
)=>"false-true"|
  (
  false,
  false
)=>"false-false"|
  (
  true,
  true
)=>"true-true"
}

test "tuple patterns check tuple items" {
  tupleLabel(
    false,
    false
  )="false-false"
    and tupleLabel(
      true,
      true
    )="true-true"
    and tupleLabel(
      true,
      false
    )="true-false"
}

test "list patterns check element shapes and values" {
  listLabel([])="empty"
    and listLabel([1])="one"
    and listLabel([
      1,
      2,
      3
    ])="one-prefix"
    and listLabel([
      4,
      5
    ])="two"
    and listLabel([
      4,
      5,
      6
    ])="many"
}

test "nested constructor patterns check inner payloads" {
  nestedLabel(Some(Ok(1)))="one"
    and nestedLabel(Some(Ok(2)))="ok"
    and nestedLabel(Some(Err("bad")))="err:bad"
    and nestedLabel(None())="none"
}
