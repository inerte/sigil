i stdlib::url

λmain()=>Unit match stdlib::url.parse("https://sigil.dev/docs?lang=sigil#intro"){
  Ok(parsed)=>console.log(("protocol="++parsed.protocol++", host="++parsed.host++", path="++parsed.path++", suffix="++stdlib::url.suffix(parsed):String))()|
  Err(err)=>console.log("url parse error: "++err.message)()
}
