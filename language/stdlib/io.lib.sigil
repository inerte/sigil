mode total

e stdlibIo:{debug:λ(String)=>!Log Unit,eprintln:λ(String)=>!Log Unit,print:λ(String)=>!Log Unit,println:λ(String)=>!Log Unit,warn:λ(String)=>!Log Unit}

λdebug(msg:String)=>!Log Unit=stdlibIo.debug(msg)

λeprintln(msg:String)=>!Log Unit=stdlibIo.eprintln(msg)

λprint(msg:String)=>!Log Unit=stdlibIo.print(msg)

λprintln(msg:String)=>!Log Unit=stdlibIo.println(msg)

λwarn(msg:String)=>!Log Unit=stdlibIo.warn(msg)
