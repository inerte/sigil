Î»normalizeRepoPath(path:String)â†’String=
  stdlibâ‹…string.join("/",normalizeSegments(stdlibâ‹…string.split("/",path),[]))

Î»normalizeSegments(parts:[String],stack:[String])â†’[String] match parts{
  []â†’stack|
  [part,.rest]â†’match part{
    ""â†’normalizeSegments(rest,stack)|
