λmain()=>Unit=()

test "random intBetween normalizes fixture draws into inclusive ranges" =>!Random world {
  c random=(†random.fixture([
  5,
  -1,
  8
]):†random.RandomEntry)
} {
  l first=(§random.intBetween(
    7,
    3
  ):Int);
  l second=(§random.intBetween(
    7,
    3
  ):Int);
  l third=(§random.intBetween(
    7,
    3
  ):Int);
  first=3
    and second=7
    and third=6
}

test "random pick returns none for empty input" =>!Random world {
  c random=(†random.seeded(1337):†random.RandomEntry)
} {
  match §random.pick(([]:[String])){
    None()=>true|
    Some(_)=>false
  }
}

test "random shuffle is deterministic under seeded world" =>!Random world {
  c random=(†random.seeded(1337):†random.RandomEntry)
} {
  §random.shuffle([
    1,
    2,
    3,
    4
  ])=[
    3,
    1,
    2,
    4
  ]
}
