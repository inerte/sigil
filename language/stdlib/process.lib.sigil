t Command={argv:[String],cwd:Option[String],env:{Stringâ†¦String}}

t RunningProcess={pid:Int}

t ProcessResult={code:Int,stderr:String,stdout:String}

Î»argv()=>!Process [String]=[]

Î»command(argv:[String])=>Command={argv:argv,cwd:None(),env:({â†¦}:{Stringâ†¦String})}

Î»exit(code:Int)=>!Process Unit=()

Î»kill(process:RunningProcess)=>!Process Unit=()

Î»run(command:Command)=>!Process ProcessResult={code:-1,stderr:"process intrinsic unavailable",stdout:""}

Î»start(command:Command)=>!Process RunningProcess={pid:-1}

Î»wait(process:RunningProcess)=>!Process ProcessResult={code:-1,stderr:"process intrinsic unavailable",stdout:""}

Î»withCwd(command:Command,cwd:String)=>Command={argv:command.argv,cwd:Some(cwd),env:command.env}

Î»withEnv(command:Command,env:{Stringâ†¦String})=>Command={argv:command.argv,cwd:command.cwd,env:env}
