λmain()=>Unit=()

test "json parse returns Err for invalid input" {
  match §json.parse("{bad"){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "json parse returns object for valid input" {
  match §json.parse("{\"name\":\"sigil\",\"ok\":true}"){
    Ok(value)=>match §json.asObject(value){
      Some(_)=>true|
      None()=>false
    }|
    Err(_)=>false
  }
}

test "json stringify roundtrip preserves shape" {
  l value=(§json.JsonObject({
    "active"↦§json.JsonBool(true),
    "name"↦§json.JsonString("sigil")
  }):§json.JsonValue);
  match §json.parse(§json.stringify(value)){
    Ok(parsed)=>parsed=value|
    Err(_)=>false
  }
}
