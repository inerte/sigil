    name:"lcm",
    pattern:"^λlcm\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:Int\\)=>Int(?==| match)",
    replacement:"§numeric.lcm"
  },
  {
    name:"lines",
    pattern:"^λlines\\(([a-z][A-Za-z0-9]*):String\\)=>\\[String\\](?==| match)",
    replacement:"§string.lines"
  },
  {
    name:"maxList",
    pattern:"^λmax\\(([a-z][A-Za-z0-9]*):\\[Int\\]\\)=>Option\\[Int\\](?==| match)",
    replacement:"§list.max"
  },
  {
    name:"maxNumeric",
    pattern:"^λmax\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:Int\\)=>Int(?==| match)",
    replacement:"§numeric.max"
  },
  {
    name:"minList",
    pattern:"^λmin\\(([a-z][A-Za-z0-9]*):\\[Int\\]\\)=>Option\\[Int\\](?==| match)",
    replacement:"§list.min"
  },
  {
    name:"minNumeric",
    pattern:"^λmin\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:Int\\)=>Int(?==| match)",
    replacement:"§numeric.min"
  },
  {
    name:"mod",
    pattern:"^λmod\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:Int\\)=>Int(?==| match)",
    replacement:"§numeric.mod"
  },
  {
    name:"nth",
    pattern:"^λnth\\[([A-Z][A-Za-z0-9]*)\\]\\([a-z][A-Za-z0-9]*:Int,[a-z][A-Za-z0-9]*:\\[\\1\\]\\)=>Option\\[\\1\\](?==| match)",
    replacement:"§list.nth"
  },
  {
    name:"pow",
    pattern:"^λpow\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:Int\\)=>Int(?==| match)",
    replacement:"§numeric.pow"
  },
  {
    name:"product",
    pattern:"^λproduct\\(([a-z][A-Za-z0-9]*):\\[Int\\]\\)=>Int(?==| match)",
    replacement:"§list.product"
  },
  {
    name:"range",
    pattern:"^λrange\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:Int\\)=>\\[Int\\](?==| match)",
    replacement:"§numeric.range"
  },
  {
    name:"removeFirst",
    pattern:"^λremoveFirst\\[([A-Z][A-Za-z0-9]*)\\]\\([a-z][A-Za-z0-9]*:\\1,[a-z][A-Za-z0-9]*:\\[\\1\\]\\)=>\\[\\1\\](?==| match)",
    replacement:"§list.removeFirst"
  },
  {
    name:"repeat",
    pattern:"^λrepeat\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:String\\)=>String(?==| match)",
    replacement:"§string.repeat"
  },
  {
    name:"replaceAll",
    pattern:"^λreplaceAll\\(([a-z][A-Za-z0-9]*):String,[a-z][A-Za-z0-9]*:String,[a-z][A-Za-z0-9]*:String\\)=>String(?==| match)",
    replacement:"§string.replaceAll"
  },
  {
