i stdlib::file

i stdlib::path

i stdlib::process

i stdlib::string

i src::support

λbadMatchSource()=>String="λfib(n:Int)=>Int match n{0=>0|1=>1|value=>fib(value-1)+fib(value-2)}\nλmain()=>Int=fib(5)\n"

λbadSignatureSource()=>String="λfib(n:Int)=>Int\nmatch n{0=>0}\nλmain()=>Int=fib(5)\n"

λcompile(file:String)=>!Process stdlib::process.ProcessResult=stdlib::process.run(src::support.sigil(["compile",file]))

λgoodFibSource()=>String="λfib(n:Int)=>Int=fibHelper(0,1,n)\n\nλfibHelper(a:Int,b:Int,n:Int)=>Int match n{\n  0=>a|\n  value=>fibHelper(b,a+b,value-1)\n}\n\nλmain()=>Int=fib(5)\n"

λmain()=>Unit=()

test "canonical rejects single-line multi-arm match" =>!Clock!Fs!Process  {
  l root=(src::support.uniqueRepoTempDir("canonicalMatch"):String);
  l file=(stdlib::path.join(root,"badMatch.sigil"):String);
  l _=(stdlib::file.writeText(badMatchSource(),file):Unit);
  l result=(compile(file):stdlib::process.ProcessResult);
  l _=(stdlib::file.removeTree(root):Unit);
  stdlib::string.indexOf(src::support.combinedOutput(result),"SIGIL-CANON-SOURCE-FORM")≥0=true
}

test "canonical rejects split signature before match" =>!Clock!Fs!Process  {
  l root=(src::support.uniqueRepoTempDir("canonicalSignature"):String);
  l file=(stdlib::path.join(root,"badSignature.sigil"):String);
  l _=(stdlib::file.writeText(badSignatureSource(),file):Unit);
  l result=(compile(file):stdlib::process.ProcessResult);
  l _=(stdlib::file.removeTree(root):Unit);
  stdlib::string.indexOf(src::support.combinedOutput(result),"SIGIL-CANON-SOURCE-FORM")≥0=true
}

test "canonical fib fixture compiles" =>!Clock!Fs!Process  {
  l root=(src::support.uniqueRepoTempDir("canonicalGood"):String);
  l file=(stdlib::path.join(root,"goodFib.sigil"):String);
  l _=(stdlib::file.writeText(goodFibSource(),file):Unit);
  l result=(compile(file):stdlib::process.ProcessResult);
  l _=(stdlib::file.removeTree(root):Unit);
  result.code=0
}

test "list reverse example compiles" =>!Process  {
  l result=(compile(src::support.repoPath("projects/algorithms/src/listReverse.sigil")):stdlib::process.ProcessResult);
  result.code=0
}

test "list length example compiles" =>!Process  {
  l result=(compile(src::support.repoPath("projects/algorithms/src/listLength.sigil")):stdlib::process.ProcessResult);
  result.code=0
}
