t Error={code:ℤ,msg:𝕊}
t Request={body:𝕊,method:𝕊,path:𝕊}
t Response={body:𝕊,headers:{𝕊↦𝕊},status:ℤ}

λget_users(req:Request)→Result[Response,Error]=Ok(Response{body:"[{\"id\":1,\"name\":\"Alice\"}]",headers:{"Content-Type"↦"application/json"},status:200})

λhandle_request(req:Request)→Result[Response,Error] match req.path{"/users"→get_users(req)|"/health"→Ok(Response{body:"OK",headers:({↦}:{𝕊↦𝕊}),status:200})|_→Err(Error{code:404,msg:"Not found"})}

λmain()→Result[Response,Error]=handle_request(Request{body:"",method:"GET",path:"/users"})
