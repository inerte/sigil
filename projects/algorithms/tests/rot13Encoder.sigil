λmain()=>Unit=()

test "rot13 encodes hello world" {
  •rot13Encoder.rot13([
    "H",
    "e",
    "l",
    "l",
    "o",
    ",",
    " ",
    "W",
    "o",
    "r",
    "l",
    "d",
    "!"
  ])="Uryyb, Jbeyq!"
}

test "rot13 preserves punctuation" {
  •rot13Encoder.rot13([
    "!",
    ".",
    ",",
    " "
  ])="!., "
}
