λfetchStatus()=>String="real"

λmain()=>Unit=()

test "withMock body can compose booleans" {
  withMock(fetchStatus,λ()=>String="temporary"){fetchStatus()="temporary" and fetchStatus()≠"real"}
}

test "withMock can replace any function in tests" {
  withMock(fetchStatus,λ()=>String="mocked"){fetchStatus()="mocked"}
}
