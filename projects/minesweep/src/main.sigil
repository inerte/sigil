total Î»cellLabel(cell:ÂµCell)=>String match cell.revealed{
  true=>match cell.bomb{
    true=>"*"|
    false=>match cell.adjacent=0{
      true=>"Â·"|
      false=>Â§string.intToString(cell.adjacent)
    }
  }|
  false=>match cell.flagged{
    true=>"!"|
    false=>"â–ˇ"
  }
}

total Î»joinCells(cells:[ÂµCell])=>String
decreases #cells
match cells{
  []=>""|
  [cell]=>cellLabel(cell)|
  [
  cell,
  .rest
]=>cellLabel(cell)
    ++" "
    ++joinCells(rest)
}

