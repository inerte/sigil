λallOk(results:[Bool])=>Bool=§list.all(λ(result:Bool)=>Bool=result,results)

λmain()=>Unit=()

test "compiler command uses repo relative output paths" {
  l command=(•examplesCompile.compilerCommand(§path.join("/repo",".local/out/example.ts"),"/repo","language/examples/demo.sigil"):§process.Command);
  allOk([command.argv=[§path.join("/repo","language/compiler/target/debug/sigil"),"compile","-o",".local/out/example.ts","language/examples/demo.sigil"],match command.cwd{
    Some(cwd)=>cwd="/repo"|
    None()=>false
  }])
}

test "parse tracked files keeps non empty paths" {
  match •examplesCompile.parseTrackedFiles({code:0,stderr:"",stdout:"language/examples/a.sigil
language/examples/b.lib.sigil

"}){
    Ok(paths)=>paths=["language/examples/a.sigil","language/examples/b.lib.sigil"]|
    Err(_)=>false
  }
}

test "parse tracked files surfaces git failure" {
  match •examplesCompile.parseTrackedFiles({code:1,stderr:"boom",stdout:""}){
    Ok(_)=>false|
    Err(message)=>message="git ls-files failed: boom"
  }
}

test "process output prefers stderr then stdout" {
  allOk([•examplesCompile.processOutput({code:1,stderr:" boom ",stdout:"ok"})="boom",•examplesCompile.processOutput({code:1,stderr:"",stdout:" ok "})="ok"])
}

