λmain()=>Unit=()

test "# returns string length" {
  #"hello"=5
}

test "# works on empty string" {
  #""=0
}

test "# works on unicode strings" {
  #"🚀"=2
}

test "# returns list length" {
  #[1,2,3]=3
}

test "charAt at index 0" {
  §string.charAt(0,"hello")="h"
}

test "contains finds present substring" {
  §string.contains("hello world","world")
}

test "contains reports missing substring" {
  ¬§string.contains("hello","xyz")
}

test "contains treats empty search as present" {
  §string.contains("hello","")
}

test "contains matches whole string" {
  §string.contains("hello","hello")
}

test "charAt at middle index" {
  §string.charAt(2,"hello")="l"
}

test "drop first n characters" {
  §string.drop(2,"hello")="llo"
}

test "drop with 0" {
  §string.drop(0,"hello")="hello"
}

test "endsWith actual suffix" {
  §string.endsWith("file.txt",".txt")=true
}

test "endsWith non-suffix" {
  §string.endsWith("hello",".txt")=false
}

test "indexOf finds occurrence" {
  §string.indexOf("hello world","o")=4
}

test "indexOf not found" {
  §string.indexOf("hello","z")=-1
}

test "intToString negative" {
  §string.intToString(-10)="-10"
}

test "intToString positive" {
  §string.intToString(42)="42"
}

test "intToString zero" {
  §string.intToString(0)="0"
}

test "isDigit letter" {
  §string.isDigit("a")=false
}

test "isDigit multi-character" {
  §string.isDigit("42")=false
}

test "isDigit single" {
  §string.isDigit("5")=true
}

test "join empty list" {
  §string.join(",",[])=""
}

test "join with separator" {
  §string.join(",",["a","b","c"])="a,b,c"
}

test "lines splits on newline" {
  §string.lines("a
b
c")=["a","b","c"]
}

test "lines preserves single line" {
  §string.lines("hello")=["hello"]
}

test "repeat repeats content" {
  §string.repeat(3,"ab")="ababab"
}

test "repeat with non-positive count returns empty" {
  §string.repeat(0,"ab")=""
}

test "reverse flips string contents" {
  §string.reverse("stressed")="desserts"
}

test "replaceAll all occurrences" {
  §string.replaceAll("o","0","hello world")="hell0 w0rld"
}

test "replaceAll no matches" {
  §string.replaceAll("z","x","hello")="hello"
}

test "split by delimiter" {
  §string.split(",","a,b,c")=["a","b","c"]
}

test "split single element" {
  §string.split(",","hello")=["hello"]
}

test "startsWith non-prefix" {
  §string.startsWith("abc","hello")=false
}

test "startsWith prefix" {
  §string.startsWith("hel","hello")=true
}

test "substring full string" {
  §string.substring(5,"hello",0)="hello"
}

test "substring portion" {
  §string.substring(4,"hello",1)="ell"
}

test "take first n" {
  §string.take(3,"hello")="hel"
}

test "take n greater than length" {
  §string.take(10,"hi")="hi"
}

test "toLower converts uppercase" {
  §string.toLower("HELLO")="hello"
}

test "toLower preserves lowercase" {
  §string.toLower("hello")="hello"
}

test "toUpper converts lowercase" {
  §string.toUpper("hello")="HELLO"
}

test "toUpper preserves uppercase" {
  §string.toUpper("HELLO")="HELLO"
}

test "trimEndChars trims repeated trailing slash characters" {
  §string.trimEndChars("/","https://sigil.dev///")="https://sigil.dev"
}

test "trimEndChars uses chars as a set" {
  §string.trimEndChars("/.","docs/...")="docs"
}

test "trimEndChars leaves non-matching suffix untouched" {
  §string.trimEndChars("/","docs")="docs"
}

test "trimEndChars with empty chars is a no-op" {
  §string.trimEndChars("","docs///")="docs///"
}

test "trimStartChars trims repeated leading slash characters" {
  §string.trimStartChars("/","///docs")="docs"
}

test "trimStartChars uses chars as a set" {
  §string.trimStartChars("/.","../docs")="docs"
}

test "trimStartChars leaves non-matching prefix untouched" {
  §string.trimStartChars("/","docs")="docs"
}

test "trimStartChars with empty chars is a no-op" {
  §string.trimStartChars("","///docs")="///docs"
}

test "trim both sides" {
  §string.trim("  hello  ")="hello"
}

test "trim leading" {
  §string.trim("  hello")="hello"
}

test "trim trailing" {
  §string.trim("hello  ")="hello"
}

test "unlines joins with newline" {
  §string.unlines(["a","b","c"])="a
b
c"
}

test "unlines on empty list" {
  §string.unlines([])=""
}

test "extract title from markdown" {
  match §string.startsWith("# ",§string.split("
","# Hello World
Content here")[0]){
    true=>§string.substring(#§string.split("
","# Hello World
Content here")[0],§string.split("
","# Hello World
Content here")[0],2)="Hello World"|
    false=>false
  }
}
