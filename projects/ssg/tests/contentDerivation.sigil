test "article ordering uses newest date first" {
  l pages=([
    articlePage("2026-02-24","older"),
    articlePage("2026-03-03","newer")
  ]:[srcâ‹…types.SitePage]);
  l sorted=(srcâ‹…content.pagesNewestFirst(pages):[srcâ‹…types.SitePage]);
  sorted[0].meta.slug="newer" and sorted[1].meta.slug="older"
}

test "article ordering falls back to descending source path" {
  l pages=([
    articlePage("","001-alpha"),
    articlePage("","002-beta")
  ]:[srcâ‹…types.SitePage]);
  l sorted=(srcâ‹…content.pagesNewestFirst(pages):[srcâ‹…types.SitePage]);
  sorted[0].meta.slug="002-beta" and sorted[1].meta.slug="001-alpha"
}

