λbadMatchSource()=>String="λfib(n:Int)=>Int match n{0=>0|1=>1|value=>fib(value-1)+fib(value-2)}
λmain()=>Int=fib(5)
"

λbadSignatureSource()=>String="λfib(n:Int)=>Int
match n{0=>0}
λmain()=>Int=fib(5)
"

λcompile(file:String)=>!Process §process.ProcessResult=§process.run(•support.sigil(["compile",file]))

λgoodFibSource()=>String="λfib(n:Int)=>Int=fibHelper(0,1,n)

λfibHelper(a:Int,b:Int,n:Int)=>Int match n{
  0=>a|
  value=>fibHelper(b,a+b,value-1)
}

λmain()=>Int=fib(5)
"

λmain()=>Unit=()

test "canonical rejects single-line multi-arm match" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalMatch"):String);
  l file=(§path.join(root,"badMatch.sigil"):String);
  l _=(§file.writeText(badMatchSource(),file):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  §string.indexOf(•support.combinedOutput(result),"SIGIL-CANON-SOURCE-FORM")≥0=true
}

test "canonical rejects split signature before match" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalSignature"):String);
  l file=(§path.join(root,"badSignature.sigil"):String);
  l _=(§file.writeText(badSignatureSource(),file):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  §string.indexOf(•support.combinedOutput(result),"SIGIL-CANON-SOURCE-FORM")≥0=true
}

test "canonical fib fixture compiles" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalGood"):String);
  l file=(§path.join(root,"goodFib.sigil"):String);
  l _=(§file.writeText(goodFibSource(),file):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  result.code=0
}

test "list reverse example compiles" =>!Process {
  l result=(compile(•support.repoPath("projects/algorithms/src/listReverse.sigil")):§process.ProcessResult);
  result.code=0
}

test "list length example compiles" =>!Process {
  l result=(compile(•support.repoPath("projects/algorithms/src/listLength.sigil")):§process.ProcessResult);
  result.code=0
}
