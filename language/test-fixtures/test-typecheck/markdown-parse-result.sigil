⟦ Test: Exact structure from markdown.sigil ⟧

t Block=Header(ℤ,𝕊)|Paragraph(𝕊)

t ParseResult={blocks:[Block],state:ParseState}

t ParseState={
  code_lang:𝕊,
  code_lines:[𝕊],
  in_code_block:𝔹,
  para_lines:[𝕊]
}

λmain()→𝕌=()

λtest(x:𝔹)→ParseResult match x{
  true → {blocks:[],state:{code_lang:"",code_lines:[],in_code_block:false,para_lines:[]}}|
  false → {blocks:[Paragraph("hi")],state:{code_lang:"js",code_lines:["test"],in_code_block:true,para_lines:[]}}
}
