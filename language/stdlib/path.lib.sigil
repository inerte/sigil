t RelativeState={
  left:[String],
  right:[String]
}

total λbasename(value:String)=>String match §list.last(splitNonempty(normalize(value))){
  Some(segment)=>segment|
  None()=>normalize(value)
}

total λdirname(value:String)=>String=dirnameFromSegments(
  §string.startsWith(
    "/",
    (normalize(value):String)
  ),
  splitNonempty((normalize(value):String))
)

total λdirnameFromSegments(isAbsolute:Bool,segments:[String])=>String match #segments≤1{
  true=>rootOrCurrent(isAbsolute)|
  false=>pathFromSegments(
    isAbsolute,
    §list.take(
      #segments-1,
      segments
    )
  )
}

total λextname(value:String)=>String=extnameFromParts(
  (basename(value):String),
  §string.split(
    ".",
    (basename(value):String)
  )
)

total λextnameFromParts(name:String,parts:[String])=>String match #parts≤1{
  true=>""|
  false=>match §string.startsWith(
    ".",
    name
  ) and #parts=2{
    true=>""|
    false=>match §list.last(parts){
      Some(lastPart)=>"."++lastPart|
      None()=>""
    }
  }
}

total λfilterEmpty(segments:[String])=>[String]
decreases #segments
match segments{
  []=>[]|
  [
  segment,
  .rest
]=>match #segment=0{
    true=>filterEmpty(rest)|
    false=>([segment]:[String])⧺filterEmpty(rest)
  }
}

total λjoin(left:String,right:String)=>String match #left=0{
  true=>normalize(right)|
  false=>match #right=0{
    true=>normalize(left)|
    false=>normalize(left
      ++"/"
      ++right)
  }
}

total λnormalize(value:String)=>String={
  l isAbsolute=(§string.startsWith(
    "/",
    value
  ):Bool);
  pathFromSegments(
    isAbsolute,
    (normalizeSegments(
      [],
      isAbsolute,
      filterEmpty(§string.split(
        "/",
        value
      ))
    ):[String])
  )
}

total λnormalizeSegments(acc:[String],isAbsolute:Bool,segments:[String])=>[String]
decreases #segments
match segments{
  []=>§list.reverse(acc)|
  [
  segment,
  .rest
]=>match segment="."{
    true=>normalizeSegments(
      acc,
      isAbsolute,
      rest
    )|
    false=>match segment=".."{
      true=>match acc{
        []=>match isAbsolute{
          true=>normalizeSegments(
            [],
            isAbsolute,
            rest
          )|
          false=>normalizeSegments(
            ([".."]:[String]),
            isAbsolute,
            rest
          )
        }|
        [
  head,
  .more
]=>match head=".."{
          true=>normalizeSegments(
            ([".."]:[String])⧺acc,
            isAbsolute,
            rest
          )|
          false=>normalizeSegments(
            more,
            isAbsolute,
            rest
          )
        }
      }|
      false=>normalizeSegments(
        ([segment]:[String])⧺acc,
        isAbsolute,
        rest
      )
    }
  }
}

total λpathFromSegments(isAbsolute:Bool,segments:[String])=>String match isAbsolute{
  true=>match #(§string.join(
    "/",
    segments
  ):String)=0{
    true=>"/"|
    false=>"/"++(§string.join(
      "/",
      segments
    ):String)
  }|
  false=>match #(§string.join(
    "/",
    segments
  ):String)=0{
    true=>"."|
    false=>(§string.join(
      "/",
      segments
    ):String)
  }
}

total λrelative(from:String,to:String)=>String={
  l state=(relativeDropCommon(
    (splitNonempty(normalize(from)):[String]),
    splitNonempty(normalize(to))
  ):RelativeState);
  pathFromSegments(
    false,
    (repeatSegment(
      #state.left,
      ".."
    ):[String])⧺state.right
  )
}

total λrelativeDropCommon(left:[String],right:[String])=>RelativeState
decreases (#left, #right)
match left{
  []=>{
    left:[],
    right:right
  }|
  [
  leftHead,
  .leftRest
]=>match right{
    []=>{
      left:left,
      right:[]
    }|
    [
  rightHead,
  .rightRest
]=>match leftHead=rightHead{
      true=>relativeDropCommon(
        leftRest,
        rightRest
      )|
      false=>{
        left:left,
        right:right
      }
    }
  }
}

total λrepeatSegment(count:Int,segment:String)=>[String]
decreases count
match count≤0{
  true=>[]|
  false=>([segment]:[String])⧺repeatSegment(
    count-1,
    segment
  )
}

total λrootOrCurrent(isAbsolute:Bool)=>String match isAbsolute{
  true=>"/"|
  false=>"."
}

total λsplitNonempty(value:String)=>[String]=filterEmpty(§string.split(
  "/",
  value
))
