    replacement:"§numeric.sign"
  },
  {
    name:"split",
    pattern:"^λsplit\\(([a-z][A-Za-z0-9]*):String,[a-z][A-Za-z0-9]*:String\\)=>\\[String\\](?==| match)",
    replacement:"§string.split"
  },
  {
    name:"sortedAsc",
    pattern:"^λsortedAsc\\(([a-z][A-Za-z0-9]*):\\[Int\\]\\)=>Bool(?==| match)",
    replacement:"§list.sortedAsc"
  },
  {
    name:"sortedDesc",
    pattern:"^λsortedDesc\\(([a-z][A-Za-z0-9]*):\\[Int\\]\\)=>Bool(?==| match)",
