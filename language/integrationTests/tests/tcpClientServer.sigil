λmain()=>Unit=()

λprojectDir()=>String=•support.repoPath("projects/topology-tcp")

λrawClientFile()=>String=§path.join(projectDir(),"src/rawTcpClient.sigil")

λrawClientSource()=>String="λmain()=>!Tcp String match §tcpClient.send(\"ping\",\"127.0.0.1\"){
  Ok(response)=>response.message|
  Err(error)=>error.message
}
"

λrawEndpointCompileOutput()=>!Fs!Process String={
  l _=(§file.writeText(rawClientSource(),rawClientFile()):Unit);
  l result=(§process.run(tcpCommand(["compile","src/rawTcpClient.sigil"])):§process.ProcessResult);
  l _=(§file.remove(rawClientFile()):Unit);
  •support.combinedOutput(result)
}

λrunClientOutput(target:String)=>!Process!Timer String={
  l server=(§process.start(tcpCommand(["run","src/tcpRoundtripServer.sigil","--env","test"])):§process.RunningProcess);
  l ready=(•support.retryRunStdoutContains(50,tcpCommand(["run","src/pingClient.sigil","--env","test"]),200,"pong"):§process.ProcessResult);
  l result=match •support.runStdoutContains("pong",ready){
    true=>(§process.run(tcpCommand(["run",target,"--env","test"])):§process.ProcessResult)|
    false=>ready
  };
  l _=(§process.kill(server):Unit);
  l _=(§process.wait(server):§process.ProcessResult);
  •support.combinedOutput(result)
}

λtcpCommand(args:[String])=>§process.Command=•support.sigilIn(args,projectDir())

λvalidateResult()=>!Process §process.ProcessResult=§process.run(tcpCommand(["validate",".","--env","test"]))

test "tcp topology validates for test env" =>!Process {
  l result=(validateResult():§process.ProcessResult);
  result.code=0
}

test "tcp ping client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/pingClient.sigil"),"pong")≥0=true
}

test "tcp echo client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/echoClient.sigil"),"echoed")≥0=true
}

test "tcp upper client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/upperClient.sigil"),"HELLO")≥0=true
}

test "tcp raw endpoint compile is forbidden" =>!Fs!Process {
  §string.indexOf(rawEndpointCompileOutput(),"SIGIL-TOPO-RAW-ENDPOINT-FORBIDDEN")≥0=true
}
