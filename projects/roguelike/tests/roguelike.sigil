    ),
    •roguelike.demoStateWithInventory(
      [•roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          6,
          4
        )
      )],
      0,
      0,
      •roguelike.point(
        35,
        12
      ),
      [•roguelike.potionPickup(•roguelike.point(
        4,
        4
      ))],
      0
    )
  ):µGameState);
  l treasureState=(•roguelike.collectPickup(
    •roguelike.point(
      5,
      4
    ),
    •roguelike.demoStateWithInventory(
      [•roguelike.playerActor(
        5,
