⟦ TEST: with_mock parser/typechecker/codegen parity ⟧

e console

mockable λfetch_status()→!IO 𝕊="real"

λmain()→𝕌=()

test "with_mock body can compose booleans" →!IO {
  with_mock(fetch_status, λ()→!IO 𝕊="temporary") {
    fetch_status()="temporary"∧fetch_status()≠"real"
  }
}

test "with_mock can replace a mockable function" →!IO {
  with_mock(fetch_status, λ()→!IO 𝕊="mocked") {
    fetch_status()="mocked"
  }
}
