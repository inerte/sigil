    replacement:"§list.reverse"
  },
  {
    name:"reverseString",
    pattern:"^λreverse\\(([a-z][A-Za-z0-9]*):String\\)=>String(?==| match)",
    replacement:"§string.reverse"
  },
  {
    name:"sign",
