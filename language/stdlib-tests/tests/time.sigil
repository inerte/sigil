λmain()=>Unit=()

test "time compare orders instants" {
  match §time.parseIso("2026-03-01"){
    Ok(first)=>match §time.parseIso("2026-03-03"){
      Ok(second)=>§time.compare(
        first,
        second
      )<0|
      Err(_)=>false
    }|
    Err(_)=>false
  }
}

test "time parse rejects non-iso date" {
  match §time.parseIso("March 3, 2026"){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "time parse accepts iso date" {
  match §time.parseIso("2026-03-03"){
    Ok(_)=>true|
    Err(_)=>false
  }
}
