total Î»renderRow(board:[ÂµCell],width:Int,x:Int,y:Int)=>[ÂµCell]
decreases #board
match board{
  []=>[]|
  [
  cell,
  .rest
]=>match cell.y=y
    and cell.xâ‰Ąx
    and cell.x<width{
    true=>[cell]â§şrenderRow(
      rest,
      width,
      cell.x+1,
      y
    )|
    false=>renderRow(
      rest,
      width,
      x,
      y
    )
  }
}

total Î»renderRows(board:[ÂµCell],height:Int,width:Int,y:Int)=>String
requires yâ‰¤height
decreases height+-y
match yâ‰Ąheight{
  true=>""|
