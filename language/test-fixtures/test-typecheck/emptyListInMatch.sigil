t Foo=A()|B()|C()

λmain()=>Unit=()

λtest1(x:Foo)=>[Int] match x{
  A()=>[1,2,3]|
  B()=>[]|
  C()=>[4,5]
}

λtest2(x:Foo)=>[String] match x{
  A()=>["hello"]|
  B()=>[]|
  C()=>[]
}

λtest3(x:Foo,y:Foo)=>[Int] match x{
  A()=>[1]|
  B()=>match y{
    A()=>[2]|
    B()=>[]|
    C()=>[3]
  }|
  C()=>[]
}
