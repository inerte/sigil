λmain()=>!Http String match §httpClient.get(
  •topology.mailerApi,
  §httpClient.emptyHeaders(),
  "/headers"
){
  Ok(response)=>match ¶map.get(
    "x-request-id",
    response.headers
  ){
    Some(value)=>§string.intToString(response.status)
      ++":"
      ++value|
    None()=>"ERR:missing-header"
  }|
  Err(error)=>"ERR:"++error.message
}
