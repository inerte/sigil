test "run check reuses matching cache entries without spawning compile" =>!AuditIo world {
  c fs=(†fs.sandbox(".local/repoCompile/cache-hit"):†fs.FsEntry)
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:"language/examples/addsNumbers.sigil
"
    }
  ),
  †process.rule(
    (•repoCompile.compilerBinaryHashCommand(".").argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:"compiler-hash
"
    }
  )
]):†process.ProcessEntry)
} {
  l task=({
    env:None(),
    path:"language",
    root:"."
  }:µRepoCompileTask);
  l _=(§file.makeDirs("language/examples"):Unit);
  l _=(§file.writeText(
    "λmain()=>Int=1
",
    "language/examples/addsNumbers.sigil"
  ):Unit);
  match •repoCompile.targetFingerprint(
    "compiler-hash",
    ["language/examples/addsNumbers.sigil"],
    task
  ){
    Ok(fingerprint)=>{
      l _=(§file.makeDirs(•repoCompile.repoCompileCacheDir(".")):Unit);
      l _=(§file.writeText(
        •repoCompile.encodeRepoCompileCacheEntry({fingerprint:fingerprint}),
        •repoCompile.cacheEntryPath(
          ".",
          task
        )
      ):Unit);
      match •repoCompile.runCheck(){
        Ok(result)=>result.issues=[]
          and result.stats.cacheHits=1
          and result.stats.cacheMisses=0
          and result.stats.compiled=0
          and result.stats.considered=1
          and result.stats.durationMs≥0|
        Err(_)=>false
      }
    }|
    Err(_)=>false
  }
}

