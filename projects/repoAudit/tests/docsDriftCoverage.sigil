λallOk(results:[Bool])=>Bool=§list.all(
  λ(result:Bool)=>Bool=result,
  results
)

λfenceInfo(context:Option[String],kind:String)=>µFenceInfo={
  context:context,
  kind:kind
}

λmain()=>Unit=()

λrepoRoot()=>!Process String match •docsDrift.gitTopLevel(){
  Err(_)=>"."|
  Ok(root)=>root
}

λsnippet(content:String,filePath:String,info:µFenceInfo,line:Int)=>µSnippet={
  content:content,
  filePath:filePath,
  info:info,
  line:line
}

test "coverage helpers parse refs exports and identifiers" {
  l parseJson=("{\"type\":\"FunctionDecl\",\"name\":\"contains\",\"type\":\"FunctionDecl\",\"name\":\"trim\",\"type\":\"FunctionDecl\",\"name\":\"split\",\"type\":\"FunctionDecl\",\"name\":\"trimEndChars\",\"type\":\"FunctionDecl\",\"name\":\"trimStartChars\"}":String);
  match §regex.compile(
    "",
    "\"type\":\"FunctionDecl\"|\"name\":\"[A-Za-z_][A-Za-z0-9_]*\""
  ){
    Ok(tokenPattern)=>match §regex.compile(
      "",
      "§[A-Za-z0-9]+\\.[a-z][A-Za-z0-9]*"
    ){
      Ok(refPattern)=>allOk([
        •coverage.collectQualifiedRefsLine(
          refPattern,
          [],
          "§list.sum(xs) and §list.sum(ys)"
        )=["§list.sum"],
        •coverage.collectQualifiedRefsLines(
          ["§string.trim(s)"],
          refPattern,
          []
        )=["§string.trim"],
        •coverage.documentedRefsForSnippetLines(
          [
            "λtrim(s:String)=>String",
            "c ignored=1"
          ],
          "§string",
          []
        )=["§string.trim"],
        •coverage.collectQualifiedRefs("⟦ mention §string.split but ignore it ⟧
§string.trim(text)")=["§string.trim"],
        •coverage.collectQualifiedRefs("λsample()=>String=§string.trim(text) ⟦ ignore §string.split in inline comment ⟧")=["§string.trim"],
        •coverage.collectStdlibExports(
          "language/stdlib/string.lib.sigil",
          parseJson
        )=[
          "§string.contains",
          "§string.trim",
          "§string.split",
          "§string.trimEndChars",
          "§string.trimStartChars"
        ],
        •coverage.functionNamesFromParseJson(parseJson)=[
          "contains",
          "trim",
          "split",
          "trimEndChars",
          "trimStartChars"
        ],
        •coverage.functionNamesFromTokens(
          false,
          [],
          tokenPattern,
          parseJson
        )=[
          "contains",
          "trim",
          "split",
          "trimEndChars",
          "trimStartChars"
        ],
        •coverage.dropUntilBoundary(
          "",
          "trim):String"
        )="trim",
        match •coverage.extractFunctionName("λtrim(s:String)=>String"){
          Some(name)=>name="trim"|
          None()=>false
        },
        match •coverage.extractFunctionName("c sample=1"){
          Some(_)=>false|
          None()=>true
        },
        •coverage.extractFunctionNameInner(
          "",
          "split(text:String)=>[String]"
        )="split",
        •coverage.insertUnique(
          "beta",
          ["alpha"]
        )=[
          "alpha",
          "beta"
        ],
        •coverage.isIdentifierChar("Z"),
        ¬•coverage.isIdentifierChar("-"),
        •coverage.mergeUnique(
          ["alpha"],
          [
            "beta",
            "alpha"
          ]
        )=[
          "alpha",
          "beta"
        ],
        •coverage.moduleNameFromStdlibFile("language/stdlib/string.lib.sigil")="string",
        •coverage.modulePathFromStdlibFile("language/stdlib/string.lib.sigil")="§string",
        •coverage.qualifyExports(
          ["trim"],
          "§string"
        )=["§string.trim"],
        •coverage.tokenName("\"name\":\"trim\"")="trim",
        •docsDrift.collectQualifiedRefs("§list.sum(xs)
§list.sum(ys)
")=["§list.sum"],
        •docsDrift.collectStdlibExports(
          "language/stdlib/string.lib.sigil",
          parseJson
        )=[
          "§string.contains",
          "§string.trim",
          "§string.split",
          "§string.trimEndChars",
          "§string.trimStartChars"
        ],
        •docsDrift.documentedRefsForSnippet(
          "§string",
          "λtrim(s:String)=>String
c ignored=1"
        )=["§string.trim"]
      ])|
      Err(_)=>false
    }|
    Err(_)=>false
  }
}

test "docs drift helper surface normalizes snippets and issues" {
  l command=(•docsDrift.compilerCommand(
    [
      "parse",
      "sample.sigil"
    ],
    "/repo"
  ):§process.Command);
  l exprSnippet=(snippet(
    §string.unlines([
      "\"hi\"",
      "\"bye\""
    ]),
    "docs/test.md",
    fenceInfo(
      None(),
      "exprs"
    ),
    1
  ):µSnippet);
  allOk([
    command.argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "parse",
      "sample.sigil"
    ],
    match command.cwd{
      Some(cwd)=>cwd="/repo"|
      None()=>false
    },
    •docsDrift.allLinesSatisfy(
      [
        "alpha",
        "beta"
      ],
      λ(line:String)=>Bool=#line>0
    ),
    ¬•docsDrift.allLinesSatisfy(
      [
        "alpha",
        ""
      ],
      λ(line:String)=>Bool=#line>0
    ),
    •docsDrift.declSnippetIssues(
      "docs/test.md",
      7,
      "c value=1"
    )=[{
      line:7,
      message:"sigil decl snippets may only contain type or function signatures",
      path:"docs/test.md"
    }],
    •docsDrift.declSnippetIssuesInner(
      "docs/test.md",
      3,
      [
        "λtrim(s:String)=>String",
        "c invalid=1"
      ]
    )=[{
      line:3,
      message:"sigil decl snippets may only contain type or function signatures",
      path:"docs/test.md"
    }],
    •docsDrift.defaultVirtualPath("module")="snippet.lib.sigil",
    •docsDrift.hasTopLevelPrefix(
      [
        "l local=1",
        "λmain()=>Unit=()"
      ],
      "λmain("
    ),
    •docsDrift.invalidFenceIssue(
      "docs/test.md",
      4,
      "boom"
    )={
      line:4,
      message:"boom",
      path:"docs/test.md"
    },
    •docsDrift.isCheckedKind("expr"),
    ¬•docsDrift.isCheckedKind("unknown"),
    •docsDrift.isDocAnnotationLine("⟦ doc ⟧"),
    •docsDrift.isProgramLikeLines(["test \"x\" { true }"]),
    •docsDrift.isTopLevelLikeLine("λtrim(s:String)=>String=s"),
    •docsDrift.isTopLevelLikeLines(["λtrim(s:String)=>String=s"]),
    •docsDrift.issueMessage({
      line:9,
      message:"bad",
      path:"docs/test.md"
    })="docs/test.md:9: bad",
    •docsDrift.mergeIssueLists(
      [{
        line:1,
        message:"left",
        path:"a.md"
      }],
      [{
        line:2,
        message:"right",
        path:"b.md"
      }]
    )=[
      {
        line:1,
        message:"left",
        path:"a.md"
      },
      {
        line:2,
        message:"right",
        path:"b.md"
      }
    ],
    •docsDrift.mergeUnique(
      ["alpha"],
      [
        "beta",
        "alpha"
      ]
    )=[
      "alpha",
      "beta"
    ],
    •docsDrift.normalizeSnippetContent(§string.unlines([
      "⟦ note ⟧",
      "λtrim(s:String)=>String=s",
      ""
    ]))="λtrim(s:String)=>String=s",
    •docsDrift.normalizedExprsKind(exprSnippet)="exprs",
    •docsDrift.normalizedSnippetContentForKind(
      "expr",
      §string.unlines([
        "⟦ note ⟧",
        "#xs",
        ""
      ])
    )="#xs",
    •docsDrift.normalizedSnippetLines(§string.unlines([
      "⟦ note ⟧",
      "λtrim(s:String)=>String=s",
      ""
    ]))=["λtrim(s:String)=>String=s"],
    •docsDrift.normalizedSnippetLinesInner([
      "⟦ note ⟧",
      "λtrim(s:String)=>String=s"
    ])=["λtrim(s:String)=>String=s"],
    •docsDrift.ordinalPath(
      2,
      "tmp"
    )=§path.join(
      "tmp",
      "snippet-2"
    ),
    match •docsDrift.parseFenceInfo("sigil expr"){
      Ok(info)=>{
        l parsed=(info:µFenceInfo);
        parsed.kind="expr" and (match parsed.context{
          None()=>true|
          Some(_)=>false
        })
      }|
      Err(_)=>false
    },
    match •docsDrift.parseFenceInfo("sigil mystery"){
      Ok(_)=>false|
      Err(message)=>§string.contains(
        message,
        "unknown Sigil fence kind"
      )
    },
    match •docsDrift.parseTrackedFiles({
      code:0,
      stderr:"",
      stdout:"a.md
b.md
"
    }){
      Ok(paths)=>paths=[
        "a.md",
        "b.md"
      ]|
      Err(_)=>false
    },
    match •docsDrift.parseTrackedFiles({
      code:1,
      stderr:"boom",
      stdout:""
    }){
      Ok(_)=>false|
      Err(message)=>message="boom"
    },
    •docsDrift.processOutput({
      code:1,
      stderr:" boom 
",
      stdout:"ok"
    })="boom",
    match •docsDrift.projectRootFromVirtualPath("projects/repoAudit/src/docsDrift.lib.sigil"){
