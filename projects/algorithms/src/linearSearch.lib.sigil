mode total

λlinearSearch(target:Int,xs:[Int])=>Int=linearSearchFrom(
  0,
  target,
  xs
)

λlinearSearchFrom(idx:Int,target:Int,xs:[Int])=>Int
requires #xs≥0
decreases #xs
match xs{
  []=>-1|
  [
  head,
  .tail
]=>match head=target{
    true=>idx|
    false=>linearSearchFrom(
      idx+1,
      target,
      tail
    )
  }
}
