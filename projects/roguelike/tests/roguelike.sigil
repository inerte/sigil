λmain()=>Unit=()

test "bestStepToward returns none from a blocked wall position" {
  match •roguelike.bestStepToward(
    1,
    false,
    •roguelike.point(
      0,
      0
    ),
    •roguelike.demoState(
      [•roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          0,
          0
        )
      )],
      •roguelike.point(
        35,
        12
      ),
      ([]:[µPickup]),
      0
    ),
    •roguelike.point(
      1,
      1
    )
  ){
    None()=>true|
    Some(_)=>false
  }
}

test "collectPickup updates inventory and score" {
