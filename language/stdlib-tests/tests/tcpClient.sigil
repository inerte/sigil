i stdlib::tcpClient

i stdlib::topology

λmain()=>Unit=()

test "tcp client request record preserves dependency and message" {
  l request=({dependency:stdlib::topology.TcpServiceDependency("eventStream"),message:"ping"}:stdlib::tcpClient.TcpRequest);
  request.dependency=stdlib::topology.TcpServiceDependency("eventStream") and request.message="ping"
}
