test "breadth first search is deterministic" {
  srcâ‹…breadthFirstSearch.breadthFirstSearch(dagGraph(),1)=[1,2,3,4]
}

test "missing start vertex returns empty traversal" {
  srcâ‹…depthFirstSearch.depthFirstSearch(dagGraph(),99)=[] and srcâ‹…breadthFirstSearch.breadthFirstSearch(dagGraph(),99)=[]
}

test "topological sort returns ordering for dag" {
  l result=(srcâ‹…topologicalSort.topologicalSort(dagGraph()):srcâ‹…graphTypes.TopologicalSortResult);
  match result{
