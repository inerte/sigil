i src::formula

i stdlib::string

λmain()=>Unit=()

λsampleChecksums()=>String=stdlib::string.unlines(["aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa  sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz","bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb  sigil-2026-03-11T14-58-24Z-darwin-x64.tar.gz","cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc  sigil-2026-03-11T14-58-24Z-linux-arm64.tar.gz","dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd  sigil-2026-03-11T14-58-24Z-linux-x64.tar.gz"])

test "archive name uses release naming convention" {
  src::formula.archiveName("darwin-arm64","2026-03-11T14-58-24Z")="sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz"
}

test "archive url points at GitHub release assets" {
  src::formula.archiveUrl("darwin-arm64","inerte/sigil","2026-03-11T14-58-24Z")="https://github.com/inerte/sigil/releases/download/2026-03-11T14-58-24Z/sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz"
}

test "formula renders release version and platform checksums" {
  l text=src::formula.formula({checksums:{darwinArm64:"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",darwinX64:"bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",linuxArm64:"cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",linuxX64:"dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"},repo:"inerte/sigil",version:"2026-03-11T14-58-24Z"});
  stdlib::string.indexOf(text,"sha256 \"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\"")≥0 and stdlib::string.indexOf(text,"sigil 2026-03-11T14-58-24Z")≥0 and stdlib::string.indexOf(text,"https://github.com/inerte/sigil/releases/download/2026-03-11T14-58-24Z/sigil-2026-03-11T14-58-24Z-linux-x64.tar.gz")≥0
}

test "parse checksums extracts all release digests" {
  match src::formula.parseChecksums(sampleChecksums(),"2026-03-11T14-58-24Z"){
    Some(checksums)=>checksums.darwinArm64="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" and checksums.darwinX64="bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb" and checksums.linuxArm64="cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc" and checksums.linuxX64="dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"|
    None()=>false
  }
}
