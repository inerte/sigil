  } and match stdlibâ‹…list.find(stdlibâ‹…numeric.isEven,[1,3,5]){
    None()â†’true|
    _â†’false
  }
}

test "list.fold reduces left to right" {
  stdlibâ‹…list.fold(0,appendDigit,[1,2,3])=123 and stdlibâ‹…list.fold(9,appendDigit,[])=9
}

test "list.last returns option" {
  match stdlibâ‹…list.last([]){
    None()â†’true|
    _â†’false
  } and match stdlibâ‹…list.last([9]){
