      path:"language/spec/stdlib-spec.md"
    }],
    •docsDrift.snippetRefsForValidatedSnippet(snippet(
      "§string.trim(\" hi \")",
      "docs/test.md",
      fenceInfo(
        None(),
        "expr"
      ),
      1
    ))=["§string.trim"],
    •docsDrift.snippetRefsForValidatedSnippet(snippet(
      "§string.trim(\" hi \") ⟦ ignore §string.split ⟧",
      "docs/test.md",
      fenceInfo(
        None(),
