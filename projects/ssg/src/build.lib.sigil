Î»assetOutputDir(config:srcâ‹…types.SiteBuildConfig)â†’String=stdlibâ‹…path.join(config.outputDir,"assets")

Î»buildSite(config:srcâ‹…types.SiteBuildConfig)â†’!IO Unit=
  l _=(prepareOutputDir(config.outputDir):Unit);
  l rawData=(loadSiteData(config):srcâ‹…types.SiteData);
  l aliasRoutes=(srcâ‹…content.buildAliasRoutes(rawData):[srcâ‹…types.AliasRoute]);
  l data=(renderSiteData(aliasRoutes,config.basePath,rawData):srcâ‹…types.SiteData);
  l _=(copyStaticAssets(assetOutputDir(config)):Unit);
  l _=(writePage(config,srcâ‹…templates.homePage(data.articles,config,data.docs,data.home,data.spec),data.home):Unit);
  l _=(writeStandalonePages(aliasRoutes,config):Unit);
  l _=(writePage(config,srcâ‹…templates.articlesIndex(config,data.articlesIntro.bodyHtml,data.articles),data.articlesIntro):Unit);
  l _=(writeArticlePages(config,data.articles):Unit);
  l _=(writeIndexHtml(stdlibâ‹…path.join(config.outputDir,"docs"),srcâ‹…templates.docsIndex(config,data.docs)):Unit);
  l _=(writePages(config,data.docs):Unit);
  l _=(writeIndexHtml(stdlibâ‹…path.join(config.outputDir,"spec"),srcâ‹…templates.specIndex(config,data.spec)):Unit);
  l _=(writePages(config,data.spec):Unit);
  l _=(writeSiteManifest(config,data):Unit);
  writeNotFound(config)

Î»buildSiteManifestJson(data:srcâ‹…types.SiteData,generatedAt:String,repoUrl:String)â†’stdlibâ‹…json.JsonValue=
  stdlibâ‹…json.JsonObject({
    "articlesCount"â†¦stdlibâ‹…json.JsonString(stdlibâ‹…string.intToString(#data.articles)),
