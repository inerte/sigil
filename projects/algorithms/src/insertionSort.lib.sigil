mode total

λinsertSorted(item:Int,xs:[Int])=>[Int]
decreases #xs
match xs{
  []=>[item]|
  [
  head,
  .tail
]=>match item≤head{
    true=>[
      item,
      head
    ]⧺tail|
    false=>[head]⧺insertSorted(
      item,
      tail
    )
  }
}

λinsertionSort(xs:[Int])=>[Int]
decreases #xs
match xs{
  []=>[]|
  [
  head,
  .tail
]=>insertSorted(
    head,
    insertionSort(tail)
  )
}
