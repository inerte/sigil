t Hub[T]=StreamHub(Int)

t Next[T]=Done()|Item(T)

t Source[T]=StreamSource(Int)

λclose[T](source:Source[T])=>!Stream Unit=()

λhub[T]()=>!Stream Owned[Hub[T]]=(StreamHub(0):Owned[Hub[T]])

λnext[T](source:Source[T])=>!Stream Next[T]=Done()

λpublish[T](hub:Hub[T],value:T)=>!Stream Unit=()

λsubscribe[T](hub:Hub[T])=>!Stream Owned[Source[T]]=(StreamSource(0):Owned[Source[T]])
