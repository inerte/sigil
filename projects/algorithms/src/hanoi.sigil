total λhanoi(aux:String,from:String,n:Int,to:String)=>String
requires 0<n
decreases n
match n{
  1=>"Move disk from "+from+" to "+to+"
"|
  count=>hanoi(
    to,
    from,
    count+-1,
    aux
  )+"Move disk from "+from+" to "+to+"
"+hanoi(
    from,
    aux,
    count+-1,
    to
  )
}

λmain()=>String=hanoi(
  "B",
  "A",
  3,
  "C"
)
