mode total

Î»firstRun(runs:[[Int]])=>[Int] match runs{
  []=>[]|
  [
  head,
  .tail
]=>match tail{
    []=>head|
    _=>head
  }
}

Î»merge(left:[Int],right:[Int])=>[Int]
requires 0â‰¤#left and 0â‰¤#right
decreases (#left, #right)
match left{
  []=>right|
  [
  leftHead,
  .leftTail
]=>match right{
    []=>left|
    [
  rightHead,
  .rightTail
]=>match leftHeadâ‰¤rightHead{
      true=>[leftHead]â§ºmerge(
        leftTail,
        right
      )|
      _=>[rightHead]â§ºmerge(
        left,
        rightTail
      )
    }
  }
}

Î»mergeAllRuns(runs:[[Int]])=>[Int]=mergeAllRunsCount(
  #runs,
  runs
)

Î»mergeAllRunsCount(runCount:Int,runs:[[Int]])=>[Int] match runCountâ‰¤1{
  true=>firstRun(runs)|
  false=>mergeAllRunsCountInner(
    runCount,
    runCount,
    runs
  )
}

Î»mergeAllRunsCountInner(fuel:Int,runCount:Int,runs:[[Int]])=>[Int]
requires fuelâ‰¥0
decreases fuel
match fuel=0{
  true=>firstRun(runs)|
  false=>match runCountâ‰¤1{
    true=>firstRun(runs)|
    false=>mergeAllRunsCountInner(
      fuel-1,
      nextRunCount(runCount),
      mergePairs(runs)
    )
  }
}

Î»mergePairs(runs:[[Int]])=>[[Int]]=mergePairsInner(
  #runs,
  runs
)

Î»mergePairsInner(fuel:Int,runs:[[Int]])=>[[Int]]
requires fuelâ‰¥0
decreases fuel
match fuel=0{
  true=>[]|
  false=>match runs{
    []=>[]|
    [
  head,
  .tail
]=>match tail{
      []=>wrapRun(head)|
      [
  right,
  .rest
]=>wrapRun(merge(
        head,
        right
      ))â§ºmergePairsInner(
        fuel-1,
        rest
      )
    }
  }
}

Î»mergeSort(xs:[Int])=>[Int]=mergeAllRuns(singletons(xs))

Î»nextRunCount(runCount:Int)=>Int
requires 0â‰¤runCount
decreases runCount
ensures resultâ‰¥0
match runCount{
  0=>0|
  1=>1|
  _=>1+nextRunCount(runCount+-2)
}

Î»singletons(xs:[Int])=>[[Int]]=xs map (Î»(head:Int)=>[Int]=[head])

Î»wrapAll(partials:[[Int]],values:[Int])=>[[Int]]
requires #valuesâ‰¥0
decreases #values
match values{
  []=>partials|
  [
  head,
  .tail
]=>wrapAll(
    wrapHead(
      head,
      partials
    ),
    tail
  )
}

Î»wrapHead(head:Int,partials:[[Int]])=>[[Int]]
requires #partialsâ‰¥0
decreases #partials
match partials{
  []=>[]|
  [
  partial,
  .tail
]=>[partialâ§º[head]]â§ºwrapHead(
    head,
    tail
  )
}

Î»wrapRun(run:[Int])=>[[Int]]=wrapAll(
  [[]],
  run
)
