e console

λadd(a:Int,b:Int)=>Int=a+b

λcomputeSum(a:Int,b:Int)=>Int=add(a,b)

λdouble(x:Int)=>Int=x*2

λfetchData()=>!Network String="network-data"

λlog(msg:String)=>!IO Unit=console.log(msg)

λlogDoubled(x:Int)=>!IO Unit=logValue(double(x))

λlogValue(x:Int)=>!IO Unit=console.log(x)

λmain()=>!IO!Network Unit=processAndLog()

λprocessAndLog()=>!IO!Network Unit=log(fetchData())
