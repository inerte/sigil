test "list.count counts duplicates" {
  stdlibâ‹…list.count(3,[3,1,3,2,3])=3 and stdlibâ‹…list.count(9,[])=0 and stdlibâ‹…list.count(7,[1,2,3])=0
}

test "list.drop clamps naturally" {
  stdlibâ‹…list.drop(0,[1,2,3])=[1,2,3] and stdlibâ‹…list.drop(2,[1,2,3,4])=[3,4] and stdlibâ‹…list.drop(10,[1,2])=[] and stdlibâ‹…list.drop(-1,[1,2])=[1,2]
}

test "list.find returns first matching option" {
  match stdlibâ‹…list.find(stdlibâ‹…numeric.isEven,[1,3,4,6]){
    Some(actual)â†’actual=4|
