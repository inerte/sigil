test "moving onto the exit preserves escaped outcome" {
  match •roguelike.advance(
    µMove(µEast()),
    •roguelike.demoState(
      [•roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          34,
          12
        )
      )],
      •roguelike.point(
        35,
        12
      ),
      ([]:[µPickup]),
      0
    )
  ){
    Some(step)=>match step.outcome{
      Some(µEscaped(turn))=>turn=1 and (step.state.turn:Int)=1|
      Some(_)=>false|
      None()=>false
    }|
    None()=>false
  }
}

test "path and movement helpers execute reachable routes" {
  l state=(•roguelike.demoStateWithInventory(
    [•roguelike.playerActor(
      5,
      1,
      •roguelike.point(
        4,
        4
      )
    )],
    0,
    0,
    •roguelike.point(
      35,
      12
    ),
    ([]:[µPickup]),
    0
  ):µGameState);
  l step0=(•roguelike.point(
    5,
    4
  ):µPoint);
  l initial=(•roguelike.initialNodes(
    1,
    false,
    •roguelike.neighbors(•roguelike.point(
      4,
      4
    )),
    •roguelike.point(
      4,
      4
    ),
    state,
    •roguelike.point(
      8,
      4
    )
  ):[µPathNode]);
  #•roguelike.appendNodes(
    ([]:[µPathNode]),
    {
      distance:1,
      first:step0,
      pos:step0
    },
    ([]:[µPathNode])
  )=1
    and #initial>0
    and #•roguelike.expandNodes(
      1,
      false,
      {
        distance:1,
        first:step0,
        pos:step0
      },
      ([]:[µPathNode]),
      state,
      •roguelike.point(
        8,
        4
      ),
      [•roguelike.point(
        4,
        4
      )]
    )>0
    and •roguelike.nodePosIn(
      initial,
      step0
    )
    and (match •roguelike.bestStepToward(
      1,
      false,
      •roguelike.point(
        4,
        4
      ),
      state,
      •roguelike.point(
        8,
        4
      )
    ){
      Some(best)=>match •roguelike.nextStepToward(
        1,
        false,
        •roguelike.point(
          4,
          4
        ),
        state,
        •roguelike.point(
          8,
          4
        )
      ){
        Some(next)=>match •roguelike.searchQueue(
          1,
          false,
          initial,
          state,
          •roguelike.point(
            8,
            4
          ),
          [•roguelike.point(
            4,
            4
          )]
        ){
          Some(node)=>match •roguelike.pathDistance(
            1,
            false,
            •roguelike.point(
              4,
              4
            ),
            state,
            •roguelike.point(
              8,
              4
            )
          ){
            Some(distance)=>match •roguelike.player(•roguelike.moveActor(
              1,
              step0,
              state
            )){
              Some(actor)=>•roguelike.samePoint(
                best,
                next
              )
                and node.distance>0
                and distance>0
                and •roguelike.samePoint(
                  actor.pos,
                  step0
                )
                and (match •roguelike.player(•roguelike.moveToward(
                  1,
                  false,
                  •roguelike.point(
                    4,
                    4
                  ),
                  state,
                  •roguelike.point(
                    8,
                    4
                  )
                )){
                  Some(afterToward)=>•roguelike.samePoint(
                    afterToward.pos,
                    step0
                  ) and (•roguelike.movePlayerToward(
                    1,
                    •roguelike.point(
                      4,
                      4
                    ),
                    •roguelike.withPickups(
                      [•roguelike.potionPickup(step0)],
                      state
                    ),
                    step0
                  ).loadout.potions:Int)=1|
                  None()=>false
                })|
              None()=>false
            }|
            None()=>false
          }|
          None()=>false
        }|
        None()=>false
      }|
      None()=>false
    })
}

test "classification and pickup helpers execute" {
  l goblin=(•roguelike.goblinActor(
    2,
    2,
    •roguelike.point(
      5,
      4
    )
  ):µActor);
  l archer=(•roguelike.archerActor(
    2,
    3,
    •roguelike.point(
      8,
      4
    )
  ):µActor);
  l brute=(•roguelike.bruteActor(
    4,
    4,
    •roguelike.point(
      10,
      4
    )
  ):µActor);
  l shaman=(•roguelike.shamanActor(
    2,
    5,
    •roguelike.point(
      12,
      4
    )
  ):µActor);
  l state=(•roguelike.demoStateWithInventory(
    [
      •roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          4,
          4
        )
      ),
      goblin,
      archer,
      brute,
      shaman
    ],
    0,
    0,
    •roguelike.point(
      35,
      12
    ),
    [
      •roguelike.potionPickup(•roguelike.point(
        6,
        4
      )),
      •roguelike.bombPickup(•roguelike.point(
        7,
        4
      )),
      •roguelike.blinkPickup(•roguelike.point(
        8,
        5
      )),
      •roguelike.spearPickup(•roguelike.point(
        9,
        5
      )),
      •roguelike.treasurePickup(•roguelike.point(
        10,
        5
      ))
    ],
    0
  ):µGameState);
  match •roguelike.actorAtExcept(
    1,
    •roguelike.point(
      5,
      4
    ),
    state
  ){
    Some(other)=>match •roguelike.adjacentGoblin(
      •roguelike.point(
        4,
        4
      ),
      •roguelike.withActors(
        [
          •roguelike.playerActor(
            5,
            1,
            •roguelike.point(
              4,
              4
            )
          ),
          •roguelike.goblinActor(
            2,
            2,
            •roguelike.point(
              4,
              5
            )
          )
        ],
        state
      )
    ){
      Some(target)=>other.id=2
        and target.id=2
        and #•roguelike.goblinIds(state.actors)=1
        and •roguelike.livingGoblinCount(state.actors)=1
        and •roguelike.isArcher(archer)
        and •roguelike.isBrute(brute)
        and •roguelike.isGoblin(goblin)
        and •roguelike.isShaman(shaman)
        and •roguelike.isPickupPotion(•roguelike.potionPickup(•roguelike.point(
          0,
          0
        )))
        and •roguelike.isPickupBomb(•roguelike.bombPickup(•roguelike.point(
          0,
          0
        )))
        and •roguelike.isPickupBlink(•roguelike.blinkPickup(•roguelike.point(
          0,
          0
        )))
        and •roguelike.isPickupSpear(•roguelike.spearPickup(•roguelike.point(
          0,
          0
        )))
        and •roguelike.isPickupTreasure(•roguelike.treasurePickup(•roguelike.point(
          0,
          0
        )))|
      None()=>false
    }|
    None()=>false
  }
}

test "pickup target helpers observe some variants" {
  l player=(•roguelike.playerActor(
    5,
    1,
    •roguelike.point(
      4,
      4
    )
  ):µActor);
  l state=(•roguelike.demoState(
    [player],
    •roguelike.point(
      35,
      12
    ),
    [
      •roguelike.potionPickup(•roguelike.point(
        6,
        4
      )),
      •roguelike.bombPickup(•roguelike.point(
        7,
        4
      )),
      •roguelike.blinkPickup(•roguelike.point(
        8,
        4
      )),
      •roguelike.spearPickup(•roguelike.point(
        9,
        4
      )),
      •roguelike.treasurePickup(•roguelike.point(
        6,
        6
      ))
    ],
    0
  ):µGameState);
  l noneState=(•roguelike.demoState(
    [player],
    •roguelike.point(
      35,
      12
    ),
    [•roguelike.bombPickup(•roguelike.point(
      7,
      4
    ))],
    0
  ):µGameState);
  match •roguelike.nearestPotionPickup(
    player,
    state
  ){
    Some(potion)=>match •roguelike.nearestPotionTarget(
      1,
      player.pos,
      state
    ){
      Some(target)=>match •roguelike.nearestBlinkPickup(
        player,
        state
      ){
        Some(blink)=>match •roguelike.nearestBombPickup(
          player,
          state
        ){
          Some(bomb)=>match •roguelike.nearestSpearPickup(
            player,
            state
          ){
            Some(spear)=>match •roguelike.nearestTreasureTarget(
              1,
              player.pos,
              state
            ){
              Some(treasure)=>match •roguelike.nearestPotionPickup(
                player,
                noneState
              ){
                None()=>match •roguelike.nearestPotionTarget(
                  1,
                  player.pos,
                  noneState
                ){
                  None()=>•roguelike.samePoint(
                    potion,
                    •roguelike.point(
                      6,
                      4
                    )
                  )
                    and •roguelike.samePoint(
                      target.pos,
                      •roguelike.point(
                        6,
                        4
                      )
                    )
                    and •roguelike.samePoint(
                      blink,
                      •roguelike.point(
                        8,
                        4
                      )
                    )
                    and •roguelike.samePoint(
                      bomb,
                      •roguelike.point(
                        7,
                        4
                      )
                    )
                    and •roguelike.samePoint(
                      spear,
                      •roguelike.point(
                        9,
                        4
                      )
                    )
                    and •roguelike.samePoint(
                      treasure.pos,
                      •roguelike.point(
                        6,
                        6
                      )
                    )|
                  Some(_)=>false
                }|
                Some(_)=>false
              }|
              None()=>false
            }|
            None()=>false
          }|
          None()=>false
        }|
        None()=>false
      }|
      None()=>false
    }|
    None()=>false
  }
}

test "none variants and retreat helpers execute" {
  l emptyState=(•roguelike.demoState(
    [•roguelike.playerActor(
      5,
      1,
      •roguelike.point(
        0,
        0
      )
    )],
    •roguelike.point(
      35,
      12
    ),
    ([]:[µPickup]),
    0
  ):µGameState);
  match •roguelike.findPlayer(([]:[µActor])){
    None()=>match •roguelike.player(•roguelike.withActors(
      ([]:[µActor]),
      emptyState
    )){
      None()=>match •roguelike.nextStepToward(
        1,
        false,
        •roguelike.point(
          0,
          0
        ),
        emptyState,
        •roguelike.point(
          0,
          0
        )
      ){
        None()=>match •roguelike.pathDistance(
          1,
          false,
          •roguelike.point(
            0,
            0
          ),
          emptyState,
          •roguelike.point(
            1,
            1
          )
        ){
          None()=>match •roguelike.searchQueue(
            1,
            false,
            ([]:[µPathNode]),
            emptyState,
            •roguelike.point(
              1,
              1
            ),
            [•roguelike.point(
              0,
              0
            )]
          ){
            None()=>match •roguelike.teleportSafe(
              •roguelike.playerActor(
                5,
                1,
                •roguelike.point(
                  4,
                  4
                )
              ),
              [
                •roguelike.point(
                  4,
                  4
                ),
                •roguelike.point(
                  5,
                  4
                )
              ],
              •roguelike.demoState(
                [
                  •roguelike.playerActor(
                    5,
                    1,
                    •roguelike.point(
                      4,
                      4
                    )
                  ),
                  •roguelike.goblinActor(
                    2,
                    2,
                    •roguelike.point(
                      5,
                      4
                    )
                  )
                ],
                •roguelike.point(
                  35,
                  12
                ),
                ([]:[µPickup]),
                0
              )
            ){
              None()=>match •roguelike.stepEnemyRetreat(
                2,
                •roguelike.point(
                  4,
                  4
                ),
                •roguelike.demoState(
                  [
                    •roguelike.playerActor(
                      5,
                      1,
                      •roguelike.point(
                        5,
                        4
                      )
                    ),
                    •roguelike.archerActor(
                      2,
                      2,
                      •roguelike.point(
                        4,
                        4
                      )
                    )
                  ],
                  •roguelike.point(
                    35,
                    12
                  ),
                  ([]:[µPickup]),
                  0
                ),
                •roguelike.point(
                  5,
                  4
                )
              ){
                Some(next)=>•roguelike.outcomeText(µEscaped(3))="Escaped on turn 3"
                  and •roguelike.shootClearColumn(
                    1,
                    •roguelike.demoState(
                      [•roguelike.playerActor(
                        5,
                        1,
                        •roguelike.point(
                          4,
                          4
                        )
                      )],
                      •roguelike.point(
                        35,
                        12
                      ),
                      ([]:[µPickup]),
                      0
                    ),
                    4,
                    5,
                    7
                  )
                  and •roguelike.samePoint(
                    next,
                    •roguelike.point(
                      4,
                      3
                    )
                  )|
                None()=>false
              }|
              Some(_)=>false
            }|
            Some(_)=>false
          }|
          Some(_)=>false
        }|
        Some(_)=>false
      }|
      Some(_)=>false
    }|
    Some(_)=>false
  }
}

