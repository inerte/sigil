test "move command walks onto pickups" {
  match •roguelike.advance(
    µMove(µEast()),
    •roguelike.demoStateWithInventory(
      [•roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          4,
          4
        )
      )],
      0,
      0,
      •roguelike.point(
        35,
        12
      ),
      [•roguelike.potionPickup(•roguelike.point(
        5,
        4
      ))],
      0
    )
  ){
    Some(step)=>(step.state.loadout.potions:Int)=1
      and step.state.lastAction="move"
      and (match •roguelike.player(step.state){
        Some(actor)=>•roguelike.samePoint(
          actor.pos,
          •roguelike.point(
            5,
            4
          )
        )|
        None()=>false
      })|
    None()=>false
  }
}

