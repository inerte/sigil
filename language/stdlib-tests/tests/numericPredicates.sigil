λmain()=>Unit=()

test "numeric.inRange is inclusive" {
  §numeric.inRange(
    3,
    1,
    3
  )=true and §numeric.inRange(
    3,
    1,
    4
  )=false
}

test "numeric.isEven and isOdd basics" {
  §numeric.isEven(4)=true and §numeric.isOdd(5)=true
}

test "numeric.isPositive and isNegative basics" {
  §numeric.isPositive(5)=true and §numeric.isNegative(-1)=true
}
