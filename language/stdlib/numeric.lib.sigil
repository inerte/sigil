mode total

t DivMod={
  quotient:Int,
  remainder:Int
}

Î»abs(x:Int)=>Int match x<0{
  true=>-x|
  false=>x
}

Î»clamp(hi:Int,lo:Int,x:Int)=>Int=max(
  lo,
  min(
    x,
    hi
  )
)

Î»divisible(d:Int,n:Int)=>Bool=n%d=0

Î»divmod(a:Int,b:Int)=>DivMod={
  quotient:(a-(mod(
    a,
    b
  ):Int))/b,
  remainder:(mod(
    a,
    b
  ):Int)
}

Î»gcd(a:Int,b:Int)=>Int
requires bâ‰¥0
=gcdLoop(
  a,
  b,
  100000
)

Î»gcdLoop(a:Int,b:Int,fuel:Int)=>Int
decreases fuel
match fuel=0{
  true=>0|
  false=>match b{
    0=>a|
    divisor=>gcdLoop(
      divisor,
      a%divisor,
      fuel+-1
    )
  }
}

Î»inRange(max:Int,min:Int,x:Int)=>Bool=inRangeHelper(
  max,
  min,
  x
)

Î»inRangeHelper(max:Int,min:Int,x:Int)=>Bool match xâ‰¥min{
  true=>xâ‰¤max|
  false=>false
}

Î»isEven(x:Int)=>Bool=x%2=0

Î»isNegative(x:Int)=>Bool=x<0

Î»isNonNegative(x:Int)=>Bool=xâ‰¥0

Î»isOdd(x:Int)=>Bool=Â¬isEven(x)

Î»isPositive(x:Int)=>Bool=x>0

Î»isPrime(n:Int)=>Bool
requires nâ‰¥0
match n{
  0=>false|
  1=>false|
  value=>isPrimeHelper(
    2,
    value
  )
}

Î»isPrimeHelper(divisor:Int,n:Int)=>Bool
requires 2â‰¤divisor and divisorâ‰¤n
decreases n+-divisor
match divisor*divisor>n{
  true=>true|
  false=>match n%divisorâ‰ 0{
    true=>isPrimeHelper(
      divisor+1,
      n
    )|
    false=>false
  }
}

Î»lcm(a:Int,b:Int)=>Int match a=0 or b=0{
  true=>0|
  false=>abs(a/(abs(gcd(
    a,
    b
  )):Int)*b)
}

Î»max(a:Int,b:Int)=>Int match a>b{
  true=>a|
  false=>b
}

Î»min(a:Int,b:Int)=>Int match a<b{
  true=>a|
  false=>b
}

Î»mod(a:Int,b:Int)=>Int match (a%b:Int)<0{
  true=>(a%b:Int)+abs(b)|
  false=>(a%b:Int)
}

Î»pow(base:Int,exp:Int)=>Int
requires expâ‰¥0
decreases exp
match exp{
  0=>1|
  remainingExp=>base*pow(
    base,
    remainingExp-1
  )
}

Î»range(start:Int,stop:Int)=>[Int] match start>stop{
  true=>[]|
  false=>rangeAsc(
    start,
    stop
  )
}

Î»rangeAsc(start:Int,stop:Int)=>[Int]
requires startâ‰¤stop
decreases stop-start
match start=stop{
  true=>[start]|
  false=>[start]â§ºrangeAsc(
    start+1,
    stop
  )
}

Î»sign(x:Int)=>Int match x<0{
  true=>-1|
  false=>match x=0{
    true=>0|
    false=>1
  }
}
