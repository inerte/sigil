          ),
          •roguelike.goblinActor(
            2,
            2,
            •roguelike.point(
              6,
              4
            )
          ),
          •roguelike.archerActor(
            2,
            3,
            •roguelike.point(
              7,
              4
            )
          )
        ],
        •roguelike.point(
          35,
          12
        ),
        ([]:[µPickup]),
        0
      )
    )
  ){
    Some(step)=>step.state.lastAction="throw bomb"
      and (step.state.loadout.bombs:Int)=0
      and (match •roguelike.findActorById(
