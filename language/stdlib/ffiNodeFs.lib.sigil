t MkdirOptions={recursive:Bool}

t RmOptions={force:Bool,recursive:Bool}

e fs:{existsSync:λ(String)=>Bool}

e fs::promises:{access:λ(String)=>Unit,appendFile:λ(String,String,String)=>Unit,mkdtemp:λ(String)=>String,mkdir:λ(String,MkdirOptions)=>Unit,readFile:λ(String,String)=>String,readdir:λ(String)=>[String],rm:λ(String,RmOptions)=>Unit,unlink:λ(String)=>Unit,writeFile:λ(String,String,String)=>Unit}
