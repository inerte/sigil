test "bomb and teleport helpers execute" {
  l player=(•roguelike.playerActor(
    5,
    1,
    •roguelike.point(
      4,
      4
    )
  ):µActor);
  l bombState=(•roguelike.withLoadout(
    •roguelike.loadoutWithBombs(
      1,
      •roguelike.defaultLoadout()
    ),
    •roguelike.demoState(
      [
        player,
        •roguelike.goblinActor(
          2,
          2,
          •roguelike.point(
            6,
            4
          )
        ),
        •roguelike.archerActor(
          2,
          3,
          •roguelike.point(
            7,
            4
          )
        )
      ],
      •roguelike.point(
        35,
        12
      ),
      ([]:[µPickup]),
      0
    )
  ):µGameState);
  l blinkFloors=([•roguelike.point(
    4,
    4
  )]:[µPoint]);
  l blinkActors=([player]:[µActor]);
  match •roguelike.targetBombInDirection(
    player,
    µEast(),
    bombState
  ){
    Some(target)=>match •roguelike.targetBombInDirection(
      player,
      µWest(),
      bombState
    ){
      None()=>match •roguelike.targetRangedInDirection(
        player,
        µWest(),
        bombState
      ){
        None()=>match •roguelike.targetBlinkInDirection(
          player,
          µEast(),
          ({
            actorIndex:•roguelike.actorIndexFor(blinkActors),
            actors:blinkActors,
            collectedTreasure:0,
            exit:•roguelike.point(
              35,
              12
            ),
            floorIndex:•roguelike.floorIndexFor(blinkFloors),
            floors:blinkFloors,
            lastAction:"ready",
            loadout:•roguelike.loadoutWithBlinks(
              1,
              •roguelike.defaultLoadout()
            ),
            pickupIndex:•roguelike.pickupIndexFor(([]:[µPickup])),
            pickups:([]:[µPickup]),
            rooms:[{
              h:1,
              w:1,
              x:4,
              y:4
            }],
            turn:0
          }:µGameState)
        ){
          None()=>match •roguelike.teleportSafe(
            player,
            [
              •roguelike.point(
                4,
                4
              ),
              •roguelike.point(
                5,
                4
              ),
              •roguelike.point(
                7,
                7
              )
            ],
            •roguelike.demoState(
              [
                player,
                •roguelike.goblinActor(
                  2,
                  2,
                  •roguelike.point(
                    5,
                    4
                  )
                )
              ],
              •roguelike.point(
                35,
                12
              ),
              ([]:[µPickup]),
              0
            )
          ){
            Some(safe)=>•roguelike.bombTarget(
              player,
              bombState,
              target
            )
              and •roguelike.throwBombEnemyCount(
                bombState.actors,
                target.pos
              )=2
              and •roguelike.samePoint(
                safe,
                •roguelike.point(
                  7,
                  7
                )
              )
              and ¬•roguelike.teleportThreatened(
                player,
                bombState
              )|
            None()=>false
          }|
          Some(_)=>false
        }|
        Some(_)=>false
      }|
      Some(_)=>false
    }|
    None()=>false
  }
}

test "enemy specialty helpers execute" {
  l bruteState=(•roguelike.demoState(
    [
      •roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          6,
          4
        )
      ),
      •roguelike.bruteActor(
        4,
        2,
        •roguelike.point(
          4,
          4
        )
      )
    ],
    •roguelike.point(
      35,
      12
    ),
    ([]:[µPickup]),
    0
  ):µGameState);
  l shamanState=(•roguelike.demoState(
    [
      •roguelike.playerActor(
        5,
        1,
        •roguelike.point(
          10,
          10
        )
      ),
      •roguelike.shamanActor(
        2,
        5,
        •roguelike.point(
          12,
          10
        )
      ),
      •roguelike.goblinActor(
