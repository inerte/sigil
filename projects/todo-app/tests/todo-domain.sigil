test "todo edit updates text" {
  srcв‹…todo-domain.editTodo("New",1,[Todo{id:1,text:"Old",done:false}])[0].text="New"
}

test "todo toggle flips done flag" {
  srcв‹…todo-domain.toggleTodo(1,[Todo{id:1,text:"Task",done:false}])[0].done=true
