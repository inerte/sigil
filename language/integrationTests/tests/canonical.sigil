test "wrapper with extra logic still compiles" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("canonicalWrapperLike"):String);
  l file=(§path.join(
    root,
    "goodWrapper.lib.sigil"
  ):String);
  l _=(§file.writeText(
    wrapperPlusLogicSource(),
    file
  ):Unit);
  l result=(compile(file):§process.ProcessResult);
  l _=(§file.removeTree(root):Unit);
  result.code=0
}

