t Hub[T]=StreamHub(Int)

t Next[T]=Done()|Item(T)

t Source[T]=StreamSource(Int)

e stdlibStream

λclose[T](source:Source[T])=>!Stream Unit=stdlibStream.close(source)

λhub[T]()=>!Stream Owned[Hub[T]]=stdlibStream.hub()

λnext[T](source:Source[T])=>!Stream Next[T]=stdlibStream.next(source)

λpublish[T](hub:Hub[T],value:T)=>!Stream Unit=stdlibStream.publish(
  hub,
  value
)

λsubscribe[T](hub:Hub[T])=>!Stream Owned[Source[T]]=stdlibStream.subscribe(hub)
