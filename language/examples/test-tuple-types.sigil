t Headers=[(рқ•Ҡ,рқ•Ҡ)]
t Nested=((в„Ө,рқ•Ҡ),рқ”№)
t Pair=(в„Ө,рқ•Ҡ)
t Triple=(в„Ө,рқ•Ҡ,рқ”№)

О»first(pair:(в„Ө,рқ•Ҡ))вҶ’в„ӨвүЎpair{(x,y)вҶ’x}

О»main()вҶ’Pair=(42,"hello")

О»swap(pair:(в„Ө,рқ•Ҡ))вҶ’(рқ•Ҡ,в„Ө)вүЎpair{(a,b)вҶ’(b,a)}

О»test()вҶ’Triple=(1,"world",вҠӨ)

О»testHeaders()вҶ’Headers=[("Content-Type","application/json"),("Accept","text/html")]

О»testNested()вҶ’Nested=((7,"test"),вҠҘ)
