i stdlibג‹…numeric

־»filterMultiples(prime:ג„₪,xs:[ג„₪])ג†’[ג„₪] match xs{
  []ג†’[]|
  [head,.tail]ג†’match head%prime=0{
    trueג†’filterMultiples(prime,tail)|
    falseג†’[head]ג§÷filterMultiples(prime,tail)
  }
}

־»sieve(limit:ג„₪)ג†’[ג„₪] match limit<2{
  trueג†’[]|
  falseג†’sieveCandidates(stdlibג‹…numeric.range(2,limit))
}

־»sieveCandidates(candidates:[ג„₪])ג†’[ג„₪] match candidates{
  []ג†’[]|
  [head,.tail]ג†’[head]ג§÷sieveCandidates(filterMultiples(head,tail))
}
