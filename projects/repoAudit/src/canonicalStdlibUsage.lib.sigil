  },
  {
    name:"join",
    pattern:"^λjoin\\(([a-z][A-Za-z0-9]*):String,[a-z][A-Za-z0-9]*:\\[String\\]\\)=>String(?==| match)",
    replacement:"§string.join"
  },
  {
    name:"last",
    pattern:"^λlast\\[([A-Z][A-Za-z0-9]*)\\]\\([a-z][A-Za-z0-9]*:\\[\\1\\]\\)=>Option\\[\\1\\](?==| match)",
    replacement:"§list.last"
  },
