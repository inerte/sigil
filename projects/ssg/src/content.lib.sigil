Î»rewriteInternalLinks(aliasRoutes:[srcâ‹…types.AliasRoute],basePath:String,markdown:String,sourcePath:String)â†’String=
  l openIdx=(stdlibâ‹…string.indexOf(markdown,"]("):Int);
  match openIdx<0{
    trueâ†’markdown|
    falseâ†’
      l afterOpen=(stdlibâ‹…string.substring(#markdown,markdown,openIdx+2):String);
      l closeIdx=(findLinkClose(afterOpen):Int);
      match closeIdx<0{
        trueâ†’markdown|
        falseâ†’
          stdlibâ‹…string.substring(openIdx+2,markdown,0)
          ++rewriteLinkTarget(aliasRoutes,basePath,sourcePath,stdlibâ‹…string.substring(closeIdx,afterOpen,0))
          ++")"
          ++rewriteInternalLinks(aliasRoutes,basePath,stdlibâ‹…string.substring(#afterOpen,afterOpen,closeIdx+1),sourcePath)
      }
  }

Î»rewriteLinkTarget(aliasRoutes:[srcâ‹…types.AliasRoute],basePath:String,sourcePath:String,target:String)â†’String match stdlibâ‹…url.parse(target){
  Err(_)â†’target|
