Î»listDir(path:String)â†’!IO [String]=stdlibâ‹…file.listDir(path)

Î»loadArticles(config:srcâ‹…types.SiteBuildConfig)â†’!IO [srcâ‹…types.SitePage]=
  l files=(filterMarkdownFiles(stdlibâ‹…file.listDir("website/articles")):[String]);
