t Block=Header(â„¤,đť•Š)
       |Paragraph(đť•Š)
       |CodeBlock(đť•Š,đť•Š)
       |UnorderedList([đť•Š])
       |OrderedList([đť•Š])
       |Blockquote(đť•Š)
       |HorizontalRule

âź¦ Parser State âź§
t ParserState={
  code_lang:đť•Š,
  code_lines:[đť•Š],
  in_code_block:đť”ą,
  in_list:đť”ą,
  list_items:[đť•Š],
  list_type:đť•Š,
