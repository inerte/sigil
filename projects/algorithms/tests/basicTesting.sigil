i stdlib::numeric

λmain()=>Unit=()

λping()=>String="real"

test "any function can be overridden in tests" {
  withMock(ping,λ()=>String="fake"){ping()="fake"}
}

test "nested withMock uses inner replacement lexically" {
  withMock(ping,λ()=>String="outer"){withMock(ping,λ()=>String="inner"){ping()="inner"}}
}

test "numeric predicates are available in projects" {
  stdlib::numeric.isEven(2)=true and stdlib::numeric.isOdd(3)=true
}

test "pure boolean passes" {
  1+1=2
}

test "withMock can be used in boolean expressions" {
  withMock(ping,λ()=>String="pong"){ping()="pong" and ping()≠"real"}
}
