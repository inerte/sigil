test "blink command picks the farthest walkable tile in a direction" {
  l actors=([•roguelike.playerActor(
    5,
    1,
    •roguelike.point(
      4,
      4
    )
  )]:[µActor]);
  l floors=([
    •roguelike.point(
      4,
      4
    ),
    •roguelike.point(
      5,
      4
    ),
    •roguelike.point(
      6,
      4
    ),
    •roguelike.point(
      7,
      4
    ),
    •roguelike.point(
      8,
      4
    )
  ]:[µPoint]);
  match •roguelike.advance(
    µBlink(µEast()),
    ({
      actorIndex:•roguelike.actorIndexFor(actors),
      actors:actors,
      collectedTreasure:0,
      exit:•roguelike.point(
        35,
        12
      ),
      floorIndex:•roguelike.floorIndexFor(floors),
      floors:floors,
      lastAction:"ready",
      loadout:•roguelike.loadoutWithBlinks(
        1,
        •roguelike.defaultLoadout()
      ),
      pickupIndex:•roguelike.pickupIndexFor(([]:[µPickup])),
      pickups:([]:[µPickup]),
      rooms:[{
        h:1,
        w:5,
        x:4,
        y:4
      }],
      turn:0
    }:µGameState)
  ){
    Some(step)=>step.state.lastAction="blink"
      and (step.state.loadout.blinks:Int)=0
      and (match •roguelike.player(step.state){
        Some(actor)=>•roguelike.samePoint(
          actor.pos,
          •roguelike.point(
            8,
            4
          )
        )|
        None()=>false
      })|
    None()=>false
  }
}

