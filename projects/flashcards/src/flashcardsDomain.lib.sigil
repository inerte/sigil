λallCards()=>[µCard]=[{answer:"Declare dependency identity in topology, then bind it per environment in config/world. Do not hardcode raw URLs in application logic.",id:"topology-vs-config",prompt:"A user wants the same program to talk to different service URLs in local, test, and prod. What should Codex change in Sigil?",references:[{kind:"doc",label:"Docs: topology",route:"/docs/topology/"},{kind:"spec",label:"Spec: topology",route:"/spec/topology/"},{kind:"article",label:"Article: Topology Says What, Config Says How",route:"/articles/topology-vs-config/"}],title:"Topology vs config",topics:["topology","worlds"]},{answer:"The world owns effect interpretation. Keep effects explicit in signatures and vary the world per environment or test instead of inventing mocks.",id:"world-boundary",prompt:"A function needs !Http and !Timer in prod, but tests should swap those behaviors predictably. What Sigil feature owns that boundary?",references:[{kind:"doc",label:"Docs: testing",route:"/docs/testing/"},{kind:"spec",label:"Spec: testing",route:"/spec/testing/"},{kind:"article",label:"Article: Worlds, Not Mocks",route:"/articles/worlds-not-mocks/"}],title:"World-owned effects",topics:["worlds","testing"]},{answer:"Use a named concurrent region. It is Sigil's canonical widening surface for controlled overlap with limits, jitter, and stop policies.",id:"named-concurrency",prompt:"A batch workflow needs width limits, jitter, rate windows, and stop-on-systemic-error semantics. Which Sigil surface should Codex reach for?",references:[{kind:"doc",label:"Docs: async",route:"/docs/async/"},{kind:"spec",label:"Spec: semantics",route:"/spec/semantics/"},{kind:"article",label:"Article: Named Concurrent Regions in Sigil",route:"/articles/named-concurrent-regions/"}],title:"Named concurrent regions",topics:["concurrency"]},{answer:"Look for an explicit decode boundary into a trusted named type. Keep the trust promotion at the edge so the rest of the program can work with the trusted shape.",id:"trusted-boundary",prompt:"A JSON payload enters the system and must become a trusted domain type before app logic uses it. What shape should Codex look for?",references:[{kind:"doc",label:"Docs: type system",route:"/docs/type-system/"},{kind:"spec",label:"Spec: type system",route:"/spec/type-system/"},{kind:"article",label:"Article: Exact Records and Trusted Boundaries",route:"/articles/exact-records-and-trusted-boundaries/"}],title:"Trusted boundaries",topics:["boundaries","types"]},{answer:"Use a constrained or meaning-rich named type when nominal identity matters. Structural shapes are for unconstrained data interchange, not semantic meaning.",id:"nominal-meaning",prompt:"The user wants one domain type to stay meaning-rich even if another record happens to have the same fields. What should Codex choose?",references:[{kind:"doc",label:"Docs: type system",route:"/docs/type-system/"},{kind:"spec",label:"Spec: type system",route:"/spec/type-system/"},{kind:"article",label:"Article: Centralized Project Types and Constrained Type Meanings",route:"/articles/centralized-project-types-and-constrained-type-meanings/"}],title:"Nominal meaning",topics:["types"]},{answer:"Delete the wrapper and call the canonical stdlib or helper surface directly. Sigil prefers one helper name over local aliases.",id:"canonical-helper",prompt:"Codex sees a local helper that only wraps a canonical helper surface over the same parameters. What is the canonical fix?",references:[{kind:"doc",label:"Docs: stdlib",route:"/docs/stdlib/"},{kind:"doc",label:"Docs: philosophy",route:"/docs/philosophy/"},{kind:"article",label:"Article: Canonical Helper Surfaces in Sigil",route:"/articles/canonical-helper-surfaces/"}],title:"Canonical helper surfaces",topics:["canonical"]},{answer:"Use structured machine-first debugging surfaces: test output, replay, spans, and runtime context. Prefer reproducible structured state over handwritten logs.",id:"machine-debugging",prompt:"A test is failing and the instinct is to add ad hoc logs. What is the better Sigil-first approach?",references:[{kind:"doc",label:"Docs: debugging",route:"/docs/debugging/"},{kind:"doc",label:"Docs: testing",route:"/docs/testing/"},{kind:"article",label:"Article: Machine-First Debugging",route:"/articles/machine-first-debugging/"}],title:"Machine-first debugging",topics:["debugging","testing"]},{answer:"Build or select a test world and run the project under it. Tests should derive the world they need instead of smuggling raw endpoints into application code.",id:"testing-worlds",prompt:"A topology-aware project needs deterministic tests for external dependencies. How should Codex structure them?",references:[{kind:"doc",label:"Docs: testing",route:"/docs/testing/"},{kind:"spec",label:"Spec: testing",route:"/spec/testing/"},{kind:"article",label:"Article: Worlds, Not Mocks",route:"/articles/worlds-not-mocks/"}],title:"Testing with worlds",topics:["testing","worlds"]},{answer:"Start in topology to declare the dependency identity, then update the environment config/world binding, then consume the declared handle in application code.",id:"new-service-handle",prompt:"The user asks to add a new external dependency used across environments. Where should Codex start?",references:[{kind:"doc",label:"Docs: topology",route:"/docs/topology/"},{kind:"spec",label:"Spec: topology",route:"/spec/topology/"},{kind:"article",label:"Article: Topology Is Runtime Truth",route:"/articles/topology-is-runtime-truth/"}],title:"Adding a new dependency",topics:["topology","worlds"]},{answer:"Use the CLI JSON/spec docs for the machine-readable contract, then pair them with the debugging/testing docs for how those outputs fit into workflows.",id:"cli-json",prompt:"Codex needs machine-readable compiler or test output for automation. Which docs explain the stable JSON surfaces?",references:[{kind:"doc",label:"Docs: debugging",route:"/docs/debugging/"},{kind:"spec",label:"Spec: CLI JSON",route:"/spec/cli-json/"},{kind:"article",label:"Article: Machine-First Debugging",route:"/articles/machine-first-debugging/"}],title:"CLI JSON surfaces",topics:["debugging","testing"]},{answer:"Canonical source form wins. Prefer the one accepted textual and helper shape so the repo teaches one form to models instead of many aliases.",id:"canonical-source",prompt:"The agent wants to invent a nicer alternate spelling or local helper because it reads better. What principle should win in Sigil?",references:[{kind:"doc",label:"Docs: philosophy",route:"/docs/philosophy/"},{kind:"article",label:"Article: One Canonical Naming System",route:"/articles/021-one-canonical-naming-system/"},{kind:"article",label:"Article: Canonical Helper Surfaces in Sigil",route:"/articles/canonical-helper-surfaces/"}],title:"Canonical source first",topics:["canonical"]},{answer:"Look for the boundary declaration or decoder that turns untrusted input into the named type. That boundary is where field-shape mismatches and trust promotion belong.",id:"boundary-debugging",prompt:"Codex needs to find where a trusted type first enters the system from inbound JSON or another untrusted source. What should it look for?",references:[{kind:"doc",label:"Docs: type system",route:"/docs/type-system/"},{kind:"spec",label:"Spec: CLI JSON",route:"/spec/cli-json/"},{kind:"article",label:"Article: Exact Records and Trusted Boundaries",route:"/articles/exact-records-and-trusted-boundaries/"}],title:"Finding the boundary",topics:["boundaries","debugging"]}]

λhasTopic(target:String,topics:[String])=>Bool match topics{
  []=>false|
  [topic,.rest]=>match topic=target{
    true=>true|
    false=>hasTopic(target,rest)
  }
}

λnextCard(session:µStudySession)=>µStudySession match #session.cards=0 or session.currentIndex+1≥#session.cards{
  true=>session|
  false=>{cards:session.cards,currentIndex:session.currentIndex+1,revealed:false,selectedTopic:session.selectedTopic,topics:session.topics}
}

λpreviousCard(session:µStudySession)=>µStudySession match #session.cards=0 or session.currentIndex=0{
  true=>session|
  false=>{cards:session.cards,currentIndex:session.currentIndex-1,revealed:false,selectedTopic:session.selectedTopic,topics:session.topics}
}

λrevealAnswer(session:µStudySession)=>µStudySession={cards:session.cards,currentIndex:session.currentIndex,revealed:true,selectedTopic:session.selectedTopic,topics:session.topics}

λselectCards(cards:[µCard],selectedTopic:String)=>[µCard] match cards{
  []=>[]|
  [card,.rest]=>match selectedTopic="all" or hasTopic(selectedTopic,card.topics){
    true=>[card]⧺selectCards(rest,selectedTopic)|
    false=>selectCards(rest,selectedTopic)
  }
}

λsessionForTopic(selectedTopic:String)=>µStudySession={cards:(selectCards(allCards(),selectedTopic):[µCard]),currentIndex:0,revealed:false,selectedTopic:selectedTopic,topics:(topicCatalog():[String])}

λtopicCatalog()=>[String]=["all","topology","worlds","types","boundaries","testing","debugging","concurrency","canonical"]
