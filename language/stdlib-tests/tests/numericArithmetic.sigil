test "numeric.lcm handles signs and zero" {
  stdlibâ‹…numeric.lcm(6,8)=24 and stdlibâ‹…numeric.lcm(-6,8)=24 and stdlibâ‹…numeric.lcm(0,7)=0
}

test "numeric.mod uses non-negative remainder" {
  stdlibâ‹…numeric.mod(17,5)=2 and stdlibâ‹…numeric.mod(-17,5)=3 and stdlibâ‹…numeric.mod(17,-5)=2
}

test "numeric.sign returns canonical sign" {
  stdlibâ‹…numeric.sign(-8)=-1 and stdlibâ‹…numeric.sign(0)=0 and stdlibâ‹…numeric.sign(12)=1
