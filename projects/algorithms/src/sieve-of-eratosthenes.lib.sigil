i stdlib‚čÖnumeric

őĽfilter_multiples(prime:‚Ą§,xs:[‚Ą§])‚Üí[‚Ą§] match xs{
  []‚Üí[]|
  [head,.tail]‚Üímatch head%prime=0{
    true‚Üífilter_multiples(prime,tail)|
    false‚Üí[head]‚ßļfilter_multiples(prime,tail)
  }
}

őĽsieve(limit:‚Ą§)‚Üí[‚Ą§] match limit<2{
  true‚Üí[]|
  false‚Üísieve_candidates(stdlib‚čÖnumeric.range(2,limit))
}

őĽsieve_candidates(candidates:[‚Ą§])‚Üí[‚Ą§] match candidates{
  []‚Üí[]|
  [head,.tail]‚Üí[head]‚ßļsieve_candidates(filter_multiples(head,tail))
}
