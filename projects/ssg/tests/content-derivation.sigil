test "article ordering uses newest date first" {
  l pages=([
    article_page("February 24, 2026","older"),
    article_page("March 3, 2026","newer")
  ]:[srcâ‹…types.SitePage]);
  l sorted=(srcâ‹…content.pages_newest_first(pages):[srcâ‹…types.SitePage]);
  sorted[0].meta.slug="newer" and sorted[1].meta.slug="older"
}

test "article ordering falls back to descending source path" {
  l pages=([
    article_page("","001-alpha"),
    article_page("","002-beta")
  ]:[srcâ‹…types.SitePage]);
  l sorted=(srcâ‹…content.pages_newest_first(pages):[srcâ‹…types.SitePage]);
  sorted[0].meta.slug="002-beta" and sorted[1].meta.slug="001-alpha"
}

