mode total

λalgorithmsSuite(root:String)=>µParallelSuite={
  command:sigilCommand(
    [
      "test",
      "projects/algorithms/tests"
    ],
    root
  ),
  label:"algorithms suite"
}

λcanonicalIntegrationSuite(root:String)=>µParallelSuite={
  command:sigilCommand(
    [
      "test",
      "language/integrationTests/tests/canonical.sigil"
    ],
    root
  ),
  label:"canonical integration"
}

λcargo(args:[String],root:String)=>§process.Command=§process.withCwd(
  §process.command(["cargo"]⧺args),
  root
)

λcompilerBin(root:String)=>String=§path.join(
  §path.join(
    §path.join(
      §path.join(
        root,
        "language"
      ),
      "compiler"
    ),
    "target"
  ),
  "debug/sigil"
)

λfailedCommandMessage(command:§process.Command,result:§process.ProcessResult)=>String="command failed: "
  ++renderCommand(command.argv)
  ++" (exit "
  ++(§string.intToString(result.code):String)
  ++")"

λfailedSuiteMessage(suite:µSuiteResult)=>String=failedCommandMessage(
  suite.command,
  suite.result
)

λfeatureFlagStorefrontRoot(root:String)=>String=§path.join(
  §path.join(
    root,
    "projects"
  ),
  "featureFlagStorefront"
)

λfeatureFlagStorefrontSuite(root:String)=>µParallelSuite={
  command:sigilCommandIn(
    [
      "test",
      "tests",
      "--env",
      "test"
    ],
    featureFlagStorefrontRoot(root),
    root
  ),
  label:"feature flag storefront suite"
}

λfinish(result:Result[
  Unit,
  String
])=>!CliIo Unit match result{
  Ok(_)=>{
    l _=(§io.println("All Sigil suites passed"):Unit);
    §process.exit(0)
  }|
  Err(message)=>{
    l _=(§io.eprintln(message):Unit);
    §process.exit(1)
  }
}

