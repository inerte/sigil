i stdlibвЛЕnumeric

ќїmain()вЖТрЭХМ=()

mockable ќїping()вЖТ!IO рЭХК="real"

test "mockable function can be overridden" вЖТ!IO {
  with_mock(ping, ќї()вЖТ!IO рЭХК="fake") {
    ping()="fake"
  }
}

test "nested with_mock uses inner replacement lexically" вЖТ!IO {
  with_mock(ping, ќї()вЖТ!IO рЭХК="outer") {
    with_mock(ping, ќї()вЖТ!IO рЭХК="inner") {
      ping()="inner"
    }
  }
}

test "numeric predicates are available in projects" {
  stdlibвЛЕnumeric.is_even(2)=вК§вИІstdlibвЛЕnumeric.is_odd(3)=вК§
}

test "pure boolean passes" {
  1+1=2
}

test "with_mock can be used in boolean expressions" вЖТ!IO {
  with_mock(ping, ќї()вЖТ!IO рЭХК="pong") {
    ping()="pong"вИІping()вЙ†"real"
  }
}
