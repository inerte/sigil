λbaseConfig(outputDir:String)=>µSiteBuildConfig={basePath:"/",outputDir:outputDir,repoUrl:"https://github.com/inerte/sigil",siteDescription:"Machine-first programming language designed for canonical code generation.",siteTitle:"Sigil",siteUrl:"https://inerte.github.io/sigil"}

λmain()=>Unit=()

test "build site removes stale output files" =>!SiteBuild {
  l outputDir=("/tmp/sigil-ssg-e2e-clean":String);
  l _=(§file.removeTree(outputDir):Unit);
  l _=(§file.makeDirs(outputDir):Unit);
  l _=(§file.writeText("stale",§path.join(outputDir,"stale.txt")):Unit);
  l _=(•build.buildSite(baseConfig(outputDir)):Unit);
  l rootEntries=(§file.listDir(outputDir):[String]);
  §list.contains("stale.txt",rootEntries)=false
}

test "build site renders docs content page" =>!SiteBuild {
  l outputDir=("/tmp/sigil-ssg-e2e-docs":String);
  l _=(§file.removeTree(outputDir):Unit);
  l _=(•build.buildSite(baseConfig(outputDir)):Unit);
  l stdlibDoc=(§file.readText(§path.join(outputDir,"docs/stdlib/index.html")):String);
  §string.contains(stdlibDoc,"Sigil Standard Library")
}

test "build site renders nav sections on homepage" =>!SiteBuild {
  l outputDir=("/tmp/sigil-ssg-e2e-home":String);
  l _=(§file.removeTree(outputDir):Unit);
  l _=(•build.buildSite(baseConfig(outputDir)):Unit);
  l home=(§file.readText(§path.join(outputDir,"index.html")):String);
  §string.contains(home,">Projects<") and §string.contains(home,">Articles<") and §string.contains(home,">Docs<") and §string.contains(home,">Spec<") and §string.contains(home,"placeholder=\"Search projects, docs, articles, and spec pages\"") and §string.contains(home,"/assets/search.js")
}

test "build site writes key output files" =>!SiteBuild {
  l outputDir=("/tmp/sigil-ssg-e2e-files":String);
  l _=(§file.removeTree(outputDir):Unit);
  l _=(•build.buildSite(baseConfig(outputDir)):Unit);
  l about=(§file.readText(§path.join(outputDir,"about-site/index.html")):String);
  l articles=(§file.readText(§path.join(outputDir,"articles/index.html")):String);
  l css=(§file.readText(§path.join(outputDir,"assets/site.css")):String);
  l docs=(§file.readText(§path.join(outputDir,"docs/index.html")):String);
  l notFound=(§file.readText(§path.join(outputDir,"404.html")):String);
  l projects=(§file.readText(§path.join(outputDir,"projects/index.html")):String);
  l siteJson=(§file.readText(§path.join(outputDir,"site.json")):String);
  l spec=(§file.readText(§path.join(outputDir,"spec/index.html")):String);
  §string.contains(about,"About This Site") and §string.contains(articles,"Latest Articles") and #css>0 and §string.contains(docs,"Docs") and §string.contains(notFound,"Page not found") and §string.contains(projects,"Projects") and §string.contains(siteJson,"\"generatedAt\":\"") and §string.contains(spec,"Spec")
}

test "build site writes manifest with repo url and counts" =>!SiteBuild {
  l outputDir=("/tmp/sigil-ssg-e2e-manifest":String);
  l _=(§file.removeTree(outputDir):Unit);
  l _=(•build.buildSite(baseConfig(outputDir)):Unit);
  l manifest=(§file.readText(§path.join(outputDir,"site.json")):String);
  §string.contains(manifest,"\"repoUrl\":\"https://github.com/inerte/sigil\"") and §string.contains(manifest,"\"articlesCount\":\"") and §string.contains(manifest,"\"docsCount\":\"") and §string.contains(manifest,"\"projectsCount\":\"") and §string.contains(manifest,"\"specCount\":\"")
}

