  §string.contains(searchIndex,"\"section\":\"article\"") and §string.contains(searchIndex,"\"title\":\"Worlds, Not Mocks\"") and §string.contains(searchIndex,"\"section\":\"project\"") and §string.contains(searchIndex,"\"title\":\"Sigil TODO\"") and §string.contains(searchIndex,"\"url\":\"/projects/sigil-todo/\"") and §string.contains(searchIndex,"\"sourcePath\":\"projects/todo-app/README.md\"") and §string.contains(searchIndex,"\"title\":\"Sigil Minesweep\"") and §string.contains(searchIndex,"\"url\":\"/projects/sigil-minesweep/\"") and §string.contains(searchIndex,"\"sourcePath\":\"projects/minesweep/README.md\"")
}

