mode total

Î»greaterOrEqual(pivot:Int,xs:[Int])=>[Int]=xs filter (Î»(value:Int)=>Bool=valueâ‰¥pivot)

Î»lessThan(pivot:Int,xs:[Int])=>[Int]=xs filter (Î»(value:Int)=>Bool=value<pivot)

Î»quickSort(xs:[Int])=>[Int]=quickSortInto(
  [],
  xs
)

Î»quickSortInto(acc:[Int],xs:[Int])=>[Int]=quickSortIntoInner(
  acc,
  #xs,
  xs
)

Î»quickSortIntoInner(acc:[Int],fuel:Int,xs:[Int])=>[Int]
requires fuelâ‰¥0
decreases fuel
match fuel=0{
  true=>acc|
  false=>match xs{
    []=>acc|
    [
  pivot,
  .tail
]=>quickSortIntoInner(
      [pivot]â§º(quickSortIntoInner(
        acc,
        fuel-1,
        greaterOrEqual(
          pivot,
          tail
        )
      ):[Int]),
      fuel-1,
      lessThan(
        pivot,
        tail
      )
    )
  }
}
