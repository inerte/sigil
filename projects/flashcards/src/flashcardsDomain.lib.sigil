λhasTopic(target:String,topics:[String])=>Bool match topics{
  []=>false|
  [
  topic,
  .rest
]=>match topic=target{
    true=>true|
    false=>hasTopic(
      target,
      rest
    )
  }
}

λnextCard(session:µStudySession)=>µStudySession match #session.cards=0 or session.currentIndex+1≥#session.cards{
  true=>session|
  false=>{
    cards:session.cards,
    currentIndex:session.currentIndex+1,
    revealed:false,
    selectedTopic:session.selectedTopic,
    topics:session.topics
  }
}

λpreviousCard(session:µStudySession)=>µStudySession match #session.cards=0 or session.currentIndex=0{
  true=>session|
  false=>{
    cards:session.cards,
    currentIndex:session.currentIndex-1,
    revealed:false,
    selectedTopic:session.selectedTopic,
    topics:session.topics
  }
}

λrevealAnswer(session:µStudySession)=>µStudySession
ensures result.revealed
={
  cards:session.cards,
  currentIndex:session.currentIndex,
  revealed:true,
  selectedTopic:session.selectedTopic,
  topics:session.topics
}

λselectCards(cards:[µCard],selectedTopic:String)=>[µCard] match cards{
  []=>[]|
  [
  card,
  .rest
]=>match selectedTopic="all" or hasTopic(
    selectedTopic,
    card.topics
  ){
    true=>[card]⧺selectCards(
      rest,
      selectedTopic
    )|
    false=>selectCards(
      rest,
      selectedTopic
    )
  }
}

λsessionForTopic(selectedTopic:String)=>µStudySession
ensures result.currentIndex=0 and ¬result.revealed
={
  cards:(selectCards(
    allCards(),
    selectedTopic
  ):[µCard]),
  currentIndex:0,
  revealed:false,
  selectedTopic:selectedTopic,
  topics:(topicCatalog():[String])
}

λtopicCatalog()=>[String]=[
  "all",
  "topology",
  "worlds",
  "types",
  "boundaries",
  "labels",
  "contracts",
  "testing",
  "debugging",
  "concurrency",
  "canonical"
]
