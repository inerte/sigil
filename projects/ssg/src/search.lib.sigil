О»allPages(data:ВөSiteData)=>[ВөSitePage]=[data.home,data.articlesIntro,data.projectsIntro]в§әdata.articlesв§әdata.docsв§әdata.projectsв§әdata.specв§әdata.standalone

О»pageText(page:ВөSitePage)=>String=В§string.trim(page.bodyMarkdown)

О»pageValue(page:ВөSitePage)=>В§json.JsonValue=В§json.JsonObject({"description"вҶҰВ§json.JsonString(page.meta.description),"section"вҶҰВ§json.JsonString(вҖўcontent.sectionNameLowercase(page.section)),"sourcePath"вҶҰВ§json.JsonString(page.sourcePath),"text"вҶҰВ§json.JsonString(pageText(page)),"title"вҶҰВ§json.JsonString(page.meta.title),"url"вҶҰВ§json.JsonString(вҖўcontent.canonicalRoute(page))})

О»pagesValue(pages:[ВөSitePage])=>В§json.JsonValue=В§json.JsonArray(pages map pageValue)

О»searchIndexJson(data:ВөSiteData)=>String=В§json.stringify(pagesValue(allPages(data)))
