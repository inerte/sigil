λallCards()=>[µCard]=[
  {
    answer:"Declare dependency identity in topology, then bind it per environment in config/world. Do not hardcode raw URLs in application logic.",
    id:"topology-vs-config",
    prompt:"A user wants the same program to talk to different service URLs in local, test, and prod. What should Codex change in Sigil?",
    references:[
      {
        kind:"doc",
        label:"Docs: topology",
        route:"/docs/topology/"
      },
      {
        kind:"spec",
        label:"Spec: topology",
