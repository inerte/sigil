λdoubleAll(xs:[Int])=>[Int]=xs map (λ(x:Int)=>Int=x*2)

λfilterThenMap(xs:[Int])=>[Int]=xs filter (λ(x:Int)=>Bool=x>0) map (λ(x:Int)=>Int=x*x)

λkeepLarge(xs:[Int])=>[Int]=xs filter (λ(x:Int)=>Bool=x>2)

λmain()=>Int=§list.sum(doubleAll([
  1,
  2,
  3
]))+§list.sum(filterThenMap([
  -2,
  1,
  3
]))+§list.sum(keepLarge([
  1,
  2,
  3,
  4,
  5
]))
