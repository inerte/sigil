]

λrules()=>[µCanonicalRule]=§list.fold(
  [],
  λ(acc:[µCanonicalRule],spec:µCanonicalRuleSpec)=>[µCanonicalRule] match compileRule(spec){
    Ok(rule)=>acc⧺[rule]|
    Err(_)=>acc
  },
  ruleSpecs()
)

λrunCheck()=>!AuditIo Result[
  [µCanonicalIssue],
  String
] match gitTopLevel(){
  Ok(root)=>match gitTrackedFiles(){
    Ok(paths)=>Ok((readIssues(
      paths,
      root,
      rules()
    ):[µCanonicalIssue]))|
    Err(message)=>Err(message)
  }|
  Err(message)=>Err(message)
}
