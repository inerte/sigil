t Event=Changed(String)|Created(String)|Removed(String)

t Watch={id:String}

λclose(watch:Watch)=>!FsWatch Unit=()

λevents(watch:Watch)=>!FsWatch §stream.Source[Event]=(§stream.StreamSource(0):§stream.Source[Event])

λwatch(path:String)=>!FsWatch Owned[Watch]=({id:path}:Owned[Watch])

λwatchAt(path:String,root:§topology.FsRoot)=>!FsWatch Owned[Watch]=({id:path}:Owned[Watch])
