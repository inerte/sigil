      ),
      1
    ))=["§string.trim"],
    •docsDrift.snippetSource(snippet(
      "#xs",
      "docs/test.md",
      fenceInfo(
        None(),
        "expr"
      ),
      1
    ))="λmain()=>Unit=#xs",
    •docsDrift.snippetSubcommand("module")="compile",
    •docsDrift.snippetSubcommandForSnippet(exprSnippet)="parse",
    •docsDrift.snippetVirtualPath(snippet(
      "λsample()=>String=\"ok\"",
      "docs/test.md",
      fenceInfo(
        Some("projects/repoAudit/src/sample.lib.sigil"),
