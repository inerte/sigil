λcommit(transaction:Transaction)=>!Sql Result[
  Unit,
  SqlFailure
]
requires transaction.state=Open
ensures transaction.state=Closed
=Err({
  kind:Unsupported(),
  message:"sql intrinsic unavailable"
})

