test "run check succeeds under a controlled world" =>!AuditIo world {
  c fs=(†fs.sandbox(".local/repoCompile/controlled-world"):†fs.FsEntry)
  c process=(†process.fixture([
  †process.rule(
    [
      "git",
      "rev-parse",
      "--show-toplevel"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:".
"
    }
  ),
  †process.rule(
    [
      "git",
      "ls-files",
      "--cached",
      "--others",
      "--exclude-standard"
    ],
    None(),
    {
      code:0,
      stderr:"",
      stdout:"language/examples/addsNumbers.sigil
"
    }
  ),
  †process.rule(
    (•repoCompile.compilerBinaryHashCommand(".").argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:"compiler-hash
"
    }
  ),
  †process.rule(
    (•repoCompile.compileTargetCommand({
      env:None(),
      path:"language",
      root:"."
    }).argv:[String]),
    Some("."),
    {
      code:0,
      stderr:"",
      stdout:""
    }
  )
]):†process.ProcessEntry)
} {
  match •repoCompile.runCheck(){
    Ok(result)=>result.issues=[]
      and result.stats.compiled+result.stats.cacheHits=1
      and result.stats.considered=1
      and result.stats.durationMs≥0|
    Err(_)=>false
  }
}

