Î»loadPage(config:srcâ‹…types.SiteBuildConfig,section:srcâ‹…types.Section,sourcePath:String)â†’!IO srcâ‹…types.SitePage=
  l markdown=(stdlibâ‹…file.readText(sourcePath):String);
