Î»deleteTodo(targetId:Int,todos:[Â”Todo])=>[Â”Todo]=todos filter (Î»(todo:Â”Todo)=>Bool=todo.id=targetId)

Î»editTodo(newText:String,targetId:Int,todos:[Â”Todo])=>[Â”Todo]=todos map (Î»(todo:Â”Todo)=>Â”Todo match todo.id=targetId{
