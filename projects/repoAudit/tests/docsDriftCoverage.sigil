test "stdlib export helpers parse repo stdlib files" =>!AuditIo {
  l root=(repoRoot():String);
  l readExports=(•docsDrift.readStdlibExports(
    ["language/stdlib/string.lib.sigil"],
    root
  ):Result[
  [String],
  String
]);
  l readExportsInner=(•docsDrift.readStdlibExportsInner(
    [],
    ["language/stdlib/string.lib.sigil"],
    root
  ):Result[
  [String],
  String
]);
  l readMissing=(•docsDrift.readStdlibExports(
    ["language/stdlib/missing.lib.sigil"],
    root
  ):Result[
  [String],
  String
]);
  l fileExports=(•docsDrift.runStdlibExportsForFile("language/stdlib/string.lib.sigil"):Result[
  [String],
  String
]);
  l pathExports=(•docsDrift.runStdlibExportsForPaths(["language/stdlib/string.lib.sigil"]):Result[
  [String],
  String
]);
  l pathExportsInner=(•docsDrift.runStdlibExportsForPathsInner(
    [],
    ["language/stdlib/string.lib.sigil"],
    root
  ):[String]);
  allOk([
    match readExports{
      Ok(exports)=>§list.contains(
        "§string.trim",
        exports
      )|
      Err(_)=>false
    },
    match readExportsInner{
      Ok(exports)=>§list.contains(
        "§string.trim",
        exports
      )|
      Err(_)=>false
    },
    match readMissing{
      Ok(exports)=>exports=[]|
      Err(_)=>false
    },
    match fileExports{
      Ok(exports)=>§list.contains(
        "§string.trim",
        exports
      )|
      Err(_)=>false
    },
    match pathExports{
      Ok(exports)=>§list.contains(
        "§string.trim",
        exports
      )|
      Err(_)=>false
    },
    §list.contains(
      "§string.trim",
      pathExportsInner
    )
  ])
}

