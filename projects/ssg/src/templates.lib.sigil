i srcâ‹…content
i srcâ‹…types

Î»allDocsSection(config:srcâ‹…types.SiteBuildConfig,docs:[srcâ‹…types.SitePage])â†’String=
  "<section class=\"listing\"><h2>Docs</h2><ul class=\"page-list\">"++pageCards(config,docs)++"</ul></section>"

Î»allSpecsSection(config:srcâ‹…types.SiteBuildConfig,spec:[srcâ‹…types.SitePage])â†’String=
  "<section class=\"listing\"><h2>Spec</h2><ul class=\"page-list\">"++pageCards(config,spec)++"</ul></section>"

Î»articleListing(config:srcâ‹…types.SiteBuildConfig,pages:[srcâ‹…types.SitePage])â†’String=
  "<section class=\"listing\"><h2>Latest Articles</h2><ul class=\"page-list\">"++pageCards(config,pages)++"</ul></section>"

Î»articlePage(config:srcâ‹…types.SiteBuildConfig,navHtml:String,page:srcâ‹…types.SitePage)â†’String=
  shell(
    sourceLink(config,page),
    config,
    breadcrumb(config,page),
    page.bodyHtml++navHtml,
    detailMeta(page),
    page.meta.title
  )

Î»articlesIndex(config:srcâ‹…types.SiteBuildConfig,introHtml:String,pages:[srcâ‹…types.SitePage])â†’String=
  shell(
    "",
    config,
    sectionIntro("Design notes and language decisions published from the repo.","Articles"),
    introHtml++articleListing(config,pages),
    "",
    "Articles"
  )

Î»breadcrumb(config:srcâ‹…types.SiteBuildConfig,page:srcâ‹…types.SitePage)â†’String=
  "<nav class=\"breadcrumb\"><a href=\""++siteUrl(config.basePath,"/")++"\">Home</a><span>/</span><a href=\""++sectionUrl(config.basePath,page.section)++"\">"++srcâ‹…content.sectionName(page.section)++"</a></nav>"

Î»detailMeta(page:srcâ‹…types.SitePage)â†’String=
  l author=(page.meta.author:String);
  l date=(page.meta.date:String);
  match (#author>0) or (#date>0){
    trueâ†’"<p class=\"page-meta\">"++detailMetaValue(author,date)++"</p>"|
    falseâ†’""
  }

Î»detailMetaValue(author:String,date:String)â†’String match (#author>0) and (#date>0){
  trueâ†’date++" Â· "++author|
  falseâ†’match #date>0{
    trueâ†’date|
    falseâ†’author
  }
}

Î»docsIndex(config:srcâ‹…types.SiteBuildConfig,pages:[srcâ‹…types.SitePage])â†’String=
  shell(
    "",
    config,
    sectionIntro("Reference docs rendered directly from language/docs.","Docs"),
    "<section class=\"listing\"><ul class=\"page-list\">"++pageCards(config,pages)++"</ul></section>",
    "",
    "Docs"
  )

Î»footer(config:srcâ‹…types.SiteBuildConfig)â†’String match #config.repoUrl>0{
  trueâ†’"<footer class=\"site-footer\"><a href=\""++config.repoUrl++"\">GitHub</a></footer>"|
  falseâ†’"<footer class=\"site-footer\">Sigil</footer>"
}

Î»githubNav(config:srcâ‹…types.SiteBuildConfig)â†’String match #config.repoUrl>0{
  trueâ†’"<a href=\""++config.repoUrl++"\">GitHub</a>"|
  falseâ†’""
}

Î»homePage(articles:[srcâ‹…types.SitePage],config:srcâ‹…types.SiteBuildConfig,docs:[srcâ‹…types.SitePage],home:srcâ‹…types.SitePage,spec:[srcâ‹…types.SitePage])â†’String=
  shell(
    "",
    config,
    sectionIntro(config.siteDescription,config.siteTitle),
    home.bodyHtml++latestArticles(articles,config)++allDocsSection(config,docs)++allSpecsSection(config,spec),
    "",
    home.meta.title
  )

Î»latestArticles(articles:[srcâ‹…types.SitePage],config:srcâ‹…types.SiteBuildConfig)â†’String=
  "<section class=\"listing\"><h2>Latest Articles</h2><ul class=\"page-list\">"++pageCards(config,srcâ‹…content.takeFirst(5,articles))++"</ul><p><a href=\""++siteUrl(config.basePath,"/articles/")++"\" class=\"view-all\">View all articles â†’</a></p></section>"

Î»nav(config:srcâ‹…types.SiteBuildConfig)â†’String=
  "<header class=\"site-header\"><div class=\"site-brand\"><a href=\""++siteUrl(config.basePath,"/")++"\">"++config.siteTitle++"</a></div><nav class=\"site-nav\"><a href=\""++siteUrl(config.basePath,"/articles/")++"\">Articles</a><a href=\""++siteUrl(config.basePath,"/docs/")++"\">Docs</a><a href=\""++siteUrl(config.basePath,"/spec/")++"\">Spec</a>"++githubNav(config)++"</nav></header>"

Î»notFoundPage(config:srcâ‹…types.SiteBuildConfig)â†’String=
  shell(
    "",
    config,
    sectionIntro("The requested route does not exist.","Page not found"),
    "<p><a href=\""++siteUrl(config.basePath,"/")++"\">Return home</a></p>",
    "",
    "Not Found"
  )

Î»pageCard(config:srcâ‹…types.SiteBuildConfig,page:srcâ‹…types.SitePage)â†’String=
  "<li class=\"page-card\" data-section=\""++srcâ‹…content.sectionNameLowercase(page.section)++"\"><a class=\"page-link\" href=\""++siteUrl(config.basePath,srcâ‹…content.canonicalRoute(page))++"\">"++page.meta.title++"</a>"++pageCardMeta(page)++pageCardDescription(page)++"</li>"

Î»pageCardDescription(page:srcâ‹…types.SitePage)â†’String match #page.meta.description>0{
  trueâ†’"<div class=\"page-card-desc\">"++page.meta.description++"</div>"|
  falseâ†’""
}

Î»pageCardMeta(page:srcâ‹…types.SitePage)â†’String match #page.meta.date>0{
  trueâ†’"<div class=\"page-card-meta\">"++page.meta.date++"</div>"|
  falseâ†’""
}

Î»pageCards(config:srcâ‹…types.SiteBuildConfig,pages:[srcâ‹…types.SitePage])â†’String match pages{
  []â†’""|
  [page,.rest]â†’pageCard(config,page)++pageCards(config,rest)
}

Î»referenceList(config:srcâ‹…types.SiteBuildConfig,heading:String,pages:[srcâ‹…types.SitePage])â†’String=
  "<section class=\"listing compact\"><h2>"++heading++"</h2><ul class=\"page-list\">"++pageCards(config,srcâ‹…content.takeFirst(6,pages))++"</ul></section>"

Î»referenceLists(config:srcâ‹…types.SiteBuildConfig,docs:[srcâ‹…types.SitePage],spec:[srcâ‹…types.SitePage])â†’String=
  "<div class=\"home-grid secondary\">"++referenceList(config,"Docs",docs)++referenceList(config,"Spec",spec)++"</div>"

Î»sectionCard(body:String,config:srcâ‹…types.SiteBuildConfig,cta:String,heading:String,route:String)â†’String=
  "<section class=\"section-card\"><h2>"++heading++"</h2><p>"++body++"</p><a class=\"cta\" href=\""++siteUrl(config.basePath,route)++"\">"++cta++"</a></section>"

Î»sectionIntro(body:String,title:String)â†’String=
  "<section class=\"section-intro\"><h1>"++title++"</h1><p>"++body++"</p></section>"

Î»sectionUrl(basePath:String,section:srcâ‹…types.Section)â†’String match section{
  srcâ‹…types.Article()â†’siteUrl(basePath,"/articles/")|
  srcâ‹…types.Doc()â†’siteUrl(basePath,"/docs/")|
  srcâ‹…types.Home()â†’siteUrl(basePath,"/")|
  srcâ‹…types.Spec()â†’siteUrl(basePath,"/spec/")
}

Î»shell(aside:String,config:srcâ‹…types.SiteBuildConfig,intro:String,mainHtml:String,meta:String,title:String)â†’String=
  "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>"++title++" Â· "++config.siteTitle++"</title><meta name=\"description\" content=\""++config.siteDescription++"\"><link rel=\"stylesheet\" href=\""++siteUrl(config.basePath,"/assets/site.css")++"\"><link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css\"></head><body><div class=\"site-shell\">"++nav(config)++"<main class=\"site-main\">"++intro++meta++"<article class=\"prose\">"++mainHtml++"</article>"++aside++"</main>"++footer(config)++"</div><script src=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js\"></script><script src=\"https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/bash.min.js\"></script><script>hljs.highlightAll();</script></body></html>"

Î»siteUrl(basePath:String,route:String)â†’String=srcâ‹…content.basePathPrefix(basePath,route)

Î»sourceLink(config:srcâ‹…types.SiteBuildConfig,page:srcâ‹…types.SitePage)â†’String match #config.repoUrl>0{
  trueâ†’"<p class=\"source-link\"><a href=\""++config.repoUrl++"/blob/main/"++page.sourcePath++"\">View source on GitHub</a></p>"|
  falseâ†’""
}

Î»specIndex(config:srcâ‹…types.SiteBuildConfig,pages:[srcâ‹…types.SitePage])â†’String=
