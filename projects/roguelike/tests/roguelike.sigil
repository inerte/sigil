        •roguelike.point(
          13,
          10
        )
      )
    ],
    •roguelike.point(
      35,
      12
    ),
    ([]:[µPickup]),
    0
  ):µGameState);
  match •roguelike.stepEnemyRetreat(
    2,
    •roguelike.point(
      0,
      0
    ),
    •roguelike.demoState(
      [
        •roguelike.playerActor(
          5,
          1,
          •roguelike.point(
            1,
            1
          )
        ),
        •roguelike.archerActor(
          2,
          2,
          •roguelike.point(
            0,
            0
          )
        )
      ],
      •roguelike.point(
        35,
        12
      ),
      ([]:[µPickup]),
      0
    ),
    •roguelike.point(
      1,
      1
    )
  ){
    None()=>match •roguelike.findActorById(
      1,
      •roguelike.stepEnemyBrute(
        •roguelike.bruteActor(
          4,
          2,
          •roguelike.point(
            4,
            4
          )
        ),
        bruteState
      ).actors
    ){
      Some(bruteHit)=>match •roguelike.findActorById(
        2,
        •roguelike.stepEnemyShaman(
          •roguelike.shamanActor(
            2,
            5,
            •roguelike.point(
              12,
              10
            )
          ),
          shamanState
        ).actors
      ){
        Some(healed)=>•roguelike.shamanHealTarget(
          •roguelike.shamanActor(
            2,
            5,
            •roguelike.point(
              12,
              10
            )
          ),
          •roguelike.goblinActor(
            1,
            2,
            •roguelike.point(
              13,
              10
            )
          ),
          shamanState
        )
          and •roguelike.shamanMoveTarget(
            •roguelike.shamanActor(
              2,
              5,
              •roguelike.point(
                12,
                10
              )
            ),
            •roguelike.goblinActor(
              1,
              2,
              •roguelike.point(
                13,
                10
              )
            )
          )
          and •roguelike.playerHp(•roguelike.stepEnemyBrute(
            •roguelike.bruteActor(
              4,
              2,
              •roguelike.point(
                4,
                4
              )
            ),
            bruteState
          ))=3
          and healed.hp=2|
        None()=>false
      }|
      None()=>false
    }|
    Some(_)=>false
  }
}
