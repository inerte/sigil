t Environment=Environment(String)

t HttpServiceDependency=HttpServiceDependency(String)

t TcpServiceDependency=TcpServiceDependency(String)

λenvironment(name:String)=>Environment=Environment(name)

λhttpService(name:String)=>HttpServiceDependency=HttpServiceDependency(name)

λtcpService(name:String)=>TcpServiceDependency=TcpServiceDependency(name)
