Î»loadSiteData(config:srcâ‹…types.SiteBuildConfig)â†’!IO srcâ‹…types.SiteData=
  l home=(loadPage(config,srcâ‹…types.Home(),"website/README.md"):srcâ‹…types.SitePage);
  l articlesIntro=(loadPage(config,srcâ‹…types.Article(),"website/articles/README.md"):srcâ‹…types.SitePage);
  l articles=(loadArticles(config):[srcâ‹…types.SitePage]);
  l docs=(loadDocs(config):[srcâ‹…types.SitePage]);
  l spec=(loadSpec(config):[srcâ‹…types.SitePage]);
  {
    articles:articles,
    articlesIntro:{
      bodyHtml:articlesIntro.bodyHtml,
      bodyMarkdown:articlesIntro.bodyMarkdown,
      meta:articlesIntro.meta,
      outputDir:"articles",
      section:articlesIntro.section,
      sourcePath:articlesIntro.sourcePath
    },
    docs:docs,
    home:{
      bodyHtml:home.bodyHtml,
      bodyMarkdown:home.bodyMarkdown,
      meta:home.meta,
      outputDir:"",
      section:home.section,
      sourcePath:home.sourcePath
    },
    spec:spec
  }

Î»loadSpec(config:srcâ‹…types.SiteBuildConfig)â†’!IO [srcâ‹…types.SitePage]=
