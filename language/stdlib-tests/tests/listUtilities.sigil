test "list.product multiplies integer lists" {
  stdlibâ‹…list.product([])=1 and stdlibâ‹…list.product([2,3,4])=24 and stdlibâ‹…list.product([5,-2,1])=-10
}

test "list.removeFirst removes only first match" {
  stdlibâ‹…list.removeFirst(2,[1,2,3,2])=[1,3,2] and stdlibâ‹…list.removeFirst(9,[1,2,3])=[1,2,3] and stdlibâ‹…list.removeFirst(9,[])=[]
}

test "list.reverse reverses list" {
  stdlibâ‹…list.reverse([])=[] and stdlibâ‹…list.reverse([1])=[1] and stdlibâ‹…list.reverse([1,2,3])=[3,2,1]
}

test "list.sum sums integer lists" {
  stdlibâ‹…list.sum([])=0 and stdlibâ‹…list.sum([1,2,3,4])=10 and stdlibâ‹…list.sum([5,-2,1])=4
}

test "list.take clamps naturally" {
  stdlibâ‹…list.take(0,[1,2,3])=[] and stdlibâ‹…list.take(2,[1,2,3,4])=[1,2] and stdlibâ‹…list.take(10,[1,2])=[1,2] and stdlibâ‹…list.take(-1,[1,2])=[]
}
