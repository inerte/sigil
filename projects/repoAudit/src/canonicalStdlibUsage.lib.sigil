  },
  {
    name:"startsWith",
    pattern:"^λstartsWith\\(([a-z][A-Za-z0-9]*):String,[a-z][A-Za-z0-9]*:String\\)=>Bool(?==| match)",
    replacement:"§string.startsWith"
  },
  {
    name:"substring",
    pattern:"^λsubstring\\(([a-z][A-Za-z0-9]*):Int,[a-z][A-Za-z0-9]*:String,[a-z][A-Za-z0-9]*:Int\\)=>String(?==| match)",
    replacement:"§string.substring"
  },
  {
    name:"sum",
    pattern:"^λsum\\(([a-z][A-Za-z0-9]*):\\[Int\\]\\)=>Int(?==| match)",
    replacement:"§list.sum"
  },
  {
    name:"takeList",
    pattern:"^λtake\\[([A-Z][A-Za-z0-9]*)\\]\\([a-z][A-Za-z0-9]*:Int,[a-z][A-Za-z0-9]*:\\[\\1\\]\\)=>\\[\\1\\](?==| match)",
    replacement:"§list.take"
  },
  {
