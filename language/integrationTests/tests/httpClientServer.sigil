λhttpCommand(args:[String])=>§process.Command=•support.sigilIn(args,projectDir())

λmain()=>Unit=()

λprojectDir()=>String=•support.repoPath("projects/topology-http")

λrawClientFile()=>String=§path.join(projectDir(),"src/rawEndpointClient.sigil")

λrawClientSource()=>String="λmain()=>!Http String match §httpClient.get(\"http://127.0.0.1:45110\",§httpClient.emptyHeaders(),\"/health\"){
  Ok(response)=>response.body|
  Err(error)=>error.message
}
"

λrawEndpointCompileOutput()=>!Fs!Process String={
  l _=(§file.writeText(rawClientSource(),rawClientFile()):Unit);
  l result=(§process.run(httpCommand(["compile","src/rawEndpointClient.sigil"])):§process.ProcessResult);
  l _=(§file.remove(rawClientFile()):Unit);
  •support.combinedOutput(result)
}

λrunClientOutput(target:String)=>!Process!Timer String={
  l server=(§process.start(httpCommand(["run","src/httpRoundtripServer.sigil","--env","test"])):§process.RunningProcess);
  l ready=(•support.retryRunStdoutContains(50,httpCommand(["run","src/getClient.sigil","--env","test"]),200,"200:healthy"):§process.ProcessResult);
  l result=match •support.runStdoutContains("200:healthy",ready){
    true=>(§process.run(httpCommand(["run",target,"--env","test"])):§process.ProcessResult)|
    false=>ready
  };
  l _=(§process.kill(server):Unit);
  l _=(§process.wait(server):§process.ProcessResult);
  •support.combinedOutput(result)
}

λvalidateResult()=>!Process §process.ProcessResult=§process.run(httpCommand(["validate",".","--env","test"]))

test "http topology validates for test env" =>!Process {
  l result=(validateResult():§process.ProcessResult);
  result.code=0
}

test "http get client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/getClient.sigil"),"200:healthy")≥0=true
}

test "http post client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/postClient.sigil"),"201:echoed")≥0=true
}

test "http json client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/jsonClient.sigil"),"{\"ok\":true}")≥0=true
}

test "http headers client reaches roundtrip server" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/headersClient.sigil"),"202:abc-123")≥0=true
}

test "http missing client returns 404" =>!Process!Timer {
  §string.indexOf(runClientOutput("src/missingClient.sigil"),"404:<h1>404 Not Found</h1>")≥0=true
}

test "http routes client returns canonical route summary" =>!Process!Timer {
  l output=(runClientOutput("src/routesClient.sigil"):String);
  §string.indexOf(output,"200:/echo")≥0=true and §string.indexOf(output,"/routes")≥0=true
}

test "http raw endpoint compile is forbidden" =>!Fs!Process {
  §string.indexOf(rawEndpointCompileOutput(),"SIGIL-TOPO-RAW-ENDPOINT-FORBIDDEN")≥0=true
}
