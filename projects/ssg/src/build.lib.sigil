Î»filterMarkdownFiles(files:[String])â†’[String] match files{
  []â†’[]|
  [file,.rest]â†’match stdlibâ‹…string.endsWith(file,".md"){
    trueâ†’[file]â§şfilterMarkdownFiles(rest)|
