λmain()=>Unit=()

λsampleChecksums()=>String=§string.unlines([
  "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa  sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz",
  "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb  sigil-2026-03-11T14-58-24Z-darwin-x64.tar.gz",
  "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc  sigil-2026-03-11T14-58-24Z-linux-arm64.tar.gz",
  "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd  sigil-2026-03-11T14-58-24Z-linux-x64.tar.gz"
])

test "archive name uses release naming convention" {
  •formula.archiveName(
    "darwin-arm64",
    "2026-03-11T14-58-24Z"
  )="sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz"
}

test "archive url points at GitHub release assets" {
  •formula.archiveUrl(
    "darwin-arm64",
    "inerte/sigil",
    "2026-03-11T14-58-24Z"
  )="https://github.com/inerte/sigil/releases/download/2026-03-11T14-58-24Z/sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz"
}

test "checksum line rejects malformed input" {
  match •formula.checksumLine("not-a-checksum"){
    Some(_)=>false|
    None()=>true
  }
}

test "checksum line parts reject missing archive name" {
  match •formula.checksumLineParts(["aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"]){
    Some(_)=>false|
    None()=>true
  }
}

test "find checksum returns none for missing archive" {
  match •formula.findChecksum(
    "missing.tar.gz",
    [({
      archive:"sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz",
      sha256:"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    }:µChecksumEntry)]
  ){
    Some(_)=>false|
    None()=>true
  }
}

test "formula renders release version and platform checksums" {
  l text=•formula.formula({
    checksums:{
      darwinArm64:"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      darwinX64:"bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      linuxArm64:"cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      linuxX64:"dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
    },
    repo:"inerte/sigil",
    version:"2026-03-11T14-58-24Z"
  });
  §string.contains(
    text,
    "sha256 \"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\""
  )
    and §string.contains(
      text,
      "depends_on \"node\""
    )
    and §string.contains(
      text,
      "pkgshare.install \"language\""
    )
    and §string.contains(
      text,
      "sigil 2026-03-11T14-58-24Z"
    )
    and §string.contains(
      text,
      "https://github.com/inerte/sigil/releases/download/2026-03-11T14-58-24Z/sigil-2026-03-11T14-58-24Z-linux-x64.tar.gz"
    )
}

test "formula smoke-tests installed compile and test flow" {
  l text=•formula.formula({
    checksums:{
      darwinArm64:"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      darwinX64:"bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      linuxArm64:"cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      linuxX64:"dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
    },
    repo:"inerte/sigil",
    version:"2026-03-11T14-58-24Z"
  });
  §string.contains(
    text,
    "system bin/\"sigil\", \"init\""
  )
    and §string.contains(
      text,
      "system bin/\"sigil\", \"inspect\", \"codegen\", \"src/main.sigil\""
    )
    and §string.contains(
      text,
      "system bin/\"sigil\", \"compile\", \".\""
    )
    and §string.contains(
      text,
      "system bin/\"sigil\", \"test\""
    )
}

test "parse checksums extracts all release digests" {
  match •formula.parseChecksums(
    sampleChecksums(),
    "2026-03-11T14-58-24Z"
  ){
    Some(checksums)=>checksums.darwinArm64="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      and checksums.darwinX64="bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
      and checksums.linuxArm64="cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
      and checksums.linuxX64="dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"|
    None()=>false
  }
}

test "parse checksums returns none when a platform digest is missing" {
  match •formula.parseChecksums(
    §string.unlines(["aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa  sigil-2026-03-11T14-58-24Z-darwin-arm64.tar.gz"]),
    "2026-03-11T14-58-24Z"
  ){
    Some(_)=>false|
    None()=>true
  }
}
