λallOk(results:[Bool])=>Bool=§list.all(
  λ(result:Bool)=>Bool=result,
  results
)

λmain()=>Unit=()

test "compile target commands use repo relative output paths" {
  l languageTask=({
    env:None(),
    path:"language",
    root:"/repo"
  }:µRepoCompileTask);
  l installCommand=(•repoCompile.installDependenciesCommand(
    "projects/featureFlagStorefront",
    "/repo"
  ):§process.Command);
  allOk([
    •repoCompile.compileTargetCommand(languageTask).argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "compile",
      "language"
    ],
    •repoCompile.compileTargetCommand({
      env:Some("test"),
      path:"projects/featureFlagStorefront",
      root:"/repo"
    }).argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "compile",
      "projects/featureFlagStorefront",
      "--env",
      "test"
    ],
    match •repoCompile.compileTargetCommand(languageTask).cwd{
      Some(cwd)=>cwd="/repo"|
      None()=>false
    },
    installCommand.argv=[
      §path.join(
        "/repo",
        "language/compiler/target/debug/sigil"
      ),
      "package",
      "install"
    ],
    match installCommand.cwd{
      Some(cwd)=>cwd="/repo/projects/featureFlagStorefront"|
      None()=>false
    }
  ])
}

test "compile target discovery keeps canonical roots and upgrades env" {
  •repoCompile.compileTargets([
    "language/examples/addsNumbers.sigil",
    "projects/featureFlagStorefront/src/main.sigil",
    "projects/featureFlagStorefront/config/test.lib.sigil",
    "projects/featureFlagStorefront/.sigil/packages/featureFlagStorefrontFlags/src/package.lib.sigil",
    "projects/featureFlagStorefrontFlags/src/package.lib.sigil",
    "projects/repoAudit/.local/src/main.sigil",
    "README.md"
  ])=([
    {
      env:None(),
      path:"language"
    },
    {
      env:Some("test"),
      path:"projects/featureFlagStorefront"
    },
    {
      env:None(),
      path:"projects/featureFlagStorefrontFlags"
    }
  ]:[µRepoCompileTarget])
}

test "process output prefers stderr then stdout" {
  allOk([
    •repoCompile.containsString(
      [
        "alpha",
        "beta"
      ],
      "beta"
    ),
    ¬•repoCompile.containsString(
      [
        "alpha",
        "beta"
      ],
      "gamma"
    ),
    •repoCompile.isTestConfigPath("projects/featureFlagStorefront/config/test.lib.sigil"),
    ¬•repoCompile.isTestConfigPath("projects/featureFlagStorefront/config/prod.lib.sigil"),
    •repoCompile.isTrackedSigilPath("language/examples/addsNumbers.sigil"),
    ¬•repoCompile.isTrackedSigilPath("projects/repoAudit/.local/src/main.sigil"),
    •repoCompile.processOutput({
      code:1,
      stderr:" boom ",
      stdout:"ok"
    })="boom",
    •repoCompile.processOutput({
      code:1,
      stderr:"",
      stdout:" ok "
    })="ok"
  ])
}

test "parse compile issue decodes structured compiler failures" {
  •repoCompile.parseCompileIssue("{\"error\":{\"message\":\"boom\",\"details\":{\"file\":\"language/examples/demo.sigil\"}}}")=Some({
    message:"compile failed: boom",
    path:"language/examples/demo.sigil"
  })
}

test "parse compile issue falls back on invalid json" {
  match •repoCompile.parseCompileIssue("nope"){
    Some(_)=>false|
    None()=>true
  }
}

test "fallback and helper none paths stay stable" {
  l empty=(({↦}:{String↦§json.JsonValue}):{String↦§json.JsonValue});
  allOk([
    •repoCompile.fallbackCompileIssue({
      code:1,
      stderr:"",
      stdout:" bad "
    })={
      message:"compile failed: bad",
      path:"."
    },
    match •repoCompile.compileIssuePath(empty){
      Some(_)=>false|
      None()=>true
    },
    match •repoCompile.jsonObjectField(
      "details",
      empty
    ){
      Some(_)=>false|
      None()=>true
    },
    match •repoCompile.jsonStringField(
      "message",
      empty
    ){
      Some(_)=>false|
      None()=>true
    },
    •repoCompile.packageInstallIssue(
      "projects/featureFlagStorefront",
      {
        code:1,
        stderr:" boom ",
        stdout:""
      }
    )={
      message:"package install failed: boom",
      path:"projects/featureFlagStorefront"
    },
    match •repoCompile.projectRootForTrackedPath("language/examples/addsNumbers.sigil"){
      Some(_)=>false|
      None()=>true
    },
    •repoCompile.projectRootForTrackedPath("projects/router/src/main.sigil")=Some("projects/router"),
    •repoCompile.secondPathSegment("projects/router/src/main.sigil")=Some("router"),
    match •repoCompile.secondPathSegment("projects"){
      Some(_)=>false|
      None()=>true
    },
    •repoCompile.mergeCompileTargetEnv(
      None(),
      Some("test")
    )=Some("test"),
    •repoCompile.mergeCompileTargetEnv(
      None(),
      None()
    )=(None():Option[String])
  ])
}

test "merge compile task outcomes preserves input order" {
  •repoCompile.mergeCompileTaskOutcomes(
    [],
    [
      Success(()),
      Failure({
        message:"compile failed: boom",
        path:"projects/featureFlagStorefront/src/main.sigil"
      })
    ],
    ([
      {
        env:None(),
        path:"language",
        root:"/repo"
      },
      {
        env:Some("test"),
        path:"projects/featureFlagStorefront",
        root:"/repo"
      },
      {
        env:None(),
        path:"projects/router",
        root:"/repo"
      }
    ]:[µRepoCompileTask])
  )=[
    {
      message:"compile failed: boom",
      path:"projects/featureFlagStorefront/src/main.sigil"
    },
    {
      message:"compile aborted",
      path:"projects/router"
    }
  ]
}

test "dependency project detection reads non-empty dependency maps" =>!Fs world {
  c fs=(†fs.sandbox(".local/repoCompile/dependencies"):†fs.FsEntry)
} {
  l _=(§file.makeDirs("projects/featureFlagStorefront"):Unit);
  l _=(§file.makeDirs("projects/demo"):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"featureFlagStorefront\",
  \"version\": \"2026-04-12T14-30-00Z\",
  \"dependencies\": {
    \"featureFlagStorefrontFlags\": \"2026-04-12T14-00-00Z\"
  }
}
",
    "projects/featureFlagStorefront/sigil.json"
  ):Unit);
  l _=(§file.writeText(
    "{
  \"name\": \"demoApp\",
  \"version\": \"2026-04-05T14-58-24Z\"
}
",
    "projects/demo/sigil.json"
  ):Unit);
  •repoCompile.dependencyProjectDirs(
    [
      "projects/featureFlagStorefront/sigil.json",
      "projects/demo/sigil.json"
    ],
    "."
  )=["projects/featureFlagStorefront"]
}

test "git top level surfaces process failure" =>!Process world {
  c process=(†process.fixture([†process.rule(
  [
    "git",
    "rev-parse",
    "--show-toplevel"
  ],
  None(),
  {
    code:1,
    stderr:"boom",
    stdout:""
  }
)]):†process.ProcessEntry)
} {
  match •repoCompile.gitTopLevel(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  }
}

